<[

library c:\sdweb\home\websites\fgl\libs\system.flb

class soapAllType
		local	node
		local	minOccurs
		local	maxOccurs
		local	children

		method GenCode ( schemaNS, elems, code, defs, init, top, genElems, name )
			local loop;

			for ( loop = 1; loop <= len ( ::children ); loop++ )
				::children[loop].GenCode ( schemaNS, elems, code, defs, init, 0, genElems, name )
			end

			return ( 1 )
			top;
		end

		method	New ( node )
			local loop

			::node = node
			::minOccurs	= ::node.Attributes.GetNamedItem ( "minOccurs" )
			::maxOccurs	= ::node.Attributes.GetNamedItem ( "maxOccurs" )

			::node = node

			::children={}

			for ( loop = 0; loop < node.ChildNodes.Length;  loop++ )
				switch ( UPPER ( node.ChildNodes.Array[loop].TagName ) )
					case "ELEMENT"
						::children[len(::children) +1] = new ( "soapElementType", node.ChildNodes.Array[loop] )
						break;
					case "SIMPLETYPE"
						::children[len(::children) +1] = new ( "soapSimpleType", node.ChildNodes.Array[loop] )
						break;
					case "SEQUENCE"
						::children[len(::children) +1] = new ( "soapSequenceType", node.ChildNodes.Array[loop] )
						break;
					case "EXTENSION"
						::children[len(::children) +1] = new ( "soapExtensionType", node.ChildNodes.Array[loop] )
						break;
					default:
						return ( 0 );
				end
			end

			return ( 1 )
		end
end

class soapRestrictionType
	local	node
	local	base
	local 	enumerations
	local	fractionDigits
	local	maxExclusive
	local	maxInclusive
	local	maxLength
	local	minExclusive
	local	minInclusive
	local	minLength
	local	pattern
	local	totalDigits
	local	whiteSpace
	local	child

	method GenCode ( schemaNS, elems, code, defs, init, top, genElems, name )
		if ( ::child )
			::child.GenCode ( schemaNS, elems, code, defs, init, 0, genElems, name )
		end

		if ( ::enumerations )
			init += "		::" + name + " = \"" + ::enumerations[1] + "\"\r\n"
		end

		return ( 1 )
		top;
	end

	method New ( node )
		local loop

		::node = node
		::base		= ::node.Attributes.GetNamedItem ( "base" )

		for ( loop = 0; loop < node.ChildNodes.Length;  loop++ )
			switch ( UPPER ( node.ChildNodes.Array[loop].TagName ) )
				case "MAXEXCLUSIVE"
					::maxExclusive = node.ChildNodes.Array[loop].Attributes.GetNamedItem ( "value" )
					break;
				case "MAXINCLUSIVE"
					::maxInclusive = node.ChildNodes.Array[loop].Attributes.GetNamedItem ( "value" )
					break;
				case "MAXLENGTH"
					::maxLength = node.ChildNodes.Array[loop].Attributes.GetNamedItem ( "value" )
					break;
				case "MINEXCLUSIVE"
					::minExclusive = node.ChildNodes.Array[loop].Attributes.GetNamedItem ( "value" )
					break;
				case "MININCLUSIVE"
					::minInclusive = node.ChildNodes.Array[loop].Attributes.GetNamedItem ( "value" )
					break;
				case "MINLENGTH"
					::minLength = node.ChildNodes.Array[loop].Attributes.GetNamedItem ( "value" )
					break;
				case "PATTERN"
					::pattern = node.ChildNodes.Array[loop].Attributes.GetNamedItem ( "value" )
					break;
				case "TOTALDIGITS"
					::totalDigits = node.ChildNodes.Array[loop].Attributes.GetNamedItem ( "value" )
					break;
				case "WHITESPACE"
					::whiteSpace = node.ChildNodes.Array[loop].Attributes.GetNamedItem ( "value" )
					break;
				case "ENUMERATION"
					::enumerations[len ( ::enumerations ) + 1] = node.ChildNodes.Array[loop].Attributes.GetNamedItem ( "value" )
					break;
				case "SIMPLETYPE"
					::child = new ( "soapSimpleType", node.ChildNodes.Array[loop] )
					break;
				case "SEQUENCE"
					::child = new ( "soapSequenceType", node.ChildNodes.Array[loop] )
					break;
				case "ALL"
					::child = new ( "soapAllType", node.ChildNodes.Array[loop] )
					break;
				default:
					return ( 0 );
			end
		end


		return ( 1 )
	end
end

class soapExtensionType
		local	name
		local	node
		local	base
		local	child

	public:

		method GenCode ( schemaNS, elems, code, defs, init, top, genElems, name )
			elems[token ( ::base, ":", 2 )][1].GenCode ( schemaNS, elems, code, defs, init, 0, genElems, name )
			if ( ::child )
				::child.GenCode ( schemaNS, elems, code, defs, init, 0, genElems, name )
			end

			return ( 1 )
			top;
		end

		method New ( node )
			::node = node

			::name		= ::node.Attributes.GetNamedItem ( "name" )
			::base		= ::node.Attributes.GetNamedItem ( "base" )


			if ( node.FirstChild )
				switch ( UPPER ( node.FirstChild.tagName ) )
					case "GROUP"
						::child = new ( "soapGroupType", node.FirstChild )
						break;
					case "SEQUENCE"
						::child = new ( "soapSequenceType", node.FirstChild )
						break;
					case "ALL"
						::child = new ( "soapAllType", node.FirstChild )
						break;
					default:
						return ( 0 );
				end
			end

			return ( 1 )
		end
end

class soapSequenceType
		local 	name
		local	node
		local	minOccurs
		local	maxOccurs
		local	children

		method GenCode ( schemaNS, elems, code, defs, init, top, genElems, name )
			local loop;

			for ( loop = 1; loop <= len ( ::children ); loop++ )
				::children[loop].GenCode ( schemaNS, elems, code, defs, init, 0, genElems, name )
			end

			return ( 1 )
			top;
		end

		method	New ( node )
			local loop

			::node = node
			::name		= ::node.Attributes.GetNamedItem ( "name" )
			::minOccurs	= ::node.Attributes.GetNamedItem ( "minOccurs" )
			::maxOccurs	= ::node.Attributes.GetNamedItem ( "maxOccurs" )

			::node = node

			::children={}

			for ( loop = 0; loop < node.ChildNodes.Length;  loop++ )
				switch ( UPPER ( node.ChildNodes.Array[loop].TagName ) )
					case "ELEMENT"
						::children[len(::children) +1] = new ( "soapElementType", node.ChildNodes.Array[loop] )
						break;
					case "SIMPLETYPE"
						::children[len(::children) +1] = new ( "soapSimpleType", node.ChildNodes.Array[loop] )
						break;
					case "SEQUENCE"
						::children[len(::children) +1] = new ( "soapSequenceType", node.ChildNodes.Array[loop] )
						break;
					default:
						return ( 0 );
				end
			end

			return ( 1 )
		end
end

class soapComplexType
		local	name
		local	node
		local	abstract
		local	mixed
		local	block
		local	final
		local	children

	public:

		method GenCode ( schemaNS, elems, code, defs, init, top, genElems, name )
			local loop

			if ( top )
				if ( !elems[::name][2] )
					elems[::name][2] = 1
					defs += "	inherit	soap_msg_base\r\n"
				end
			end

			for ( loop = 1; loop <= len ( ::children ); loop++ )
				::children[loop].GenCode ( schemaNS, elems, code, defs, init, 0, genElems, name )
			end

			return ( 1 )
		end

		method New ( node )
			local loop

			::node = node
			::name		= ::node.Attributes.GetNamedItem ( "name" )
			::abstract	= ::node.Attributes.GetNamedItem ( "abstract" )
			::mixed		= ::node.Attributes.GetNamedItem ( "mixed" )
			::block		= ::node.Attributes.GetNamedItem ( "block" )
			::final		= ::node.Attributes.GetNamedItem ( "final" )

			::children={}
			for ( loop = 0; loop < node.ChildNodes.Length;  loop++ )
				switch ( UPPER ( node.ChildNodes.Array[loop].TagName ) )
					case "SEQUENCE"
						::children[len(::children) +1] = new ( "soapSequenceType", node.ChildNodes.Array[loop] )
						break;
					case "SIMPLETYPE"
						::children[len(::children) +1] = new ( "soapSimpleType", node.ChildNodes.Array[loop] )
						break;
					case "SIMPLECONTENT"
						::children[len(::children) +1] = new ( "soapSimpleContent", node.ChildNodes.Array[loop] )
						break;
					case "COMPLEXCONTENT"
						::children[len(::children) +1] = new ( "soapComplexContent", node.ChildNodes.Array[loop] )
						break;
					case "ALL"
						::children[len(::children) +1] = new ( "soapAllType", node.ChildNodes.Array[loop] )
						break;
					default:
						return ( 0 );
				end
			end

			return ( 1 )
		end
end

class soapSimpleType
		local	name
		local	node
		local	minOccurs
		local	maxOccurs
		local	type
		local	default
		local	ref
		local	child

	public:

		method GenCode ( schemaNS, elems, code, defs, init, top, genElems, name )
			if ( ::child )
				::child.GenCode ( schemaNS, elems, code, defs, init, 0, genElems, name ? name : ::name )
			end

			return ( 0 )
			top;
		end

		method New ( node )
			::node = node

			::name		= ::node.Attributes.GetNamedItem ( "name" )
			::minOccurs	= ::node.Attributes.GetNamedItem ( "minOccurs" )
			::maxOccurs	= ::node.Attributes.GetNamedItem ( "maxOccurs" )
			::type		= ::node.Attributes.GetNamedItem ( "type" )
			::default	= ::node.Attributes.GetNamedItem ( "default" )
			::ref		= ::node.Attributes.GetNamedItem ( "default" )


			if ( node.FirstChild )
				switch ( UPPER ( node.FirstChild.tagName ) )
					case "RESTRICTION"
						::child = new ( "soapRestrictionType", node.FirstChild )
						break;
					case "EXTENSION"
						::child = new ( "soapExtensionType", node.FirstChild )
						break;
					default:
						return ( 0 );
				end
			end

			return ( 1 )
		end
end

