class soapComplexContent
		local	name
		local	node
		local	minOccurs = 0
		local	maxOccurs = 1
		local	type
		local	default
		local	ref
		local	child

	public:

		method GenCode ( schemaNS, elems, code, defs, init, top, genElems, name )
			if ( ::child )
				::child.GenCode ( schemaNS, elems, code, defs, init, 0, genElems, name )
			end

			return ( 1 )
			top;
		end

		method New ( node )
			::node = node

			::name		= ::node.Attributes.GetNamedItem ( "name" )
			::minOccurs	= ::node.Attributes.GetNamedItem ( "minOccurs" )
			::maxOccurs	= ::node.Attributes.GetNamedItem ( "maxOccurs" )
			::type		= ::node.Attributes.GetNamedItem ( "type" )
			::default	= ::node.Attributes.GetNamedItem ( "default" )
			::ref		= ::node.Attributes.GetNamedItem ( "default" )

			if ( node.FirstChild )
				switch ( UPPER ( node.FirstChild.tagName ) )
					case "RESTRICTION"
						::child = new ( "soapRestrictionType", node.FirstChild )
						break;
					case "EXTENSION"
						::child = new ( "soapExtensionType", node.FirstChild )
						break;
					default:
						return ( 0 );
				end
			end

			return ( 1 )
		end
end

class  soapElementType
		local	name
		local	node
		local	minOccurs
		local	maxOccurs
		local	type
		local	default
		local	ref
		local	child

	public:

		method GenCode ( schemaNS, elems, code, defs, init, top, genElems, name )
			local 	newDefs
			local	newInit
			local	newGenElems
			local	newCode
			local	emitCode
			local	loop

			if ( top )
				if ( !elems[::node.name][2] )
					elems[::node.name][2] = 1
					defs += "	inherit	soap_msg_base\r\n"
				end
			else
				// child element (sequence or such)
				if ( ::name )
					genElems[len(genElems) + 1][1] = ::name
					genElems[len(genElems)    ][2] = ::type
					genElems[len(genElems)    ][3] = ::minOccurs
					genElems[len(genElems)    ][4] = ::maxOccurs

					if ( !elems[token ( ::type, ":", 2 )][2] )
						emitCode = 1
					else
						emitCode = 0
					end

					if ( token ( ::type, ":", 1 ) != schemaNS )
						defs += "	local	" + ::name + "\r\n"

						newInit = serverBuffer()
						newDefs = serverBuffer()
						newCode	= serverBuffer()
						newGenElems = {}

						if ( elems[token ( ::type, ":", 2 )][1].GenCode ( schemaNS, elems, newCode, newDefs, newInit, 1, newGenElems, ::name ) )
							if ( 0 + ::maxOccurs > 1 )
								if ( upper ( schemaNS ) != upper ( token ( ::type, ":", 1 ) ) )
									init += "		::" + ::name + " = new ( \"" + token ( ::type, ":", 2 ) + "\", \"" + ::name + "\", \"" + ::type 				  + "\", " + ::minOccurs + ", " + ::maxOccurs + " )\r\n"
								else
									init += "		::" + ::name + " = new ( \"" + token ( ::type, ":", 2 ) + "\", \"" + ::name + "\", \"" + token ( ::type, ":", 2 ) + "\", " + ::minOccurs + ", " + ::maxOccurs + " )\r\n"
								end
							else
								init += "		::" + ::name + " = new ( \"" + token ( ::type, ":", 2 ) + "\" )\r\n"
							end

							if ( emitCode )
								code += newCode.str
								code +=	"CLASS " + token ( ::type, ":", 2 ) + "\r\n"
								code += newDefs.str

								if ( newGenElems )
									code += "\r\n	ACCESS genElems\r\n"
									code += "		return { "
									for ( loop = 1; loop <= len ( newGenElems ); loop++ )
										code += "{"
										code += "\"" + newGenElems[loop][1] + "\", "
										if ( upper ( schemaNS ) == upper ( token ( newGenElems[loop][2], ":", 1 ) ) )
											code += "\"" + token ( newGenElems[loop][2], ":", 2 ) + "\", "
										else
											code += "\"" + newGenElems[loop][2] + "\", "
										end
										code += newGenElems[loop][3] + ", "
										code += newGenElems[loop][4]
										code += "}"

										if ( loop != len ( newGenElems ) )
											code += ", "
										end
									end
									code += " }\r\n"
									code += "	END\r\n"
								end

								if ( newInit.Str )
									code += "\r\n	METHOD New()\r\n"
									code += newInit.str
									code += "		return 1\r\n"
									code += "	END\r\n"
								end
								code += "END\r\n\r\n"
							else
							end
						else
							defs += newDefs.str
							init += newInit.str
							for ( loop = 1; loop <= len ( newGenElems ); loop++ )
								genElems[len ( genElems ) + 1] = newGenElems[loop]
							end
						end
					else
						defs += "	local	" + ::name
						if ( 0 + ::minOccurs  )
							switch ( UPPER ( token ( ::type, ":", 2 ) ) )
								case "STRING":
									defs += " = \"\"";
									break;
								case "INT":
									defs += " = 0"
									break;
								case "BOOLEAN":
									defs += " = \"false\"";
									break;
								case "DATETIME":
									defs += " = \"0001-01-01T00:00:00\"";
									break;
							end
						end
						defs += "\r\n"
					end
				else
				end
			end
			if ( ::child )
				::child.GenCode ( schemaNS, elems, code, defs, init, 0, genElems, ::name )
			end
		end

		method New ( node )
			::node = node

			::name		= ::node.Attributes.GetNamedItem ( "name" )
			::minOccurs	= ::node.Attributes.GetNamedItem ( "minOccurs" )
			::maxOccurs	= ::node.Attributes.GetNamedItem ( "maxOccurs" )
			::type		= ::node.Attributes.GetNamedItem ( "type" )
			::default	= ::node.Attributes.GetNamedItem ( "default" )
			::ref		= ::node.Attributes.GetNamedItem ( "default" )

			if ( upper ( ::maxOccurs ) == "UNBOUNDED" )
				::maxOccurs = 2147483647
			end
			::maxOccurs = 0 + ::maxOccurs

			if ( node.FirstChild )
				switch ( UPPER ( node.FirstChild.tagName ) )
					case "COMPLEXTYPE"
						::child = new ( "soapComplexType", node.FirstChild )
						break;
					case "COMPLEXCONTENT"
						::child = new ( "soapComplexContent", node.FirstChild )
						break;
					case "RESTRICTION"
						::child = new ( "soapRestrictionType", node.FirstChild )
						break;
					case "SIMPLETYPE"
						::child = new ( "soapSimpleType", node.FirstChild )
						break;
					default:
						return ( 0 );
				end
			end

			return ( 1 )
		end
end

class	soapWrapper

	private:
		local	xml
		local 	wsdlNS
		local 	schemaNS
		local	targetNS

		local 	typeList
		local 	elementList
		local	elems
		local 	oppList
		local	actionUrl

	public:
		local aSoapClasses = {}

		method ParseWsdl ( xml )
			local ops
			local loop
			local loop2
			local schema
			local definitions;
			local binding;
			local msg;
			local obj;

			// parse name space definitions
			definitions = xml."definitions".Attributes.Array

			for ( loop = 0; loop <= len ( definitions ); loop++ )
				switch ( definitions[loop][2] )
					case "http://www.w3.org/2001/XMLSchema":
						::schemaNS = token (  definitions[loop][1], ":", 2 )
						break;
					case "http://schemas.xmlsoap.org/wsdl/":
						::wsdlNS = token (  definitions[loop][1], ":", 2 )
						break;
				end
			end

			::actionUrl = xml."service"."port"."address".Attributes.GetNamedItem ( "location" )

			// build the list of operations from the port list

			ops = xml."portType".GetElementsByName ( "operation" )

			::oppList={}
			for ( loop = 1; loop <= ops.length; loop++ )
				::oppList[len ( ::oppList ) + 1][1] = ops.Array[loop].Attributes.GetNamedItem ( "name" )
				::oppList[len ( ::oppList )    ][2] = ops.Array[loop]."Input".Attributes.GetNamedItem ( "message" );
				::oppList[len ( ::oppList )    ][3] = ops.Array[loop]."Output".Attributes.GetNamedItem ( "message" );
			end

			// add in the bindings
			binding = xml."binding".GetElementsByNameNS ( "operation", ::wsdlNS );

			for ( loop = 1; loop <= len ( ::oppList ); loop++ )
				for ( loop2 = 1; loop2 <= binding.length; loop2++ )
					if ( upper ( ::oppList[loop][1] ) == upper ( binding.Array[loop2].Attributes.GetNamedItem ( "name" ) ) )
						::oppList[loop][4] = binding.Array[loop2]."Operation".FirstChild."Operation".Attributes.GetNamedItem ( "soapAction" )
						break
					end
				end
			end

			// parse out the message's
			msg = xml.GetElementsByNameNS ( "message", ::wsdlNS )
			for ( loop = 1; loop <= len ( ::oppList ); loop++ )
				for ( loop2 = 1; loop2 <= msg.Length; loop2++ )
					if ( token ( ::oppList[loop][2], ":", 2 ) == msg.Array[loop2].Attributes.GetNamedItem ( "name" ) )
						::oppList[loop][5] = msg.Array[loop2]."part".Attributes.GetNamedItem ( "element" )
						break
					end
				end
			end

			::targetNS = xml."types"."schema".Attributes.GetNamedItem ( "targetNamespace" )

			// parse out the schema types
			schema = xml."types"."schema".ChildNodes.Array

			::elems = new ( "AArray" )

			for ( loop = 0; loop <= len ( schema ); loop++ )
				switch ( upper ( schema[loop].tagName ) )
					case "ELEMENT":
						obj = new ( "soapElementType", schema[loop] );
						::elems[obj.name] = { obj, 0 }
						break;
					case "COMPLEXTYPE"
						obj= new ( "soapComplexType", schema[loop] );
						::elems[obj.name] = { obj, 0 }
						break;
					case "SIMPLETYPE"
						obj = new ( "soapSimpleType", schema[loop] );
						::elems[obj.name] = { obj, 0 }
						break;
					default:
						return ( 0 )
				end
			end

			return 1
		end

		method GenCode ( op )
			local	code
			local	defs
			local	init
			local	ns
			local	func
			local	loop
			local	loop2
			local	genElems
			local	name

			code = new ( "serverBuffer" )
			defs = new ( "serverBuffer" )
			init = new ( "serverBuffer" )

			for ( loop = 1; loop <= len ( ::oppList ); loop++ )
				func 	= ::oppList[loop][5]
				ns 		= token (  func, ":", 1 )
				name 	= token (  func, ":", 2 )
				if ( !op || (op == name) )

					defs = ""
					init = ""
					genElems={}

					::elems[name][1].GenCode ( ::schemaNS, ::elems, @code, @defs, @init, 1, @genElems, NULL )

					::aSoapClasses[ len( ::aSoapClasses ) + 1 ] = name

					code +=	"CLASS " + name + "\r\n"
					code += defs.str
					code +=	"	local	targetNS\r\n"
					code +=	"	local	msg\r\n"
					code +=	"	local	actionUrl\r\n"
					code += "	local	soapAction\r\n"
					if ( genElems )
						code += "\r\n	ACCESS genElems\r\n"
						code += "		return { "
						for ( loop2 = 1; loop2 <= len ( genElems ); loop2++ )
							code += "{"
							code += "\"" + genElems[loop2][1] + "\", "
							if ( upper ( ::schemaNS ) == upper ( token ( genElems[loop2][2], ":", 1 ) ) )
								code += "\"" + token ( genElems[loop2][2], ":", 2 ) + "\", "
							else
								code += "\"" + genElems[loop2][2] + "\", "
							end
							code += genElems[loop2][3] + ", "
							code += genElems[loop2][4]
							code += "}"

							if ( loop2 != len ( genElems ) )
								code += ", "
							end
						end
						code += " }\r\n"
						code += "	END\r\n\r\n"
					end
					if ( init.Str )
						code += "	METHOD New()\r\n"
						code += init.str
						code += "		::msg =\"" + name + "\"\r\n"
						code += "		::targetNS =\"" + ::targetNS + "\"\r\n"
						code += "		::actionUrl =\"" + ::actionurl + "\"\r\n"
						code += "		::soapAction =\"" + ::oppList[loop][4] + "\"\r\n"
						code += "		return 1\r\n"
						code += "	END\r\n"
					end
					code += "END\r\n\r\n"
				end
			end

			return ( code.str )
		end

		method New ( wsdl )
			::xml = xmlDocument ( wsdl, 1 )
			return ::ParseWsdl( ::xml )
		end
end

class soap_msg_base
	local	name
	local	type
	local	max
	local	min
	local	data

	Method New ( name, type, max, min )
		::name = name
		::type = type
		::max = max
		::min = min
		return 1
	end

	operator [ ( index )
		if ( TYPE ( ::data[index] ) == "U" )
			if ( token ( ::type, ":", 2 ) )
				::data[index] = new ( token ( ::type, ":", 2 ) )
			end
		end
		return ( ::data[index] )
	end

	method GenOutput ( buffer, indent )
		local	elems
		local	loop

		elems = sender.GenElems
		if ( !::data )
			for ( loop = 1; loop <= len ( elems ); loop++)
				buffer += space ( indent )

				if ( type ( sender.(elems[loop][1]) ) == "O" )
					buffer += "<" + elems[loop][1]   + ">\r\n"
					sender.(elems[loop][1]).GenOutput ( buffer, indent + 4 )
					buffer += space ( indent )
					buffer += "</" + elems[loop][1] + ">\r\n"
				else
					if ( type ( sender.(elems[loop][1]) ) != "U" )
						buffer += "<" + elems[loop][1] + ">"
						buffer += sender.(elems[loop][1])
						buffer += "</" + elems[loop][1] + ">\r\n"
					else
						buffer += "<" + elems[loop][1] + "/>\r\n"
					end
				end
			end
		else
			for ( loop = 1; loop <= len ( ::data ); loop++)
				::data[loop].GenOutput ( buffer, indent )
			end
		end
		return buffer
	end

	method soapMessage()
		local	buffer = new ( "serverBuffer" )

		buffer += "<?xml version=\"1.0\" encoding=\"utf-8\"?>\r\n"
		buffer += "<soap:Envelope xmlns:soap=\"http://schemas.xmlsoap.org/soap/envelope/\" xmlns:xsi=\"http://www.w3.org/2001/XMLSchema-instance\" xmlns:xsd=\"http://www.w3.org/2001/XMLSchema\">\r\n"
		buffer += "    <soap:Body>\r\n"
		buffer += "        <" + sender.msg + " xmlns=\"" + sender.targetNS + "\">\r\n"
		::GenOutput ( buffer, 12 )
		buffer += "        </" + sender.msg + ">\r\n"
		buffer += "    </soap:Body>\r\n"
		buffer += "</soap:Envelope>\r\n"
		return ( buffer.str )
	end
end

