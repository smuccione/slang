<[

function  fannkuch ( n )
    local	perm;
    local	perm1;
    local	count;
    local	flips;
    local	flipsMax;
    local	r;
    local	i;
    local	k;
    local	j;
    local	tmp
    local	didpr;
    local	n1	= n - 1;
    local	perm0

    if( n < 1 ) 
    	return 0;
    end

	perm 	= array ( 0, n )
	perm1 	= array ( 0, n )
	count	= array ( 0, n )

    for( i=0 ; i<n ; ++i ) 
    	perm1[i] = i;
    end

    r 			= n; 
    didpr 		= 0; 
    flipsMax	= 0;
    
    for(;;) 
		if ( didpr < 30 ) 
			for( i=0 ; i<n ; ++i ) 
				printf("%d", 1 + perm1[i] );
			end
			printf("\n");
			++didpr;
		end
		
		for( ; r!=1 ; --r )
			count[r-1] = r;
		end

		if( ! (perm1[0]==0 || perm1[n1]==n1) )
		
			flips = 0;
			
			for( i=0 ; i<n ; ++i ) 
				perm[i] = perm1[i];
			end
			
			k = perm1[0];
			repeat
				for( i=1, j=k-1 ; i<j ; ++i, --j )
					tmp = perm[i]
					perm[i] = perm[j]
					perm[j] = tmp
				end
				++flips;
				
				j=perm[k] 
				perm[k]=k
				k=j;
			until ( !k );
			
			flipsMax = flipsMax :> flips
		end

		for(;;)
	    	if( r == n )
				return flipsMax;
		    end
		    
			perm0 = perm1[0];
			i = 0;
			while( i < r )
				k = i+1;
				perm1[i] = perm1[k];
				i = k;
			end

			perm1[r] = perm0;

			if( (count[r] -= 1) > 0 )
				break;
	    	end
			++r;
		end
	end
end

n = 8;

printf ("Pfannkuchen(%d) = %d\n", n, fannkuch(n) );

]>
