CLASS AttachedStructures
  PUBLIC:
	local _title, _class, obj, IsView
	local aDesc, aPorch, aDeck, aOtherStruct, aUse, aValue, aWidth, aLength, aYearBuilt, aProfessional, aHeating    
	local a2Desc, a2Porch, a2Deck, a2OtherStruct, a2Use, a2Value, a2Width, a2Length, a2YearBuilt, a2Professional, a2Heating    
	
    METHOD new( obj, IsView )
    	::_title = "ATTACHED STRUCTURES"
    	::_class = "AttachedStructures"
    	::obj = obj
    	::IsView = IsView
    	::init( )
    	return( 1 )
    END

	ACCESS aVars
		static a = { 
			{ "aDesc", 1 },
			{ "aDeck", 2 },
			{ "aOtherStruct", 2 },
			{ "aPorch", 2 },
			{ "aHeating", 5 },
			{ "aLength", 1 },
			{ "aProfessional", 4 },
			{ "aUse", 5 },
			{ "aValue", 1 },
			{ "aWidth", 1 },
			{ "aYearBuilt", 5 },
			{ "a2Desc", 1 },
			{ "a2Deck", 2 },
			{ "a2OtherStruct", 2 },
			{ "a2Porch", 2 },
			{ "a2Heating", 1 },
			{ "a2Length", 1 },
			{ "a2Professional", 2 },
			{ "a2Use", 5 },
			{ "a2Value", 1 },
			{ "a2Width", 1 },
			{ "a2YearBuilt", 5 }
		}
        return( a )
	END


	METHOD init( )
        ::aDesc = ::obj.aDesc
        ::aDeck = ::obj.aDeck
        ::aOtherStruct = ::obj.aOtherStruct
        ::aPorch = ::obj.aPorch
        ::aHeating = ::obj.aHeating
        ::aLength = ::obj.aLength
       	::aProfessional = ::obj.aProfessional
        ::aUse = ::obj.aUse
        ::aValue = ::obj.aValue
        ::aWidth = ::obj.aWidth
        ::aYearBuilt = ::obj.aYearBuilt
        ::a2Desc = ::obj.a2Desc
        ::a2Deck = ::obj.a2Deck
        ::a2OtherStruct = ::obj.a2OtherStruct
        ::a2Porch = ::obj.a2Porch
        ::a2Heating = ::obj.a2Heating
        ::a2Length = ::obj.a2Length
       	::a2Professional = ::obj.a2Professional
        ::a2Use = ::obj.a2Use
        ::a2Value = ::obj.a2Value
        ::a2Width = ::obj.a2Width
        ::a2YearBuilt = ::obj.a2YearBuilt

		return( 1 )	
	END

	METHOD IsSupplemental( )
		return( ! strempty( ::a2desc ) )
	END

	METHOD display( ioClass, ReadOnly, DisplayItem )
		local s="", item, g

		g = new( "GlobalParams" )
		item = new( "appitem" )

		if ( type( DisplayItem ) != "N" )
			DisplayItem = 0
		end
		
		if ( ( ! DisplayItem ) || ( DisplayItem == 1 ) )
			if ( ReadOnly && ( ! ::IsView ) )
				s += "<tr><td class=t9 align=center bgcolor=black><a href=\"javascript:appEdit( '" + ::_class + "' );\">" + ::_title + "</a></td></tr>\r\n"
			else
				s += "<tr><td class=t9 align=center bgcolor=black><font color=white>" + ::_title + "</font></td></tr>\r\n"
			end
			s += "<tr><td>\r\n"
			s += "<font class=p8>\r\n"
			s += " &nbsp; Type of Structures: \r\n"
			s += item.CheckBox( "Porch &nbsp;", "aPorch", ::aPorch, ioclass, ReadOnly )
			s += item.CheckBox( "Deck &nbsp;", "aDeck", ::aDeck, ioclass, ReadOnly )
			s += item.CheckBox( "Other", "aOtherStruct", ::aOtherStruct, ioclass, ReadOnly ) + "<br>"
			s += " &nbsp; Attached Stuctures Description:<br><center><textarea class=e1 rows=1 cols=30 name=\"aDesc\"" + ( ReadOnly ? " readonly" : "" ) + ">" + ::aDesc + "</textarea></center>\r\n"
			s += item.ListBox( " &nbsp; Use: ", "aUse", ::aUse, "Residential;Commercial", ioclass, ReadOnly, 0 ) + "\r\n"
			s += " Value $:<input class=" + ioclass + " style=\"width:62;\" name=\"aValue\" value=\"" + ::aValue + "\"" + ( ReadOnly ? " readonly" : "" ) + "><br>\r\n"
			s += " &nbsp; Width:<input class=" + ioclass + " style=\"width:39;\" name=\"aWidth\" value=\"" + ::aWidth + "\"" + ( ReadOnly ? " readonly" : "" ) + ">(ft)\r\n"
			s += " Length:<input class=" + ioclass + " style=\"width:39;\" name=\"aLength\" value=\"" + ::aLength + "\"" + ( ReadOnly ? " readonly" : "" ) + ">(ft)\r\n"
			s += item.ListBox( " Year Built:", "aYearBuilt", ::aYearBuilt, g.ArrayToString( g.aCreateNumberList( 1920, 0 + date( "YYYY" ) + 1 ) ), ioclass, ReadOnly, 50 ) + "<br>\r\n"
			s += item.YesNo( " &nbsp; Built by a Professional Contractor?", "aProfessional", ::aProfessional, ioclass, ReadOnly ) + "<br>\r\n"
			s += item.ListBox( " &nbsp; Auxilliary heating or a fireplace?", "aHeating", ::aHeating, "None;Factory Installed;Commercially Installed;Self-Installed", ioclass, ReadOnly, 130 ) + "<br>\r\n"
			s += "</td></tr>\r\n"
		end

		if ( ( ! DisplayItem ) || ( DisplayItem == 2 ) )
			if ( DisplayItem == 2 )
				if ( ReadOnly && ( ! ::IsView ) )
					s += "<tr><td class=t9 align=center bgcolor=black><a href=\"javascript:appEdit( '" + ::_class + "' );\">" + ::_title + "</a></td></tr>\r\n"
				else
					s += "<tr><td class=t9 align=center bgcolor=black>" + ::_title + "</td></tr>\r\n"
				end
			end
			s += "<tr><td>\r\n"
			s += "<font class=p8>\r\n"
			s += " &nbsp; 2. Type of Structures: \r\n"
			s += item.CheckBox( "Porch &nbsp;", "a2Porch", ::a2Porch, ioclass, ReadOnly )
			s += item.CheckBox( "Deck &nbsp;", "a2Deck", ::a2Deck, ioclass, ReadOnly )
			s += item.CheckBox( "Other", "a2OtherStruct", ::a2OtherStruct, ioclass, ReadOnly ) + "<br>"
			s += " &nbsp; Attached Stuctures Description:<br><center><textarea class=e1 rows=1 cols=30 name=\"a2Desc\"" + ( ReadOnly ? " readonly" : "" ) + ">" + ::aDesc + "</textarea></center>\r\n"
			s += item.ListBox( " &nbsp; Use: ", "a2Use", ::a2Use, "Residential;Commercial", ioclass, ReadOnly, 0 ) + "\r\n"
			s += " Value $:<input class=" + ioclass + " style=\"width:62;\" name=\"a2Value\" value=\"" + ::a2Value + "\"" + ( ReadOnly ? " readonly" : "" ) + "><br>\r\n"
			s += " &nbsp; Width:<input class=" + ioclass + " style=\"width:39;\" name=\"a2Width\" value=\"" + ::a2Width + "\"" + ( ReadOnly ? " readonly" : "" ) + ">(ft)\r\n"
			s += " Length:<input class=" + ioclass + " style=\"width:39;\" name=\"a2Length\" value=\"" + ::a2Length + "\"" + ( ReadOnly ? " readonly" : "" ) + ">(ft)\r\n"
			s += item.ListBox( " Year Built:", "a2YearBuilt", ::a2YearBuilt, g.ArrayToString( g.aCreateNumberList( 1920, 0 + date( "YYYY" ) + 1 ) ), ioclass, ReadOnly, 50 ) + "<br>\r\n"
			s += item.YesNo( " &nbsp; Built by a Professional Contractor?", "a2Professional", ::a2Professional, ioclass, ReadOnly ) + "<br>\r\n"
			s += item.ListBox( " &nbsp; Auxilliary heating or a fireplace?", "a2Heating", ::a2Heating, "None;Factory Installed;Commercially Installed;Self-Installed", ioclass, ReadOnly, 130 ) + "\r\n"
			s += "</td></tr>\r\n"
		end

		return( s )
	END

	METHOD InitEditor( )
		return( appInitEditor( ::aVars ) )
	END
	METHOD update( qstr )
		return( appUpdate( ::aVars, qstr ) )
	END
    
END


CLASS UnattachedStructures
  PUBLIC:
	local _title, _class, obj, IsView
	local uDesc, uUse, uValue, uWidth, uLength, uYearBuilt, uProfessional, uHeating
	local u2Desc, u2Use, u2Value, u2Width, u2Length, u2YearBuilt, u2Professional, u2Heating
	
