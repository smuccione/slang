					s += "<tr><td class=t9 align=center bgcolor=black><a href=\"javascript:appEdit( '" + ::_class + "' );\">" + ::_title + "</a></td></tr>\r\n"
				else
					s += "<tr><td class=t9 align=center bgcolor=black>" + ::_title + "</td></tr>\r\n"
				end
			end
			s += "<tr><td>\r\n"
			s += "<font class=p8>\r\n"
			s += " &nbsp; 2. Unattached Stuctures Description:<br><center><textarea class=e1 rows=1 cols=30 name=\"u2Desc\"" + ( ReadOnly ? " readonly" : "" ) + ">" + ::u2Desc + "</textarea></center>\r\n"
			s += item.ListBox( " &nbsp; Use: ", "u2Use", ::u2Use, "Residential;Commercial", ioclass, ReadOnly, 0 ) + "\r\n"
			s += " Value $:<input class=" + ioclass + " style=\"width:62;\" name=\"u2Value\" value=\"" + ::u2Value + "\"" + ( ReadOnly ? " readonly" : "" ) + "><br>\r\n"
			s += " &nbsp; Width:<input class=" + ioclass + " style=\"width:39;\" name=\"u2Width\" value=\"" + ::u2Width + "\"" + ( ReadOnly ? " readonly" : "" ) + ">(ft)\r\n"
			s += " Length:<input class=" + ioclass + " style=\"width:39;\" name=\"u2Length\" value=\"" + ::u2Length + "\"" + ( ReadOnly ? " readonly" : "" ) + ">(ft)\r\n"
			s += item.ListBox( " Year Built:", "u2YearBuilt", ::u2YearBuilt, g.ArrayToString( g.aCreateNumberList( 1920, 0 + date( "YYYY" ) + 1 ) ), ioclass, ReadOnly, 50 ) + "<br>\r\n"
