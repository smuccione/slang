		g = new( "GlobalParams" )
		item = new( "appitem" )

		if ( type( DisplayItem ) != "N" )
			DisplayItem = 0
		end
		
		if ( ( ! DisplayItem ) || ( DisplayItem == 1 ) )
			if ( ReadOnly && ( ! ::IsView ) )
				s += "<tr><td class=t9 align=center bgcolor=black><a href=\"javascript:appEdit( '" + ::_class + "' );\">" + ::_title + "</a></td></tr>\r\n"
			else
				s += "<tr><td class=t9 align=center bgcolor=black><font color=white>" + ::_title + "</font></td></tr>\r\n"
			end
			s += "<tr><td>\r\n"
			s += "<font class=p8>\r\n"
			s += " &nbsp; Unattached Stuctures Description:<br><center><textarea class=e1 rows=1 cols=30 name=\"uDesc\"" + ( ReadOnly ? " readonly" : "" ) + ">" + ::uDesc + "</textarea></center>\r\n"
			s += item.ListBox( " &nbsp; Use: ", "uUse", ::uUse, "Residential;Commercial", ioclass, ReadOnly, 0 ) + "\r\n"
			s += " Value $:<input class=" + ioclass + " style=\"width:62;\" name=\"uValue\" value=\"" + ::uValue + "\"" + ( ReadOnly ? " readonly" : "" ) + "><br>\r\n"
			s += " &nbsp; Width:<input class=" + ioclass + " style=\"width:39;\" name=\"uWidth\" value=\"" + ::uWidth + "\"" + ( ReadOnly ? " readonly" : "" ) + ">(ft)\r\n"
			s += " Length:<input class=" + ioclass + " style=\"width:39;\" name=\"uLength\" value=\"" + ::uLength + "\"" + ( ReadOnly ? " readonly" : "" ) + ">(ft)\r\n"
			s += item.ListBox( " Year Built:", "uYearBuilt", ::uYearBuilt, g.ArrayToString( g.aCreateNumberList( 1920, 0 + date( "YYYY" ) + 1 ) ), ioclass, ReadOnly, 50 ) + "<br>\r\n"
			s += item.YesNo( " &nbsp; Built by a Professional Contractor?", "uProfessional", ::uProfessional, ioclass, ReadOnly ) + "<br>\r\n"
