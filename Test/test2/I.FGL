CLASS FileClass

  PUBLIC:

    METHOD copy()

        LOCAL source, destin, hsource, hdestin, buffsize
        LOCAL size, bytescopied, i , copybytes, data

        source = param(2)
        destin = param(3)

        hsource = fileOpen(source, 0)
        if (hsource < 1)
            return(0)
        end
        hdestin = fileCreate(destin)
        if (hdestin < 1)
            fileclose(hsource)
            return(0)
        end

        buffsize = 60000
        size = flen(hsource)

        println ( "buff size = ", buffsize )

        bytescopied = 0

        while (bytescopied < size)
            i = size - bytescopied
            copybytes = (i > buffsize) ? buffsize : i

            retry = 1
            while ( retry )
               copybytes = (i > buffsize) ? buffsize : i

println ( "buff size = ", buffsize )
               try
                  data = fread(hsource, copybytes)
                  retry = 0
               catch ( error )
                  if ( error == 1 )
                    retry = 1
                    if ( (buffSize = buffSize >> 1) == 0 )
                       except ( error )
                    end
                  end
               end
            end

            if ( data )
               fwrite(hdestin, data)

               print('.')

               bytescopied += len(data)
            end

//            data = ""
        end

        fclose(hsource)
        fclose(hdestin)

        return(bytescopied)

    END
END

