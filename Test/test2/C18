class a
   local val

   operator = ( b )
      return self.val = b
   end

   operator associative + ( b )
      switch ( type ( b ) )
         case 'O'
            switch ( classname ( b ) )
               case 'B'
                  return ( self.val + b.val )
                  break
            end
            break
         default
            break;
      end
      except ( 33 )  // illegal operand
   end
end

class b
   local val

   operator = ( b )
      return self.val = b
   end

   operator associative + ( b )
      switch ( type ( b ) )
         case 'O'
            except ( 33 )
         default
            return self.val + b
         break
      end
   end
end


