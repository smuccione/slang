class op
   local val

   operator = ( a )
      return self.val = a
   end

   operator += ( a )
      return self.val += a
   end

   operator ++( void )
      return self.val++
   end

   operator ++()
      return ++self.val
   end
end


class test
   inherit op

   method test
      println ( self.val )
   end
end

local obj

obj = new ( "test" )

obj  = 4
println ( ++obj, " - should be 5" )
println ( obj++, " - should be 5" )
println ( obj     )
println ( obj.val, " - should be 6" )
