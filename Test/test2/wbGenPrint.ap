<[

	LIBRARY c:\sdweb\home\insmgmt\insmgmt.flb

	function RemoveQuotes ( s )
		if ( len( s ) > 2 )
			return( substr( s, 2, len( s ) - 2 ) )
		else
			return ( "" )
		end
	end
	
	function MemfWriteLine ( s, Errline )
		s += Errline + "\r\n"
		return( s )
	end

	function ScrubString ( s )
		s = strswap( s, ".", "" )
		s = strswap( s, " ", "" )
		s = strswap( s, ",", "" )
		s = strswap( s, "(", "" )
		s = strswap( s, ")", "" )
		s = strswap( s, "-", "" )
		s = strswap( s, "/", "" )
		
		return(s)
	end
	
	function FormatPhone(s)
		local ln
		
		s = ScrubString( s )
		ln = len( s )
		
		
		if ( ln < 7 )
			return ( s )
		end
		
		if ( ln < 10 )
			return ( left( s, 3 ) + "-" + substr( s, 4, ln - 3 ) )
		else
			return ( left( s, 3 ) + "-" + substr( s, 4, 3 ) + "-" + substr( s, 7, ln - 6 ) )
		end
	end
	
	function FormatSSN(s)
		local ln
		
		s = ScrubString( s )
		ln = len( s )
		
		
		if ( ln < 9 )
			return ( s )
		end
		
		return ( left( s, 3 ) + "-" + substr( s, 4, 2 ) + "-" + substr( s, 6, ln - 5 ) )
	end


