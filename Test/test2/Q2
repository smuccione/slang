function SuperDayQuoter()
   field quote

   if ( !dbuse ( "q.d" ) )
      if ( (file = fopen( "DQUOTES.DA6" , 0 )) == -1 )
         println ( "File not found: DQUOTES.DA6" )
         return
      end
      x = { {"QUOTE", "C", 128, 0} }
      if ( !dbcreate ( "q.d", x ) )
         println ( "ERROR: can not create q.d" )
         return
      else
         dbuse ( "q.d", )
         while ( !feof ( file ) )
            line = freadline ( file )
            if ( line != "" )
               dbappend()
               quote = line
            end
         end
      end
   end

   dbgoto ( (random() % (dblastrec() - 1)) + 1 )
   ret = alltrim ( quote )

   dbclose()
   return ret
end

println ( SuperDayQuoter() )

