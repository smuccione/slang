   </font></font>
   <br><br>

  </td>
  
  <!-- CENTER COLUMN -->
  <td valign=top width=*>
   <table border=0 width=100%  cellspacing=0 cellpadding=0 class=txt>
    <tr>
     <td width=17>&nbsp;</td>
    
     <td width=* align=left>
      <br>

<[
	ExpireDays = user.ApointmentExpiration( )
ExpireDays = 5
	if ( ExpireDays < 0 )
		! "<script language=JavaScript>\r\n"
		! "  alert( 'Your AGENT APPOINTMENT has expired. Please contact\\nyour AGENT REPRESENTATIVE for additional information.' );\r\n"
		! "  parent.document.location = '" + carrier.login + "';\r\n"
		! "</script>\r\n"
		return( 1 )
	elseif ( ExpireDays < 31 )

		! "<table border=0 width=400 bgcolor='#F0F0A0' cellspacing=0 cellpadding=10 class=txt><tr><td>\r\n"
		! "  <b>NOTICE:</b> Your AGENT APPOINTMENT will expire in " + ExpireDays + " day(s). Please contact your AGENT REPRESENTATIVE for additional information or to request renewal of your appointment.\r\n"
		! "</td></tr></table>\r\n"
	end
]>


	  <p class=talltxt><a href="<[ ! carrier.website ]>" target=_blank><img src="/asic/images/office.jpg" border=0 width=240 height=150 align=right hspace=10 vspace=10 alt="Access American Superior's corporate website..."></a>
	  <font class=title><b>American Superior Insurance Company</b></font><br> is a Florida domiciled property and casualty insurance company specializing in residential property coverage. Our focus is on providing superior customer service by helping Florida homeowners protect their most valuable assets. Started in 1997 to help alleviate Florida's insurance market after Hurricane Andrew, our veteran staff of insurance professionals is committed to providing our policyholders and independent agents with quality products and superior service.
	  <br><br>
	  <font class=talltxt>

	  <hr>
	  <br><font class=verybigtxt><b>Useful Tips</b></font><br><br>
	  <p><b><u>Mailing Deadline</u></b>: A fully executed application needs to be mailed with full payment within 10 days from the date coverages are bound. If application and/or monies are not received, the application will be cancelled.
	  <p><b><u>Binder Box Must Be Completed</u></b>. If the binder box is not completed, the application will be suspended and an e-mail notification will be sent to the agency e-mail address on file. A completed binder box is not received within 30 days, the application will be cancelled.
	  <p><b><u>Mailing Address</u></b>: If the risk is the owner’s primary residence, and the mailing address is different than the property address, please explain why under the remarks section of the application.
	  <p><b><u>Prior Coverage Information</u></b> needs to be fully completed including name, policy # and expiration date. If there is no prior coverage indicated as required by the underwriting guidelines, the application will be cancelled. NOTE: Prior coverage is required, except in the case of new purchases/leases within 45 days of closing. 
	  <p><b><u>Supplemental Application</u></b> needs to be fully completed (all questions need to be answered and initialed). If there are incomplete items, the application will be suspended and an e-mail notification will be sent to the agency e-mail address on file. If the required information is not received within 30 days, the application will be cancelled.
	  <p><b><u>Proper Documentation</u></b> needs to be submitted with application for credits to apply (alarm certificate, storm shutters, 4-point inspection, etc.). If proper documentation is not received the application will not receive credits and/or may be surcharged. Please refer to the underwriting guidelines for more details.
	  <br><br><hr>	  

 	  </font>
	  <center>
      <font class=copyright2>
      Copyright (c) 2001-2004 <a href="http://www.brtsystems.com" target="_blank"><font color="#A0A0A0">Business Risk Technologies</font></a>, All Rights Reserved.<br>
      </font>
      </center>
      <br><br><br>
      
      </font>
     
	 </td>
	</tr>
   </table>
  </td>

  <!-- RIGHT COLUMN -->
  <td valign=top width=190>
   <table border=0 width=100%  cellspacing=0 cellpadding=15 class=txt>
    <tr>
     <td width=100% align=center>
      <font class=smtxt>
<[

	! "<a href=\"/insmgmt/ScheduleDetail.htm?" + qstr + "&date=" + date( ) + "\"><font color=black><b>" + date( "MMMM, YYYY" ) + "</b></font></a><br>"
	! DisplayCalendarX( date( ), 1, 180, 24, "", page )
//	! "<center><a href=\"javascript:alert('Add activity for " + cMonthYear( date( ) ) + "...');\">Add Activity</a> | <a href=\"javascript:alert('View activities for " + cMonthYear( date( ) ) + "...');\">View Activities</a></center>"
	for ( i=1; i<3; i++ )
		! "<br>"
		d = cMonthAdd( date( ), i )
		f = FirstOfMonth( d )
		! "<a href=\"/insmgmt/ScheduleDetail.htm?" + qstr + "&date=" + d + "\"><font color=black><b>" + cMonthYear( d ) + "</b></font></a><br>"
		! DisplayCalendarX( d, 0, 180, 24, "", page )
	end

]>
	  </font>
     </td>
    </tr>
   </table>
  </td>

 </tr>
</table>
</body>
</html>
