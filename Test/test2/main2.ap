<[
	LIBRARY c:\sdweb\home\insmgmt\insmgmt.flb
//	LIBRARY c:\sdweb\home\nia\niaSupport.flb
	LIBRARY c:\sdweb\home\insmgmt\calendar.flb

	session = new( "session" )

	companyid = session.var( "companyid" )
	userid = session.var( "userid" )

	theme = "Agent"

	id = companyid + "." + userid
	qstr = "companyid=" + companyid + "&userid=" + userid + "&subcmd=AGENTPORTAL&theme=" + theme

	page = new( "PageTheme" )
	page.LoadTheme( theme )

	entity = new( "objEntity" )
	user = entity.GetEntityObject( "1", id )
	if ( type( user ) != "O" )
		entity.close( )
//		session.response( "<b>LOGIN ERROR.</b><br><br>Unable to locate USER ID (" + upper( companyid + "/" + userid )+ ").<br><br><a href=\"/asic/portal.htm\" target=\"_parent\">Click here</a> to retry..." )
		session.redir( "/asic/" )
		return( 1 )
	end
	agency = entity.GetAgencyRecord( companyid )
	if ( ! agency )
		entity.close( )
		session.response( "<b>ACCESS ERROR.</b><br><br>Unable to locate ID (" + upper( companyid )+ ").<br><br><a href=\"/asic/portal.htm\" target=\"_top\">Click here</a> to retry..." )
		return( 1 )
	end
	
	CarrierId = "ASIC"
	carrier = objCarrier( CarrierId )

]>
<html>
<head>

 <META HTTP-EQUIV="imagetoolbar" CONTENT="no">

 <style>
  A { COLOR: #000000; FONT-FAMILY: Arial, helvetica, sans-serif; text-decoration: none; }
  A:hover { COLOR: <[ ! page.menuText ]>; FONT-FAMILY: Arial, helvetica, sans-serif; text-decoration: underline; }
  .hdr { color:#000000;font-size:14pt;font-family:Arial;font-weight:bold; }
  .subhdr { color:#00223E;font-size:12pt;font-family:Arial;font-weight:900; }
  .tab { color:#000000;font-size:8pt;font-family:Arial;font-weight:900; }
  .tab2 { color:#FFF3CE;font-size:8pt;font-family:Arial;font-weight:700; }
  .title { color:#000000;font-size:12pt;font-family:Arial;font-weight:900; }
  .txt { color:#000000;font-size:9pt;font-family:Arial; }
  .navtxt { color:#FFFFFF;font-size:9pt;font-family:Arial; }
  .bigtxt { color:<[ ! page.menuForeground ]>;font-size:11pt;font-family:Arial; }
  .verybigtxt { color:#000000;font-size:14pt;font-family:Arial; }
  .smtxt { color:#000000;font-size:8pt;font-family:Arial; }
  .lst { color:#000000;font-size:9pt;font-family:Arial; }
  .copyright { color:#99ccff;font-size:8pt;font-family:Arial; }
  .copyright2 { color:#A0A0A0;font-size:7pt;font-family:Arial; }

  .newshdr { color:#000000;font-size:8pt;font-family:Verdana,Arial,Helvetica,sans-serif;font-weight:500; }
  .newssubhdr { color:#808080;font-size:7pt;font-family:Verdana,Arial,Helvetica,sans-serif;font-weight:500; }

  .talltxt {
	color:#000000;
	font-size:9pt;
	font-family:Arial;
	line-height:20px;
	letter-spacing: .01em;
	word-spacing: .01em;
   }


 </style>

<script language=JavaScript>

function OpenWindow( url, x, y, id ) {
  var base =  ", width=" + x + ", height=" + y + ", status=no, location=no, toolbar=no, scrollbars=yes, menubar=no, directories=no, resizable=yes";
  var left = ( screen.availWidth - x ) / 2;
  var top = ( screen.availHeight - y ) / 2;
  var str = "left=" + left + " top=" + top;
  var win = window.open( url, id, str + base );
  win.focus( );
}

function UserEditor( ) {
  OpenWindow( "/insmgmt/agency/AgentEdit.htm?<[ ! qstr ]>&agentid=<[ ! id ]>&mode=READONLY", 600, 500, "EditUser" );
}

function AccessAdmin( ) {
	var p = prompt( "Enter ADMINISTRATION password:", "" );
	if ( ( p != "" ) && ( p != null ) ) {
		parent.document.location = "/asic/portal/agency/index.htm?<[ ! qstr ]>&access=" + p;
	}
}

</script>

</head>

<body leftmargin=0 topmargin=0 bgcolor="#FFFFFF" >

<table border=0 width=100%  height=100% cellspacing=0 cellpadding=0 class=txt>
 <tr>

  <td valign=top width=165 bgcolor="<[ ! page.navBackground ]>" height=100% align=center>

   <!-- LEFT COLUMN -->
   <table border=0 width=100%  cellspacing=0 cellpadding=10 class=navtxt>
    <tr>
     <td width=100%>
      <font class=copyright><font color=<[ ! page.navHilite ]>>Signed on as:</font><br><br></font><b>
<[
	! user.fname + " " + user.lname + "<br>"
	! user.city + ", " + user.state + " " + user.zip + "<br>"
//	! user.workphone + " work<br>"
	! user.homephone + "</b>"
	! "<center><font class=copyright><br><a href='javascript:UserEditor( );'><font color='" + page.navHilite + "'>Update</a> | <a href='javascript:AccessAdmin( );'><font color='" + page.navHilite + "'>Admin</font></a> | <a href='" + carrier.login + "' target=_top><font color='" + page.navHilite + "'>Signoff</font></a></font></center>"
]>
     </td>
    </tr>
   </table>

   <hr color=<[ ! page.dlgLite ]> size=1>   

   <table border=0 width=100%  cellspacing=0 cellpadding=10 class=navtxt>
    <tr>
     <td width=100% align=left>
 	  Resources:<br>
 	  <ul>
 	  <li><a href="/insmgmt/news_list.htm?<[ ! qstr ]>"><font color=white>Company News</font></a>
 	  <li><a href="<[ ! carrier.website ]>" target=_blank><font color=white>Corporate Website</font></a>
 	  <li><a href="/insmgmt/news.htm"><font color=white>Industry News</font></a>
 	  <li><a href="/insmgmt/resources_list.htm?<[ ! qstr ]>"><font color=white>Useful Resources</font></a>
 	  <li><a href="/insmgmt/contact_list.htm?<[ ! qstr ]>&basecompany=<[ ! carrierid ]>"><font color=white>Contact Info</font></a>
	 </ul>
     </td>
    </tr>
   </table>
   
<!--    <img src="/asic/images/HandShake.jpg" width=145 height=111 border=0> -->
   
   
