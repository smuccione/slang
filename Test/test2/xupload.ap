<[
	session = new ( "session" )
	for ( loop = 1; loop <= session.numParts(); loop++ )
		if ( session.var ( "name", loop ) == "cmd" )
			if ( session.postData ( loop ) == "xupload" )
				! "" + (session.numParts() - 2) + " file(s) upload sucessfully"
				return
			end
		end
	end

]>

<html>
<body>

upload some stuff<br>

<OBJECT WIDTH=500 HEIGHT=200 
ID="UploadCtl" 
CLASSID="CLSID:E87F6C8E-16C0-11D3-BEF7-009027438003" 
CODEBASE="XUpload.ocx"> 
<PARAM NAME="Server" VALUE="localhost"> 
<PARAM NAME="Script" VALUE="xupload.ap"> 
<PARAM NAME="HtmlForm" VALUE="MyForm"> 
</OBJECT> 

<FORM name="myform" > 
<INPUT TYPE=hidden name="cmd" value = "xupload" > 
</FORM> 
<INPUT TYPE=BUTTON VALUE="Upload!" onClick="UploadCtl.Upload()" > 


</body>
</html>
