<[

	function test2 ( )
		println ( pCount() )
	end
	
	FUNCTION displaydate( month = date( "MM" ), day = date( "DD" ), year = date( "YYYY" ) )
		printf ( "%s  %s  %s\r\n", month, day, year )
	end
	
	class cTest
		method new ( a = "def a", b = "def b", c )
			println ( a, " ", b, " ", c )
			return 1
		end
		
		method test ( a = "def a", b = "def b", c )
			println ( a, " ", b, " ", c )
		end
	end
	
	function test ( a, b = "b def", c = "c def", d )
		println ( a, " ", b, " ", c, " ", d )
	end

	o = new ( "cTest", "a" );
	
	displaydate ()	
	displaydate ( "9", "5", "1967" )	

	test2( )
	
	o = cTest("param c")
	o = cTest()
	o.test()
	o.test("here",,"there" )

	test ( 1, 2, 3, 4 )
	test ( 1, , 3, 4 )
	test ( 1, 2, 3    )
	test ( 1, 2 )
	test ( 1 )
]>

