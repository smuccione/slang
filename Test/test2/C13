   end
end

class combine
   inherit a, b

   public:
      local x

      message doit is test in b
      message doit2 is test in x
      message test in b
      message test2 is test in a
      message var is a in b

   protected:
      method testSender ( var )
         println ( var )
         sender.testSender()
      end

   private:
      method new()
         self.x = new ( "c" )
         return 1
      end
end

local a

a = new ( "combine" )

