CLASS A160_company_information
  PUBLIC:
    local _title, _class, obj, errmsg

    local Date, CarrierName, CodeNAIC, CarrierPolProgrName, CarrierProgrCode, PolNew
    local PolRenew, DateEff, DateExp, PayDirectBill, PayAgencyBill, PayPlan, Quote
    local PolIssue, Bound, BounDate, CarrierDepositAmt, PolTypeSTD, PolTypeSpec
    local PolTypeOther1, PolTypeOther2, PolicyType, AppType, AppStatusType, BillType

    METHOD new( obj )
        ::_title = "COMPANY INFORMATION"
        ::_class = "A160_company_information"
        ::obj = obj
        ::errmsg = ""
        ::init( )
        return( 1 )
    END

    METHOD init( )
        ::Date = ""
        ::CarrierName = ""
        ::CodeNAIC = ""
        ::CarrierPolProgrName = ""
        ::CarrierProgrCode = ""
        ::PolNew = ""
        ::PolRenew = ""
        ::DateEff = ""
        ::DateExp = ""
        ::PayDirectBill = ""
        ::PayAgencyBill = ""
        ::PayPlan = ""
        ::Quote = ""
        ::PolIssue = ""
        ::Bound = ""
        ::BounDate = ""
        ::CarrierDepositAmt = ""
        ::PolTypeSTD = ""
        ::PolTypeSpec = ""
        ::PolTypeOther1 = ""
        ::PolTypeOther2 = ""
        ::PolicyType = ""
        ::AppType = ""
        ::AppStatusType = ""
        ::BillType = ""
        return( 1 )
    END

    ACCESS aVars
        static a = {
            { "Date", 1, "Date", "date", 65 },
            { "CarrierName", 1, "Company", "text", 300 },
            { "" },
            { "CodeNAIC", 1, "NAIC Code", "textbutton", 100, "", "...", "SelectNAIC( 'CodeNAIC' )" },
            { "" },
            { "CarrierPolProgrName", 1, "Company Policy or Program Name", "text", 300 },
            { "CarrierProgrCode", 1, "Program Code", "textreadonly", 250 },

			{ "AppType", 1, "Type of Application", "lbstr", 1, "-;New;Renew;", "onChange=\"lbUpdateX( this, 'input', ';PolNew;PolRenew' );\"" },
            { "PolNew", 1, "", "hidden", 1 },
            { "PolRenew", 1, "", "hidden", 1 },
            { "" },
            { "DateEff", 1, "Effective Date", "date", 65 },
            { "DateExp", 1, "Expiration Date", "date", 65 },
            { "" },
			
			{ "BillType", "1", "Billing Method", "lbstr", 1, "-;Direct Bill;Agency Bill;", "onChange=\"lbUpdateX( this, 'input', ';PayDirectBill;PayAgencyBill;' );\"" },
            { "PayDirectBill", 1, "", "hidden", 1 },
            { "PayAgencyBill", 1, "", "hidden", 1 },
            
            { "PayPlan", 1, "Payment Plan", "text", 100 },
            { "" },
            
            { "AppStatusType", 1, "Application Status", "lbstr", 1, "-;Quote;Issued;Bound;", "onChange=\"lbUpdateX( this, 'input', ';Quote;PolIssue;Bound' );\"" },
            { "Quote", 1, "", "hidden", 100 },
            { "PolIssue", 1, "", "hidden", 100 },
            { "Bound", 1, "", "hidden", 100 },

            { "BounDate", 1, "Bound (date)", "date", 65 },


            { "" },

//            { "PolTypeSTD", 1, "Policy Type", "lbstr2d",1, "-;X|STD;-|Special;-|Other;" },

			{ "PolicyType", 1, "PolicyType", "lbstr", 1, "-;Standard;Special;Other;", "onChange=\"lbUpdateX( this, 'input', ';PolTypeSTD;PolTypeSpec;PolTypeOther1' );\"" },
            { "PolTypeSTD", 1, "", "hidden", 1 },
            { "PolTypeSpec", 1, "", "hidden", 100 },
            { "PolTypeOther1", 1, "", "hidden", 100 },
            { "PolTypeOther2", 1, "Other Type", "text", 100 },
            { "" },

            { "CarrierDepositAmt", 1, "Deposit Amount", "DOLLARANDCENTS", 100 }

        }
        return( a )
    END

    METHOD LoadFromObject( data )
        ::Date = data.Date
        ::CarrierName = data.CarrierName
        ::CodeNAIC = data.CodeNAIC
        ::CarrierPolProgrName = data.CarrierPolProgrName
        ::CarrierProgrCode = data.CarrierProgrCode
        ::PolNew = data.PolNew
        ::PolRenew = data.PolRenew
        ::DateEff = data.DateEff
        ::DateExp = data.DateExp
        ::PayDirectBill = data.PayDirectBill
        ::PayAgencyBill = data.PayAgencyBill
        ::PayPlan = data.PayPlan
        ::Quote = data.Quote
        ::PolIssue = data.PolIssue
        ::Bound = data.Bound
        ::BounDate = data.BounDate
        ::CarrierDepositAmt = data.CarrierDepositAmt
        ::PolTypeSTD = data.PolTypeSTD
        ::PolTypeSpec = data.PolTypeSpec
        ::PolTypeOther1 = data.PolTypeOther1
        ::PolTypeOther2 = data.PolTypeOther2
        ::PolicyType = data.PolicyType
        ::AppType = data.AppType
        ::AppStatusType = data.AppStatusType
        ::BillType = data.BillType
        return( 1 )
    END

    METHOD put( data )
        data.Date = ::Date
        data.CarrierName = ::CarrierName
        data.CodeNAIC = ::CodeNAIC
        data.CarrierPolProgrName = ::CarrierPolProgrName
        data.CarrierProgrCode = ::CarrierProgrCode
        data.PolNew = ::PolNew
        data.PolRenew = ::PolRenew
        data.DateEff = ::DateEff
        data.DateExp = ::DateExp
        data.PayDirectBill = ::PayDirectBill
        data.PayAgencyBill = ::PayAgencyBill
        data.PayPlan = ::PayPlan
        data.Quote = ::Quote
        data.PolIssue = ::PolIssue
        data.Bound = ::Bound
        data.BounDate = ::BounDate
        data.CarrierDepositAmt = ::CarrierDepositAmt
        data.PolTypeSTD = ::PolTypeSTD
        data.PolTypeSpec = ::PolTypeSpec
        data.PolTypeOther1 = ::PolTypeOther1
        data.PolTypeOther2 = ::PolTypeOther2
        data.PolicyType = ::PolicyType
        data.AppType = ::AppType
        data.AppStatusType = ::AppTypeStatus
        return( 1 )
    END

    METHOD validate( )
        local s = ""
        ::errmsg = s
        return( strempty( ::errmsg ) )
    END

    METHOD update( data )
        local line, val, key, i=1
        while ( 1 )
            line = strextract( data, "&", i++ )
            if ( strempty( line ) )
                break
            end
            key = strextract( line, "=", 1 )
            val = webDecodeURL( right( line, len( line ) - ( len( key ) + 1 ) ) )
            self.(upper(key)) = val
        end
        return( 1 )
    END

    ACCESS default( name )
        name = name
        return( '' )
    END
    ASSIGN default( name, val )
        name = name
        val = val
    END

    METHOD flatten( g )
        return( g.CreateClassVarString( self ) )
    END

END

