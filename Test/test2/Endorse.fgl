			return( 0 )
		end

		tbl = "a" + Key + "Table_" + x

		// Get Medical Rate
		a = ::rtb.( upper( tbl ) )
		r = ""
		for ( j=1; j<=len( a ); j++ )
			if ( cov == a[j][1] && terr == a[j][2] )
				r = 0 + a[j][3]
			end
		end
		if ( "" + r == "" )
			::errmsg = "***** SYSTEM ERROR *****     Class: " + ::name + ", Table: " + key + ", Territory: " + terr + ". Record not found"
			println( ::errmsg )
			return( 0 )
		end

		::Premium = r
				
		::obj.debug ( "Medical_GrossPremium Calc End" )
		return( 1 )
	END
