CLASS TotalAtFaultAccidents
  PUBLIC:
	// required variables
	local obj, rtb, name, title, premium, errmsg, footnote
	
	// local variables
	local Count
	
	METHOD new( obj )
		::obj = obj
		::obj.debug ( "TotalAtFaultAccidents New Start" )
		::name = "TotalAtFaultAccidents"
		::title = "Total At Fault Accidents"
		::premium = 0
		::errmsg = ""
		::footnote = ""
		::rtb = new( "Rating_Tables", ::obj )
//		if ( ! ValidateRequiredVariables( self ) )
//			return( 1 )
//		end
		::init( )
		::calculate( )
		::obj.debug ( "TotalAtFaultAccidents New End" )
		return( 1 )
	END

	ACCESS RequiredVars
		// array of required variables
		static a = {
			"DriverCnt",
			"data.EffDate",
			"data.XferCreditDate",
			"data.d1AtFaultAccidentsCnt",
			"data.d2AtFaultAccidentsCnt",
			"data.d3AtFaultAccidentsCnt",
			"data.d4AtFaultAccidentsCnt",
			"data.d5AtFaultAccidentsCnt",
			"data.d6AtFaultAccidentsCnt",
			"data.d1LastAccDate",
			"data.d2LastAccDate",
			"data.d3LastAccDate",
			"data.d4LastAccDate",
			"data.d5LastAccDate",
			"data.d6LastAccDate"
		}
		return( a )
	END

	ACCESS aVars
		// array of exported local variables
		static a = {
			"Count"
		}
		return( a )
	END

	METHOD init( )
		// initialize local variables here
			::Count = 0
		return( 1 )
	END

	METHOD calculate( )
		// perform calculations here
		::obj.debug ( "TotalAtFaultAccidents Calc Start" )

		local PolEffDate, effDate, xFerDate, LastAccDate, aCnt
		local i, j, dCnt, age, d1, d2, temp

		PolEffDate = ::obj.data.EffDate
		dCnt       = 0  + ::obj.DriverCnt
		effDate    = "" + ::obj.data.EffDate
		PolEffDate = "" + dateformatj( datej( effDate ), "YYYYMMDD" )
		xFerDate   = "" + ::obj.data.XferCreditDate
		xFerDate   = ( ! strempty( xFerDate ) ? "" + dateformatj( datej( ::obj.data.XferCreditDate ), "YYYYMMDD" ) : xFerDate )
		aCnt       = 0
		for ( i=1; i<=6; i++ )
			LastAccDate[i] = ""
		end

		// Get the required rate table names based upon Policy Effective Date
		for ( i=1; i<=dCnt; i++ )
			age  = 0
			if ( ! strempty( ::obj.data.( upper( "d" + i + "LastAccDate" ) ) ) )
				::obj.data.( upper( "d" + i + "LastAccDate" ) ) = ::obj.g.NormalizeDate( ::obj.data.( upper( "d" + i + "LastAccDate" ) ) )
			end
			LastAccDate[i] = ::obj.data.( upper( "d" + i + "LastAccDate" ) )
			aCnt = 0 + upper( ::obj.data.( upper( "d" + i + "AtFaultAccidentsCnt" ) ) )
			if ( ! strempty( LastAccDate[i] ) )
				if ( aCnt < 1 )
					aCnt = 1
					::obj.data.( upper( "d" + i + "AtFaultAccidentsCnt" ) ) = "" + aCnt
				end
				age  = 0 + ::obj.g.CalculateAgeBetweenDates( effDate, LastAccDate[i] )
				LastAccDate[i] = dateformatj( datej( LastAccDate[i] ), "YYYYMMDD" )
				if ( age < 2 )
					::Count += aCnt
				end
			end
		end

	// Sort Last Accident Dates - Descending
		if ( dCnt > 1 )
			for ( i=1; i<=dCnt; i++ )
				for ( j=2; j<=dCnt; j++ )
					d1 = LastAccDate[i]
					d2 = LastAccDate[j]
					if ( d1 < d2 )
						temp = LastAccDate[i]
						LastAccDate[i] = LastAccDate[j]
						LastAccDate[j] = temp
					end
				end
			end
		end

	// Set Transfer Credit Date = Last Accident Date if necessary
		if ( ! strempty( xFerDate ) )
			if ( xFerDate < LastAccDate[1] )
				::obj.data.XferCreditDate =  substr( LastAccDate[1], 5, 2 ) + "-" + right( LastAccDate[1], 2 ) + "-" + left( LastAccDate[1], 4 )
				::obj.change( "Transfer Credit Date changed to match last Accident Date" )
			end
		end

		::obj.debug ( "TotalAtFaultAccidents Calc End" )
		return( 1 )
	END
END

CLASS Credits
  PUBLIC:
	// required variables
	local obj, rtb, name, title, premium, errmsg, footnote
	
	// local variables
	local AirbagCred, AntiTheftCred, APCCred, InAgencyCred, NamedOperatorCred
	local MultiCarCred, RenewalCred, TransferCred, LIABCred, PDCred

	METHOD new( obj )
		::obj = obj
		::obj.debug ( "Credits New Start" )
		::name = "Credits"
		::title = "Credits"
		::premium = 0
		::errmsg = ""
		::footnote = ""
		::rtb = new( "Rating_Tables", ::obj )
		::obj.debug ( "Credits Validate Start" )
//		if ( ! ValidateRequiredVariables( self ) )
//			return( 1 )
//		end
		::obj.debug ( "Credits Init Start" )
		::init( )
		::calculate( )
		::obj.debug ( "Credits New End" )
		return( 1 )
	END

	ACCESS RequiredVars
		// array of required variables
		static a = {
			"data.EffDate",
			"data.RaterType",
			"DriverCnt",
			"VehicleNo",
			"VehicleCnt",
			"TotalAtFaultAccidents",
			"data.AgencyXfer",
			"data.NamedOperator",
			"data.XferCredit",
			"data.XferCreditDate",
			"data.v" + ::obj.VehicleNo + "CovType",
			"data.v" + ::obj.VehicleNo + "AirBag",
			"data.v" + ::obj.VehicleNo + "AntiTheft",
			"data.d" + ::obj.( upper( "v" + ::obj.VehicleNo + "DriverNo" ) ) + "APCDate",
			"v" + ::obj.VehicleNo + "LIAB_MaximumCred",
			"v" + ::obj.VehicleNo + "PD_MaximumCred",
			"v" + ::obj.VehicleNo + "DriverNo"
		}
		return( a )
	END

	ACCESS aVars
		// array of exported local variables
		static a = {
			"AirbagCred",
			"AntiTheftCred",
			"APCCred",
			"InAgencyCred",
			"MultiCarCred",
			"NamedOperatorCred",
			"RenewalCred",
			"TransferCred",
			"LIABCred",
			"PDCred"
		}
		return( a )
	END

	METHOD init( )
		// initialize local variables here
			::AirbagCred = 0.00
			::AntiTheftCred = 0.00
			::APCCred = 0.00
			::InAgencyCred = 0.00
			::MultiCarCred = 0.00
			::NamedOperatorCred = 0.00
			::RenewalCred = 0.00
			::TransferCred = 0.00
			::LIABCred = 0.00
			::PDCred = 0.00
		return( 1 )
	END

	METHOD calculate( )
		// perform calculations here
		::obj.debug ( "Credits Calc Start" )

		local PolEffDate, cov, a, aKey, i, j, tbl, x, CheckDate, drvNo
		local LIABMax, PDMax, AtFaultCnt, effDate
		local m, d, y, _m, _d, _y, mDiff, dDiff, yDiff, n6MonthPeriods
		
		effDate    = ::obj.data.EffDate
		PolEffDate = dateformatj( datej( effDate ), "YYYYMMDD" )
		drvNo      = ::obj.( upper( "v" + ::obj.VehicleNo + "DriverNo" ) )
		LIABMax    = 0.00 + ::obj.( upper( "v" + drvNo + "LIAB_MaximumCred" ) )
		PDMax      = 0.00 + ::obj.( upper( "v" + drvNo + "PD_MaximumCred" ) )
		AtFaultCnt = 0 + ::obj.TotalAtFaultAccidents
		cov        = "*"
		a          = ::rtb.aRateChangeDates
		aKey       = ::aRateTableKey

		// Get the required rate table names based upon Policy Effective Date

		for ( i=1; i<=8; i++ )
			x[i] = ""
			for ( j=1; j<=len( a ); j++ )
				if ( ( aKey[i] == a[j][1] ) && ( PolEffDate >= a[j][2] ) && ( PolEffDate <= a[j][3] ) )
					x[i] = "" + a[j][4]
				end
			end
		end
		for ( i=1; i<=8; i++ )
			if ( x[i] == "" )
				::errmsg = "***** SYSTEM ERROR *****     Class: " + ::name + ", " + aKey[i] + " table not found for policy effective date of " + ::obj.data.EffDate
				println( ::errmsg )
				return( 0 )
			end
		end
		for ( i=1; i<=8; i++ )
			tbl[i] = "a" + aKey[i] + "Table_" + x[i]
			::obj.Debug( "tbl[" + i + "] = " + tbl[i] )
		end

		// Get AirBagCredit
		if ( upper( ::obj.data.( upper( "v" + ::obj.VehicleNo + "AirBag" ) ) ) == "ON" )
			a = ::rtb.( upper( tbl[1] ) )
			for ( j=1; j<=len( a ); j++ )
				if ( cov == a[j][1] )
					::AirbagCred = 0.00 + a[j][2]
				end
			end
		end

		// Get AntiTheftDeviceCredit
		if ( upper( ::obj.data.( upper( "v" + ::obj.VehicleNo + "AntiTheft" ) ) ) == "ON" )
			a = ::rtb.( upper( tbl[2] ) )
			for ( j=1; j<=len( a ); j++ )
				if ( cov == a[j][1] )
					::AntiTheftCred = 0.00 + a[j][2]
				end
			end
		end

		// Get APC Credit
		CheckDate = ::obj.data.( upper( "d" + drvNo + "APCDate" ) )
		if ( CheckDate == "" )
		else
			CheckDate = dateformatj( datej( CheckDate ), "YYYYMMDD" )
			// valid for 3 years in South Dakota
			y  = 0  + left( CheckDate, 4 ) + 3
			m  = "" + substr( CheckDate, 5, 2 )
			d  = "" + right( CheckDate, 2 )
			CheckDate = "" + y + m + d
			if ( CheckDate >= PolEffDate )
				a = ::rtb.( upper( tbl[3] ) )
				for ( j=1; j<=len( a ); j++ )
					if ( cov == a[j][1] )
						::APCCred = 0.00 + a[j][2]
					end
				end
			end
		end

		// Get InAgencyTransferCredit
		if ( upper( ::obj.data.AgencyXfer ) == "YES" )
			a = ::rtb.( upper( tbl[4] ) )
			for ( j=1; j<=len( a ); j++ )
				if ( cov == a[j][1] )
					::InAgencyCred = 0.00 + a[j][2]
				end
			end
		end

		// Get MultiCarCredit
		if ( ::obj.VehicleCnt > 1 )
			a = ::rtb.( upper( tbl[5] ) )
			for ( j=1; j<=len( a ); j++ )
				if ( cov == a[j][1] )
					::MultiCarCred = 0.00 + a[j][2]
					if ( upper( a[j][3] ) == "MAX DRIVERS" )
						if ( ::obj.VehicleNo > ::obj.DriverCnt )
							::MultiCarCred = 0.00
						end
					end
				end
			end
		end

		// Get RenewalCredit

		if ( ::obj.CalcType == "RENEWALAPP" )
			if ( upper( ::obj.data.XferCredit ) == "YES" )
				if ( strempty( ::obj.data.XferCreditDate ) )
				else
					CheckDate = dateformatj( datej( ::obj.data.XferCreditDate ), "YYYYMMDD" )
					::obj.Debug( "CheckDate = " + CheckDate )

					y  = 0 + left( PolEffDate, 4 )
					m  = 0 + substr( PolEffDate, 5, 2 )
					d  = 0 + right( PolEffDate, 2 )

					_y = 0 + left( CheckDate, 4 )
					_m = 0 + substr( CheckDate, 5, 2 )
					_d = 0 + right( CheckDate, 2 )

					yDiff = y - _y
					dDiff = d - _d
					::obj.Debug( "yDiff = " + yDiff )
					::obj.Debug( "dDiff = " + dDiff )
					
					if ( yDiff >= 0 )
						m = m + ( yDiff * 12 )
						if ( dDiff < 0 )
							m = m - 1
						end
						mDiff = m - _m
						::obj.Debug( "mDiff = " + mDiff )
						n6MonthPeriods = 0 + int( mDiff / 6 )
						::obj.Debug( "n6MonthPeriods = " + n6MonthPeriods )
						if ( n6MonthPeriods >= 1 )
							a = ::rtb.( upper( tbl[7] ) )
							for ( j=1; j<=len( a ); j++ )
								if ( cov == a[j][1] )
									::RenewalCred = n6MonthPeriods * ( 0.00 + a[j][2] )
								end
							end
						end
					end
				end
			end
		end

		// Get Transfer Credit
		if ( ::obj.CalcType == "NEWQUOTE" || ::obj.CalcType == "NEWAPP" )
			if ( upper( ::obj.data.XferCredit ) == "YES" )
				if ( strempty( ::obj.data.XferCreditDate ) )
				else
					CheckDate = dateformatj( datej( ::obj.data.XferCreditDate ), "YYYYMMDD" )
					::obj.Debug( "CheckDate = " + CheckDate )

					y  = 0 + left( PolEffDate, 4 )
					m  = 0 + substr( PolEffDate, 5, 2 )
					d  = 0 + right( PolEffDate, 2 )

					_y = 0 + left( CheckDate, 4 )
					_m = 0 + substr( CheckDate, 5, 2 )
					_d = 0 + right( CheckDate, 2 )

					yDiff = y - _y
					dDiff = d - _d
					::obj.Debug( "yDiff = " + yDiff )
					::obj.Debug( "dDiff = " + dDiff )

					if ( yDiff >= 0 )
						m = m + ( yDiff * 12 )
						if ( dDiff < 0 )
							m = m - 1
						end
						mDiff = m - _m
						::obj.Debug( "mDiff = " + mDiff )
						n6MonthPeriods = 0 + int( mDiff / 6 )
						::obj.Debug( "n6MonthPeriods = " + n6MonthPeriods )
						if ( n6MonthPeriods >= 1 )
							a = ::rtb.( upper( tbl[7] ) )
							for ( j=1; j<=len( a ); j++ )
								if ( cov == a[j][1] )
									::TransferCred = n6MonthPeriods * ( 0.00 + a[j][2] )
								end
							end
						end
					end
				end
			end
		end

		// Get NamedOperatorCredit - NOT CAPPED
		if ( upper( ::obj.data.NamedOperator ) == "YES" )
			a = ::rtb.( upper( tbl[8] ) )
			for ( j=1; j<=len( a ); j++ )
				if ( cov == a[j][1] )
					::NamedOperatorCred = 0.00 + a[j][2]
				end
			end
		end

		::LIABCred = 0.00 + ::TransferCred + ::RenewalCred + ::MultiCarCred + ::APCCred + ::InAgencyCred
		
		cov = ::obj.data.( upper( "v" + ::obj.VehicleNo + "CovType" ) )
		if ( upper( cov ) == "LIAB ONLY" )
			::PDCred = 0.00
		else
			::PDCred   = 0.00 + ::TransferCred + ::RenewalCred + ::MultiCarCred + ::APCCred + ::InAgencyCred + ::AntiTheftCred
		end

		::LIABCred = ( ::LIABCred >= LIABMax ? LIABMax : ::LIABCred )
		::PDCred   = ( ::PDCred   >= PDMax   ? PDMax   : ::PDCred   )

		::obj.debug ( "Credits Calc End" )
		return( 1 )
	END

	ACCESS aRateTableKey
		static a = {
			"AirBagCredit",
			"AntiTheftDeviceCredit",
			"APCCredit",
			"InAgencyTransferCredit",
			"MultiCarCredit",
			"RenewalCredit",
			"TransferCredit",
			"NamedOperatorPolicyCredit"
		}
		return( a )
	END
END

CLASS SR22_Fee
  PUBLIC:
	// required variables
	local obj, rtb, name, title, premium, errmsg, footnote
	
	// local variables

	METHOD new( obj )
		::obj = obj
		::obj.debug ( "SR22_Fee New Start" )
		::name = "SR22_Fee"
		::title = "SR22 Fee"
		::premium = 0
		::errmsg = ""
		::footnote = ""
		::rtb = new( "Rating_Tables", ::obj )
//		if ( ! ValidateRequiredVariables( self ) )
//			return( 1 )
//		end
		::init( )
		::calculate( )
		::obj.debug ( "SR22_Fee New End" )
		return( 1 )
	END

	ACCESS RequiredVars
		// array of required variables
		static a = {
			"data.EffDate",
			"data.d1SR22_Required",
			"data.d2SR22_Required",
			"data.d3SR22_Required",
			"data.d4SR22_Required",
			"data.d5SR22_Required",
			"data.d6SR22_Required"
		}
		return( a )
	END

	ACCESS aVars
		// array of exported local variables
		static a = {
		}
		return( a )
	END

	METHOD init( )
		// initialize local variables here
		return( 1 )
	END

	METHOD calculate( )
		// perform calculations here
		::obj.debug ( "SR22_Fee Calc Start" )

		local PolEffDate, cov, a, key, i, j, tbl, x, r

		PolEffDate = dateformatj( datej( ::obj.data.EffDate ), "YYYYMMDD" )
		
		// Get the required rate table names based upon Policy Effective Date
		
		a = ::rtb.aRateChangeDates
		
		Key = "SR22_Fees"

		x = ""
		for ( j=1; j<=len( a ); j++ )
			if ( ( Key == a[j][1] ) && ( PolEffDate >= a[j][2] ) && ( PolEffDate <= a[j][3] ) )
				x = "" + a[j][4]
			end
		end
		if ( x == "" )
			::errmsg = "***** SYSTEM ERROR *****     Class: " + ::name + ", " + Key + " table not found for policy effective date of " + ::obj.data.EffDate
			println( ::errmsg )
			return( 0 )
		end

		tbl = "a" + Key + "Table_" + x
		a = ::rtb.( upper( tbl ) )

		for ( i=1; i<=6; i++ )
			cov = upper( ::obj.data.( upper( "d" + i + "SR22_Required" ) ) )
			::obj.debug( "cov" + i + " = " + cov )
			r = ""
			for ( j=1; j<=len( a ); j++ )
				if ( cov == a[j][1] )
					r = 0 + a[j][2]
					break
				end
			end
			::obj.debug ( "rate = " + r )
			if ( "" + r == "" )
				::errmsg = "***** SYSTEM ERROR *****     Class: " + ::name + ", Table: " + key + ", Coverage: " + cov + ". Record not found"
				println( ::errmsg )
				return( 0 )
			end

			::Premium += r
		end
		::obj.debug ( "SR22_Fee Calc End" )
		return( 1 )
	END
END

CLASS NewPolicy_Fee
  PUBLIC:
	// required variables
	local obj, rtb, name, title, premium, errmsg, footnote
	
	// local variables

	METHOD new( obj )
		::obj = obj
		::obj.debug ( "NewPolicy_Fee New Start" )
		::name = "NewPolicy_Fee"
		::title = "NewPolicy Fee"
		::premium = 0
		::errmsg = ""
		::footnote = ""
		::rtb = new( "Rating_Tables", ::obj )
//		if ( ! ValidateRequiredVariables( self ) )
//			return( 1 )
//		end
		::init( )
		::calculate( )
		::obj.debug ( "NewPolicy_Fee New End" )
		return( 1 )
	END

	ACCESS RequiredVars
		// array of required variables
		static a = {
			"data.EffDate",
			"data.ContCoverage"
		}
		return( a )
	END

	ACCESS aVars
		// array of exported local variables
		static a = {
		}
		return( a )
	END

	METHOD init( )
		// initialize local variables here
		return( 1 )
	END

	METHOD calculate( )
		// perform calculations here
		::obj.debug ( "NewPolicy_Fee Calc Start" )

		local PolEffDate, cov, a, key, j, tbl, x, r

		if ( upper( ::obj.data.ContCoverage ) == "YES" )
			r = 0
		else
			PolEffDate = dateformatj( datej( ::obj.data.EffDate ), "YYYYMMDD" )

			// Get the required rate table names based upon Policy Effective Date

			a = ::rtb.aRateChangeDates

			Key = "NewPolicy_Fees"

			x = ""
			for ( j=1; j<=len( a ); j++ )
				if ( ( Key == a[j][1] ) && ( PolEffDate >= a[j][2] ) && ( PolEffDate <= a[j][3] ) )
					x = "" + a[j][4]
				end
			end
			if ( x == "" )
				::errmsg = "***** SYSTEM ERROR *****     Class: " + ::name + ", " + Key + " table not found for policy effective date of " + ::obj.data.EffDate
				println( ::errmsg )
				return( 0 )
			end

			tbl = "a" + Key + "Table_" + x
			a = ::rtb.( upper( tbl ) )

			cov = "*"
			r = ""
			for ( j=1; j<=len( a ); j++ )
				if ( cov == a[j][1] )
					r = 0 + a[j][2]
					break
				end
			end
			::obj.debug ( "rate = " + r )
			if ( "" + r == "" )
				::errmsg = "***** SYSTEM ERROR *****     Class: " + ::name + ", Table: " + key + ", Coverage: " + cov + ". Record not found"
				println( ::errmsg )
				return( 0 )
			end
		end

		::Premium = r
		::obj.debug ( "NewPolicy_Fee Calc End" )
		return( 1 )
	END
END

CLASS Payday_Surcharge
  PUBLIC:
	// required variables
	local obj, rtb, name, title, premium, errmsg, footnote
	
	// local variables

	METHOD new( obj )
		::obj = obj
		::obj.debug ( "Payday_Surcharge New Start" )
		::name = "Payday_Fee"
		::title = "Payday Fee"
		::premium = 0
		::errmsg = ""
		::footnote = ""
		::rtb = new( "Rating_Tables", ::obj )
//		if ( ! ValidateRequiredVariables( self ) )
//			return( 1 )
//		end
		::init( )
		::calculate( )
		::obj.debug ( "Payday_Surcharge New End" )
		return( 1 )
	END

	ACCESS RequiredVars
		// array of required variables
		static a = {
			"data.EffDate",
			"data.Payday",
			"pol_MonthlyNetPrem"
		}
		return( a )
	END

	ACCESS aVars
		// array of exported local variables
		static a = {
		}
		return( a )
	END

	METHOD init( )
		// initialize local variables here
		return( 1 )
	END

	METHOD calculate( )
		// perform calculations here
		::obj.debug ( "Payday_Surcharge Calc Start" )

		local PolEffDate, cov, a, key, j, tbl, x, r

		PolEffDate = dateformatj( datej( ::obj.data.EffDate ), "YYYYMMDD" )
		
		// Get the required rate table names based upon Policy Effective Date
		
		a = ::rtb.aRateChangeDates
		
		Key = "PaydayPlan_Surcharge"

		x = ""
		for ( j=1; j<=len( a ); j++ )
			if ( ( Key == a[j][1] ) && ( PolEffDate >= a[j][2] ) && ( PolEffDate <= a[j][3] ) )
				x = "" + a[j][4]
			end
		end
		if ( x == "" )
			::errmsg = "***** SYSTEM ERROR *****     Class: " + ::name + ", " + Key + " table not found for policy effective date of " + ::obj.data.EffDate
			println( ::errmsg )
			return( 0 )
		end

		tbl = "a" + Key + "Table_" + x
		a = ::rtb.( upper( tbl ) )

		cov = upper( ::obj.data.Payday )
		r = ""
		for ( j=1; j<=len( a ); j++ )
			if ( cov == a[j][1] )
				r = 0.00 + a[j][2]
				break
			end
		end
		::obj.debug ( "rate = " + r )
		if ( "" + r == "" )
			::errmsg = "***** SYSTEM ERROR *****     Class: " + ::name + ", Table: " + key + ", Coverage: " + cov + ". Record not found"
			println( ::errmsg )
			return( 0 )
		end

		::Premium = ::obj.g.DollarRoundUp( ::obj.pol_MonthlyNetPrem * r )

		::obj.debug ( "Payday_Surcharge Calc End" )
		return( 1 )
	END
END


// All DB Access Objects are located here

CLASS objTerritory
  PUBLIC:
    local IsOpen, errmsg, dbFileName
    local effdate, expdate, territory, zipcode

    METHOD New( FileName )
        ::IsOpen = 0
        ::errmsg = ""
        ::dbFileName = FileName
        ::Init( )
        return( 1 )
    END

    METHOD Init( )
        ::effdate = ""
        ::expdate = ""
        ::territory = ""
        ::zipcode = ""
        return( 1 )
    END

    ACCESS dbIndexName
        return( strextract( ::dbFileName, ".", 1 ) + ".dx" )
    END

    METHOD create( )
        local db_struct = {
            { "EFFDATE", "C", 8, 0 },
            { "EXPDATE", "C", 8, 0 },
            { "ZIPCODE", "C", 9, 0 },
            { "TERRITORY", "C", 3, 0 }
        }
        return( dbcreate( ::dbFileName, db_struct ) )
    END

    METHOD open( )
        if ( ::IsOpen )
            ::IsOpen++
            return( 1 )
        end

        if ( ! fileExists( ::dbFileName ) )
            ::create( )
        end

        ::IsOpen = 1

        dbuse( ::dbFileName, "objTerritory", 1 )
        if ( ! fileExists( ::dbIndexName ) )
            objTerritory->dbCreateIndex( ::dbIndexName, "EFFDATE+EXPDATE+ZIPCODE", 0 )
        end
        objTerritory->dbOpenIndex( ::dbIndexName )

        return( 1 )
    END

    METHOD close( )
        if ( ::IsOpen == 1 )
            objTerritory->dbClose( )
        end
        ::IsOpen--
        return( 1 )
    END

    METHOD seek( item )
        objTerritory->dbSeek( upper( item ) )
        return( objTerritory->dbFound( ) )
    END

    METHOD reindex( )
        return( objTerritory->dbReindex( ) )
    END

    METHOD get( )
        ::effdate = alltrim( objTerritory->effdate )
        ::expdate = alltrim( objTerritory->expdate )
        ::territory = alltrim( objTerritory->territory )
        ::zipcode = alltrim( objTerritory->zipcode )
        return( 1 )
    END

    METHOD put( )
        objTerritory->effdate = ::effdate
        objTerritory->expdate = ::expdate
        objTerritory->territory = ::territory
        objTerritory->zipcode = ::zipcode
        return( 1 )
    END

    METHOD validate( )
        return( 1 )
    END

    METHOD CreateNewRecord( key )
        if ( ! ::validate( ) )
            return( 0 )
        end

        ::open( )
        if ( ::seek( key ) )
            ::errmsg = "Record (" + key + ") already exists!"
            ::close( )
            return( 0 )
        end

        objTerritory->dbAppend( )
        ::put( )

        ::close( )
        return( 1 )
    END

    METHOD GetRecord( key )
        ::open( )

        ::init( )
        if ( ! ::seek( key ) )
            ::errmsg = "Unable to locate record (" + key + ")"
            ::close( )
            return( 0 )
        end

        ::get( )
        ::close( )

        return( 1 )
    END

    METHOD SetRecord( key )
        if ( ! ::validate( ) )
            return( 0 )
        end

        ::open( )

        if ( ! ::seek( key ) )
            ::errmsg = "Unable to locate record (" + key + ")"
            ::close( )
            return( 0 )
        end

        ::put( )
        ::close( )

        return( 1 )
    END

	METHOD GetTerritory( eff, exp, zip )
		local key, x
		::open( )
		key = untrim( eff, 8 ) + untrim( exp, 8 ) + untrim( zip, 9 )
		if ( ::seek( key ) )
			x = "" + objTerritory->territory
		else
			x = "Not Found"
		end
		::close( )
		return( x )
	END

END

