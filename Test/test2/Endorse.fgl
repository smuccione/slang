CLASS ADD_Premium
  PUBLIC:
	// required variables
	local obj, rtb, name, title, premium, errmsg, footnote
	
	METHOD new( obj )
		::obj = obj
		::obj.debug ( "ADD_Premium New Start" )
		::name = "ADD_Premium"
		::title = "Accidental Death Premium"
		::premium = 0
		::errmsg = ""
		::footnote = ""
		::rtb = new( "Rating_Tables", ::obj )
//		if ( ! ValidateRequiredVariables( self ) )
//			return( 1 )
//		end
		::init( )
		::calculate( )
		::obj.debug ( "ADD_Premium New End" )
		return( 1 )
	END

	ACCESS RequiredVars
		// array of required variables
		static a = {
			"data.EffDate",
			"d" + ::obj.DriverNo + "ADD"
		}
		return( a )
	END

	ACCESS aVars
		// array of exported local variables
		static a = {
		}
		return( a )
	END

	METHOD init( )
		// initialize local variables here
		return( 1 )
	END

	METHOD calculate( )
		// perform calculations here
		::obj.debug ( "ADD_Premium Calc Start" )

		local PolEffDate, cov, a, key, j, tbl, x, r

		PolEffDate = dateformatj( datej( ::obj.data.EffDate ), "YYYYMMDD" )
		
		// Get the required rate table names based upon Policy Effective Date
		
		a = ::rtb.aRateChangeDates
		
		// Get ADD Monthly Premium

		Key = "ADD_Rates"

		x = ""
		for ( j=1; j<=len( a ); j++ )
			if ( ( Key == a[j][1] ) && ( PolEffDate >= a[j][2] ) && ( PolEffDate <= a[j][3] ) )
				x = "" + a[j][4]
			end
		end
		if ( x == "" )
			::errmsg = "***** SYSTEM ERROR *****     Class: " + ::name + ", " + Key + " table not found for policy effective date of " + ::obj.data.EffDate
			println( ::errmsg )
			return( 0 )
		end

		tbl = "a" + Key + "Table_" + x

		// Get ADD Rate
		a = ::rtb.( upper( tbl ) )

		r = ""
		cov = upper( ::obj.data.( upper( "d" + ::obj.DriverNo + "ADD" ) ) )
		::obj.debug( "cov = " + cov )
		
		r = ""
		for ( j=1; j<=len( a ); j++ )
			if ( cov == a[j][1] )
				r = 0 + a[j][2]
				break
			end
		end
		::obj.debug ( "rate = " + r )
		if ( "" + r == "" )
			::errmsg = "***** SYSTEM ERROR *****     Class: " + ::name + ", Table: " + key + ", Coverage: " + cov + ". Record not found"
			println( ::errmsg )
			return( 0 )
		end


		::Premium = r
		
		::obj.debug ( "ADD_Premium Calc End" )
		return( 1 )
	END
END

