FUNCTION DisplayTip( dlg, hstatus, htime )
    local x, y, x1, y1, cur, id, obj, data, curtime, str
    
    str = 'Click the mouse over the desired item...'
    cur = -1
    curtime = ''
    while ( winIsValid( dlg.handle ) )

        x1 = mouseCurPosX( )
        y1 = mouseCurPosY( )
        if ( winHandleFromPoint( x1, y1 ) != dlg.handle )
            cur = -1
            winSetText( hstatus, str )
            winSetText( htime, date( 'MMM DDDD' ) + ', ' + TimeToStr( time( ), 0 ) + 'm' )
            taskWait( {|| ( ( ! winIsValid( dlg.handle ) ) || ( x1 != mouseCurPosX( ) ) || ( y1 != mouseCurPosY( ) ) || ( curtime != time( ) ) ) } )
            curtime = time( )
            continue
        end

        x = sysScrToWinX( dlg.handle, x1 )
        y = sysScrToWinY( dlg.handle, y1 )

        id = dlgPtInHotspot(dlg.handle, x, y)
        if (id != cur)
            cur = id

            // get the object
            if ( id )
                obj = dlg.ObjFromId( id )
                if ( type( obj ) == 'O' )
                    // get the data 
                    data = new( 'iniItem', inifile, 'data', obj.alias )
                    if ( type( data ) == 'O' )
                        winSetText( hstatus, data.desc )
                    end
                    
                end
            else    
                cur = -1
                winSetText( hstatus, str )
            end
            winSetText( htime, date( 'MMM DDDD' ) + ', ' + TimeToStr( time( ), 0 ) + 'm' )

        end
        taskWait( {|| ( ( ! winIsValid( dlg.handle ) ) || ( x1 != mouseCurPosX( ) ) || ( y1 != mouseCurPosY( ) ) || ( curtime != time( ) ) ) } )
        curtime = time( )
    end
    return( 1 )
END



