STATIC gslExecWin
STATIC hSmallFont, hBigFont, TextColor, inifile, gslStatus
STATIC pg_acce, pg_comp, pg_conf, pg_cust, pg_dire, pg_prod, pg_refe, pg_util


//LIBRARY sysclass

     
CLASS window
  PRIVATE:
    local IsDebug, IsSound
    local v_bkwindow

  PUBLIC:

    local handle, hparent, hbkwin, prevpage
    local curevent
    local sndCreateFile
    local numEvents
    local numctrls
    local ctrls
    local numpages
    local pages
    local dblclick
    local onLeftClick
    local onRightClick
    local onSound
    local onControl
    local curpage
    local bkwinclr
    local IsTab
    local onOK
    local onHelp
    local onCancel
    local onPageSet
    local IsSpy

    METHOD new( parent, title, x, y, width, height, style, bkclr, bkwindowclr, isbkwin )
        self.curevent     = 0
        self.curpage      = 0
        self.dblclick     = 0
        self.bkwinclr     = bkwindowclr
        self.hparent      = parent
        self.hbkwin       = 0
        self.IsDebug      = 0
        self.IsSound      = 1
        self.IsTab        = 0
        self.numevents    = 0
        self.numctrls     = 0
        self.numpages     = 0
        self.v_bkwindow    = isbkwin
        self.prevpage     = 0
        self.IsSpy        = 0

        if (isbkwin)
            // create the background window
            // NOTE: Windows with separate background windows cannot have a parent!!!
            self.hbkwin = dlgCreate(0, "DLG", "", -1, -1, scrGetWidth() + 100, scrGetHeight() + 100, 0, self.bkwinclr)
            self.hparent = self.hbkwin
        end    
        // create the main window
        self.handle = dlgCreate(self.hparent, "DLG", title, x, y, ((width >= 0) ? width : scrGetWidth()), ((height >= 0) ? height : scrGetHeight()), style, bkclr)
        return(1)
    END

    METHOD AliasID( val )
        local x, alias

        alias = upper( val )    
        for ( x=1; x<=self.numctrls; x++ )
            if ( upper( self.ctrls[ x ].alias ) == alias )
                return( self.ctrls[ x ].id )
            end
        end
        return( 0 )        
    END

    METHOD AliasFromId( id )
        local x

        for ( x=1; x<=self.numctrls; x++ )
            if ( self.ctrls[ x ].id == id )
                return( self.ctrls[ x ].alias )
            end
        end
        return( '' )        
    END

    ACCESS bkframe
        return( ! ( dlgExStyle(self.handle) & 1 ) )
    END

    ASSIGN bkframe(flag)
        if (flag)
            dlgExStyle(self.handle, dlgExStyle(self.handle) & ~1)
        else
            dlgExStyle(self.handle, dlgExStyle(self.handle) | 1)
        end
    END

    ACCESS bkimage
        return(dlgBkImage(self.handle))
    END

    ASSIGN bkimage(file)
        dlgBkImage(self.handle, file)
    END

    ACCESS bkpaint
        return(dlgExStyle(self.handle))
    END

    ASSIGN bkpaint(flag)
        if (flag)
            dlgExStyle(self.handle, dlgExStyle(self.handle) & ~2)
        else
            dlgExStyle(self.handle, dlgExStyle(self.handle) | 2)
        end
    END

    ACCESS bkwindow
        return(self.v_bkwindow)
    END

    ASSIGN bkwindow(flag)
        self.v_bkwindow = flag

        if (flag && (! self.hbkwin))
            // create the background window
            self.hbkwin = dlgCreate(0, "DLG", "", -1, -1, scrGetWidth() + 100, scrGetHeight() + 100, 0, self.bkwinclr)
        end

        if (winIsVisible(self.handle))
            winShow(self.hbkwin, (self.v_bkwindow) ? 5 : 0)
        end
    END

    METHOD close
        // close the main window
        dlgEnd(self.handle)
        self.handle = 0

        // close the background window
        if (self.hbkwin)
            dlgEnd(self.hbkwin)
            self.hbkwin = 0
        end
    END

    METHOD controls(type, text, x, y, width, height, style, cmd, sound, hfont, bkclr, alias)
        // controls registered here are part of page #0, the master page
        
        local i, title
        
        if ( upper( type ) == 'TAB' )
            self.IsTab = 1
            if ( strempty( text ) )
                // get the page descriptions
                title = ''
                for ( i=1; i<=self.numpages; i++ )
                    title += ( self.pages[ i ].title + ';' )
                end
            end
        end
        self.numctrls++
        self.ctrls[ self.numctrls ] = new( 'wincontrol', self, 0, type, strempty( text ) ? title : text, x, y, width, height, style, cmd, sound, hfont, bkclr, alias )
        return( self.ctrls[ self.numctrls ] )
    END

    ACCESS debug
        return(self.IsDebug)
    END

    ASSIGN debug(flag)
        if (flag == 1)
            dlgExStyle(self.handle, dlgExStyle(self.handle) | 16)  // show hotspots
        else
            dlgExStyle(self.handle, dlgExStyle(self.handle) & ~16) // no show hotspots
        end
        self.IsDebug = flag
        return
    END

    METHOD display( )
        self.show()
    END

    METHOD CurEventId( )
        return( dlgEventID( self.handle ) )
    END
    
    METHOD CurEventObj( )
        return( self.ObjFromId( dlgEventID( self.handle ) ) )
    END

    ACCESS hicon
        return( dlgIcon( self.handle ) )
    END

    ASSIGN hicon( val )
        dlgIcon( self.handle, val )
    END

    METHOD hide( )
        self.show( 0 )
    END

    METHOD IdFromAlias( alias )
        local x, _alias

        _alias = upper( alias )    
        for ( x=1; x<=self.numctrls; x++ )
            if ( upper( self.ctrls[ x ].alias ) == _alias )
                return( self.ctrls[ x ].id )
            end
        end
        return( 0 )
    END

    METHOD ObjFromAlias( alias )
        local x, _alias

        _alias = upper( alias )    
        for ( x=1; x<=self.numctrls; x++ )
            if ( upper( self.ctrls[ x ].alias ) == _alias )
                return( self.ctrls[ x ] )
            end
        end
        return( 0 )
    END

    METHOD ObjFromId( id )
        local x

        for ( x=1; x<=self.numctrls; x++ )
            if ( self.ctrls[ x ].id == id )
                return( self.ctrls[ x ] )
            end
        end
        return( 0 )        
    END

    METHOD pageControls(page, type, text, x, y, width, height, style, cmd, sound, hfont, bkclr, alias )
        self.numctrls++
        self.ctrls[self.numctrls] = new('wincontrol', self, page, type, text, x, y, width, height, style, cmd, sound, hfont, bkclr, alias )
        return(self.ctrls[self.numctrls])
    END

    METHOD pageCreate(title, bkimage)
        self.numpages++
        self.pages[self.numpages] = new( 'winpages', self, title, bkimage )
        return(self.numpages)
    END

    METHOD pageDisplay( page )
        local x, y, isfirst=0, obj

//        dlgCursorSet( self.handle, sysSetCursor( "WAIT" ) )
        mouseCapture( self.handle )

        // process PageSet handler
        if ( type( self.onPageSet ) == 'B' )
            x = self.curpage
            self.curpage = page
            ( self.onPageSet ) ( )
            self.curpage = x
        end

        // check if already on this page
        if ( self.curpage == page )
            self.show( ) 
//            dlgCursorSet( self.handle, 0 )
            mouseCaptureRelease( )
            return( 1 )
        end

        winSetRedraw( self.handle, 0 )

        isfirst = ( self.curpage ) ? 0 : 1

        if ( isfirst )
            if (self.hbkwin)
                if (self.v_bkwindow)
                    winShow(self.hbkwin, ((pcount() == 2) ? 5 : param(2)))
                else
                    winShow(self.hbkwin, 0)
                end
            end
//            self.show( )
        end
        
        y = self.numctrls
        for ( x=1; x<=y; x++ )

            // hide the previous page's controls
            obj = self.ctrls[ x ]
            if ( self.curpage )
                if ( obj.page == self.curpage )
                    dlgSetHiddenFlag( self.handle, obj.id, 1 )
                    continue
                end
            end

            // unhide the new page's controls        
            if ( obj.page == page )
                dlgSetHiddenFlag( self.handle, obj.id, 0 )
            end
        end
        
        self.prevpage = self.curpage
        self.curpage = page

        // set the background image
        if ( ! strempty( self.pages[ self.curpage ].bkimage ) )
            self.bkimage = self.pages[ self.curpage ].bkimage
        end    
    
        winSetRedraw( self.handle, 1 )

        if ( isfirst )
            winUpdate( self.handle, 1 )
        elseif ( ! self.IsTab )
            winUpdate( self.handle, self.bkframe ? 2 : 1 )
        else 
            tabUpdate( self.handle )
        end
        mouseCaptureRelease( )
//        dlgCursorSet( self.handle, 0 )

        return(1)
    END

    METHOD ProcessEvents
        local x, id, obj
        local DLG_QUIT = -9
        local DLG_LEFTCLICK = 2
        local DLG_LEFTDBLCLICK = 3
        local DLG_RIGHTCLICK = 4
        local DLG_CONTROL = 8
        local DLG_TABEVENT = 10
        local IDOK = 1
        local IDCANCEL = 2
        local IDHELP = 197
        local TAB_BUTTON = 1
        local TAB_SETPAGE = 2
        local TAB_DELETE = 3
        
        // activate the window
        winActive( self.handle )
//        winSendKeys( self.handle, '<TAB>' );
        
        // process the events
        while ( winIsValid( self.handle) )
            
            // get the current event
            x = dlgEvent(self.handle)
            self.curevent = x
            if ( x == DLG_QUIT )
                break
            end

            if ((self.curevent == DLG_LEFTCLICK) && (! self.dblclick))
                id = dlgEventId(self.handle)
                self.spy( 'event=DLG_LEFTCLICK, id=' + id )
            elseif ((self.curevent == DLG_LEFTDBLCLICK) && (self.dblclick))
                id = dlgEventId(self.handle)
                self.spy( 'event=DLG_LEFTDBLCLICK, id=' + id )
            elseif ( self.curevent == DLG_RIGHTCLICK )
                id = dlgEventId(self.handle)
                self.spy( 'event=DLG_RIGHTCLICK, id=' + id )
            elseif (self.curevent == DLG_TABEVENT)
                id = dlgEventId(self.handle)
                self.spy( 'event=DLG_TABEVENT, id=' + id )
            elseif (self.curevent == DLG_CONTROL)
                id = dlgEventId(self.handle)
                self.spy( 'event=DLG_CONTROL, id=' + id )
            else
                continue
            end

            if ( self.curevent == DLG_TABEVENT )

                switch( id )

                  case TAB_BUTTON

                    switch ( dlgEventParam( self.handle ) )

                      case IDOK
                        self.runBuffer( self.onOK, 'id=TAB_BUTTON onOK( )' )
                        break

                      case IDCANCEL
                        self.runBuffer( self.onCancel, 'id=TAB_BUTTON onCancel( )' )
                        break

                      case IDHELP
                        self.runBuffer( self.onHelp, 'id=TAB_BUTTON onHelp( )' )
                        break
                        
                    end
                    break

                  case TAB_SETPAGE
                    self.spy( 'id=TAB_SETPAGE, param=' + dlgEventParam(self.handle) )
                    self.pageDisplay( dlgEventParam( self.handle ) )
                    break

                  case TAB_DELETE
                    self.spy( 'id=TAB_DELETE, param=' + dlgEventParam(self.handle) + ' (NOT USED)' )
                    break

                end
                continue
            end    

            for ( x=1; x<=self.numctrls; x++ )
                if ( self.ctrls[ x ].id != id )
                    continue
                end
                obj = self.ctrls[ x ]

                // process right click action
                if (self.curevent == DLG_RIGHTCLICK)
                    self.runBuffer( self.onRightClick, 'id=' + id + ' onRightClick( )', obj )
                    continue
                end

                // process sound
                if (self.IsSound)
                    switch ( type( self.onSound ) )
                      case 'C'
                        if ( ! strempty( self.onSound ) )
                            self.spy( 'Processing onSound( ) [string], id=' + id )
                            &( self.onSound )              // no parameter passing
                        else
                            if ( ! strempty( obj.sound ) )
                                self.spy( 'Playing default sound, id=' + id )
                                sndPlayWaveFile( obj.sound )
                            end                                
                        end    
                        break

                      case 'B'
                        self.spy( 'Processing onSound( ) [codeblock], id=' + id )
                        ( self.onSound )( obj )
                        break

                      default
                        if ( ! strempty( obj.sound ) )
                            self.spy( 'Playing default sound, id=' + id )
                            sndPlayWaveFile( obj.sound )
                        end                                
                    end
                end

                // process commands, must be last!!!

                // check for handlers
                switch ( self.curevent )

                  case DLG_LEFTCLICK
                    if ( self.runBuffer( self.onLeftClick, 'id=' + id + ' onLeftClick( )', obj ) )
                        continue
                    end
                    break
                  
                  case DLG_LEFTDBLCLICK
                    if ( self.runBuffer( self.onLeftDblClick, 'id=' + id + ' onLeftDblClick( )', obj ) )
                        continue
                    end
                    break
                  
                  case DLG_CONTROL
                    if ( self.runBuffer( self.onControl, 'id=' + id + ' onControl( )', obj ) )
                        continue
                    end
                    break
                  
                end
                
                // process attached command if no handler installed
                self.runBuffer( obj.cmd, 'id=' + id + ' obj.cmd( )', obj )
                
            end
        end
        return(self.curevent)
    END

    METHOD runBuffer( buf, desc, obj )
 
        local param, file

        // process attached command if no handler installed

        switch ( type( buf ) )

          case 'C'
            if ( strempty( buf ) )
                // nothing to process
                return( 0 );
            end

            param = strextract( buf, ' ', 1 )
            if ( at( '.', param) < 1 )
                // must be a command
                self.spy( desc + ' [string]' )
                &( buf )
            else
                // first parameter is a file...
                        
                // morework: Add CD-ROM drive substitution and other string translation here...
                file = fileFindFullName( param )
                if ( fileExists( file ) )
                    self.spy( desc + ' [smartrun]' )
                    smartrun( buf )
                else
                    return( 0 )
                end
            end                        
            return( 1 )
                        
          case 'B'
            self.spy( desc + ' [codeblock]' )
            if ( type( obj ) == 'O' )
                ( buf )( obj )
            else
                ( buf )( )
            end    
            return( 1 )

        end
        return( 0 )
    END

    METHOD show
        if (self.hbkwin)
            if (self.v_bkwindow)
                winShow(self.hbkwin, ((pcount() == 1) ? 5 : param(2)))
            else
                winShow(self.hbkwin, 0)
            end
        end
        winShow(self.handle, ((pcount() == 1) ? 5 : param(2)))
    END
  
    ACCESS sound
        return(self.IsSound)
    END

    ASSIGN sound(flag)
        self.IsSound = flag
        return
    END

    METHOD spy( str )
        if ( self.IsSpy )
            println( str )
        end
        return( 1 )
    END

    METHOD TextFromAlias( alias )
        local obj
        obj = self.ObjFromAlias( alias )
        if ( type( obj ) == 'O' )
            return( winGetText( obj.handle ) )
        end
        return( '' )
    END

    ACCESS valid
        return(winIsValid(self.handle))
    END
    
END


CLASS wincontrol
  PUBLIC:
    local dlg, page, type, text, x, y, width, height, style, cmd, id, handle, sound, hidden, hfont, bkclr, alias

    METHOD new(pdlg, page, type, text, x, y, width, height, style, cmd, snd, hfont, bkclr, alias)
        self.dlg    = pdlg
        self.page   = page
        self.type   = upper(type)
        self.text   = text
        self.x      = x
        self.y      = y
        self.width  = width
        self.height = height
        self.style  = style
        self.cmd    = cmd
        self.sound  = snd
        self.hfont  = hfont
        self.bkclr  = bkclr
        self.hidden = (page == 0) ? 0 : 1
        self.alias  = type( alias ) == 'C' ? alias : ''
        self.id     = dlgCreate(self.dlg.handle, type, text, ((x > 0) ? xadj(x) : x), ((y > 0) ? yadj(y) : y), ((width > 0) ? xadj(width) : width), ((height > 0) ? yadj(height) : height), style, (self.type == 'TAB') ? 1 : self.bkclr)
        self.handle = dlgWinFromId(self.dlg.handle, self.id)

        if (hfont)
            fontset(self.handle, hfont)
        end

        // hide the control if not part of the master page
        dlgSetHiddenFlag(self.dlg.handle, self.id, self.hidden)

        return(1)
    END


    METHOD delete()
        dlgDeleteControl(self.dlg.handle, self.id)
    END


    METHOD display
        return(dlgSetHiddenFlag(self.dlg.handle, self.id, 0))
    END

    METHOD hide
        return(dlgSetHiddenFlag(self.dlg.handle, self.id, 1))
    END
END


CLASS winpages
  PUBLIC:
    local dlg, title, bkimage

    METHOD new( dlg, title, bkimage )
        self.dlg     = dlg
        self.title   = title
        self.bkimage = type( bkimage ) == 'C' ? bkimage : ''
        return(1)
    END

END


CLASS iniFile
  // new(inifile)
  // destroy()
  // GetString(section, key, defval)
  // SetString(section, key, value)

  PUBLIC:
    local filename, hfile

    METHOD new( inifile )
        local file

        file = fileFindFullName( inifile )
        if ( strempty( file ) )
            return( 0 )
        end
        self.filename = file
        return( 1 )
    END

    METHOD GetString(section, key, defval)
        return( iniGetString( self.filename, section, key, defval ) )
    END


    METHOD SetString(section, key, val)
        return( iniSetString( self.filename, section, key, val ) )
    END

END

  








CLASS iniItem       // object items data structure

  PUBLIC:
    local ini, section, key, desc, action, sound

    METHOD new( ini, section, key )
        self.ini = ini
        self.section = section
        self.key = key
        self.get( )
        return( 1 )
    END

    METHOD get( )
        local str
        str = iniGetString( self.ini, self.section, self.key, '' )
        
        self.desc      = strextract( str, '|', 1 )
        self.action    = strextract( str, '|', 2 )        
        self.sound     = strextract( str, '|', 3 )

        return( str )
    END

    METHOD set( )
        local str

        str = self.desc + '|' + self.action + '|' + self.sound
        return( iniSetString( self.ini, self.section, self.key, str ) )
    END

END



FUNCTION Properties( dlg )
    local style, win, id, alias, actionstr, soundstr, obj
    local params, options, about, textclr, titleclr, head, contacttext, descstr

    textclr = RGB( 0, 0, 128 )
    titleclr = textclr
        
    id = dlgEventID( dlg.handle ) // who called us

    // check the alias
    alias = dlg.AliasFromId( id )
    if ( strempty( alias ) )
        return( 0 )
    end

    // get the data object
    obj = new( 'iniItem', inifile, 'data', alias )
    if ( type( obj ) != 'O' )
        msgdelay( 2000, 'Unable to access ' + alias + ' data item in ' + inifile )
        return( 0 )
    end
    
    style = 0x00C00000 | (0x7FFFFFFF + 1)        // caption, popup
    win = new( 'window', dlg.handle, 'Program Options - ' + obj.Desc, -1, -1, 200, 157, style, RGB(192,192,192), RGB(0,0,255), 0 )
    if ( type( win ) != 'O' )
        return( 0 )
    end
    win.bkframe  = 1

    // create some pages for the tab control
    params  = win.pageCreate( '&Parameters', '' )
    options = win.pageCreate( 'Op&tions', '' )
    about   = win.pageCreate( '&About', '' )

    // create the tab control on the master page
    win.controls( 'TAB', '', -1, 0, 0, 0, 1 | 2, '', '' )
    
    descstr = 'Enter the DESCRIPTION for this item:'
    win.pageControls( params, 'text', descstr,     15,  23, 172,  9, 0, '', '', hSmallFont, textclr )
    win.pageControls( params, 'edit', obj.Desc,    16,  33, 171,  9, 0, '', '', hSmallFont, 0, 'Desc' )

    actionstr = 'Enter the name of the PROGRAM TO RUN when this item is selected. Click on the browse [ >> ] button to search for a specific application, or enter any VirtualDESK command:'
    win.pageControls( params, 'text', actionstr,   15,  50, 172, 24, 0, '', '', hSmallFont, textclr )
    win.pageControls( params, 'edit', obj.Action,  16,  76, 155,  9, 0, '', '', hSmallFont, 0, 'Action' )
    win.pageControls( params, 'pb',   ' >>',      176,  75,  11, 11, 0, {||browseActions(win)}, '', hSmallFont )

    soundstr = 'Enter the name of the SOUND TO PLAY when selected:'    
    win.pageControls( params, 'text', soundstr,    15,  96, 172,  9, 0, '', '', hSmallFont, textclr )
    win.pageControls( params, 'edit', obj.Sound,   16, 106, 155,  9, 0, '', '', hSmallFont, 0, 'Sound' )
    win.pageControls( params, 'pb',   ' >>',      176, 105,  11, 11, 0, {||browseSound(win)}, '', hSmallFont )
    
    win.pageControls( options, 'gb',  'Startup',            15,  24,  80,  96, 0, '', '', hSmallFont, 0 )
    win.pageControls( options, 'rb',  'Access Area',        25,  36,  60,   9, 0, '', '', hSmallFont, 0 )
    win.pageControls( options, 'rb',  'Computer Area',      25,  46,  60,   9, 0, '', '', hSmallFont, 0 )
    win.pageControls( options, 'rb',  'Conference Area',    25,  56,  60,   9, 0, '', '', hSmallFont, 0 )
    win.pageControls( options, 'rb',  'Custom Area',        25,  66,  60,   9, 0, '', '', hSmallFont, 0 )
    win.pageControls( options, 'rb',  'Directory Area',     25,  76,  60,   9, 0, '', '', hSmallFont, 0 )
    win.pageControls( options, 'rb',  'Productivity Area',  25,  86,  60,   9, 0, '', '', hSmallFont, 0 )
    win.pageControls( options, 'rb',  'Reference Area',     25,  96,  60,   9, 0, '', '', hSmallFont, 0 )
    win.pageControls( options, 'rb',  'Utility Area',       25, 106,  60,   9, 0, '', '', hSmallFont, 0 )

    win.pageControls( options, 'gb',  'Security',          103,  24,  83,  46, 0, '', '', hSmallFont, 0 )
    win.pageControls( options, 'cb',  'Enable Security',   110,  35,  60,   9, 0, '', '', hSmallFont, 0 )
    win.pageControls( options, 'text','Password:',         110,  45,  60,   9, 0, '', '', hSmallFont, 0 )
    win.pageControls( options, 'edit','',                  109,  55,  71,   9, 0, '', '', hSmallFont, 0 )

    win.pageControls( options, 'gb',  'Other',             103,  74,  83,  46, 0, '', '', hSmallFont, 0 )
    win.pageControls( options, 'cb',  'Full Screen',       110,  84,  60,   9, 0, '', '', hSmallFont, 0 )
    win.pageControls( options, 'cb',  'Enable Sounds',     110,  93,  60,   9, 0, '', '', hSmallFont, 0 )
    win.pageControls( options, 'pb',  'Advanced Customization', 108, 104,  73,  11, 0, '', '', hSmallFont, 0 )

    head[1] = 'SmartDesk'
    head[2] = 'Screen Launcher'
    head[3] = 'v2.5'
    head[4] = '(c) 1996, SmartDesk, Inc.'
    head[5] = "All Rights Reserved.\r714-582-4020"

    contacttext[1] = 'Visit us at www.smartdesk.com'
    contacttext[2] = 'Setup & Launcher created with VirtualDESK'

    win.pageControls( about, 'image','execspla.tif',     15,  25,  95,  71, 8, '', '', 0 )
    win.pageControls( about, 'text',  head[1],          115,  35,  75,   9,  0, '', '', hbigfont, titleclr )
    win.pageControls( about, 'text',  head[2],          115,  44,  75,   9,  0, '', '', hbigfont, titleclr )
    win.pageControls( about, 'text',  head[3],          115,  53,  75,   9,  0, '', '', hbigfont, titleclr )
    win.pageControls( about, 'text',  head[4],          115,  68,  75,   8,  0, '', '', hsmallfont, 0 )
    win.pageControls( about, 'text',  head[5],          115,  75,  75,  20,  0, '', '', hsmallfont, 0 )

    win.pageControls( about, 'text',  contacttext[1],    10, 103, 185,   9, -1, '', '', hbigfont, titleclr )
    win.pageControls( about, 'text',  contacttext[2],    10, 112, 185,   7, -1, '', '', hsmallfont, 0 )

    win.onOK     = { ||SaveProperties( win, obj ) }
    win.onCancel = { ||win.close() }
    win.onHelp   = ''

    win.pageDisplay( params )
    win.ProcessEvents( )
    win.close( )

    return( 1 )
END


FUNCTION RunAction( dlg )
    local id, alias, obj, textclr, titleclr, o

    textclr = RGB( 0, 0, 128 )
    titleclr = textclr
        
    id = dlgEventID( dlg.handle ) // who called us

    // check the alias
    alias = dlg.AliasFromId( id )
    if ( strempty( alias ) )
        // get any attached action
        obj = dlg.ObjFromId( id )
        if ( type( obj ) == 'O' )
            if ( type( obj.cmd ) == 'B' )
                ( obj.cmd )( )
                return( 1 )
            end
        end
        return( 0 )
    end

    // get the data object
    obj = new( 'iniItem', inifile, 'data', alias )
    if ( type( obj ) != 'O' )
        msgdelay( 2000, 'Unable to access ' + alias + ' data item in ' + inifile )
        return( 0 )
    end

    if ( ! strempty( obj.Sound ) )
        sndPlayWaveFile( obj.Sound )
    end
    if ( ! strempty( obj.Action ) )
        if ( at( '(', obj.action ) > 0 )
            &( obj.action )
        else
            smartrun( obj.Action )
        end
    else
        // check for default action
        o = dlg.ObjFromId( id )
        if ( type( o ) == 'O' )
            if ( type( o.cmd ) == 'B' )
                ( o.cmd )( )
                return( 1 )
            end
        end
    end    
    
    return( 1 )    
END


FUNCTION SaveProperties( win, data )
    data.Desc   = win.TextFromAlias( 'Desc' )
    data.Action = win.TextFromAlias( 'Action' )
    data.Sound  = win.TextFromAlias( 'Sound' )
    data.Set( )
    win.close( )
    return( 1 )
END
   
   
FUNCTION browseActions( win )

    local filterstr, textstr, obj

    // get the current object    
    obj = win.ObjFromAlias( 'Action' )
    if ( type( obj ) != 'O' )
        return( 0 )
    end
    
    filterstr = 'All Executables|*.exe;*.com;*.bat;*.pif;*.fgl;*.fgx|All Files|*.*|Executable|*.exe|Command|*.com|Batch|*.bat|PIF|*.pif|FGL|*.fgl|FGX|*.fgx||'
    textstr = fileSelect( win.handle, 'Select Program to Run', '', filePathName( winGetText( obj.handle ) ), filterstr )
    if ( textstr )
        dlgSetText( obj.handle, lower( textstr ) )
    end
    return( 1 )
END


FUNCTION browseSound( win )

    local filterstr, textstr, obj

    // get the current object    
    obj = win.ObjFromAlias( 'Sound' )
    if ( type( obj ) != 'O' )
        return( 0 )
    end

    filterstr = 'Wave File|*.wav|MIDI files|*.mid|All Files|*.*||'
    textstr = fileSelect( win.handle, 'Select Sound to Play', '', filePathName( winGetText( obj.handle ) ), filterstr )
    if ( textstr )
        dlgSetText( obj.handle, lower( textstr ) )
    end
    return( 1 )
END

  
FUNCTION splash( title, image, delay )
    local style, hwnd

    style = ( 0x7FFFFFFF + 1 )        // caption, popup

    hwnd = dlgCreate( 0, 'DLG', title, -1, -1, 163, 123, style, RGB( 192, 192, 192 ) )
    dlgCreate( hwnd, 'image', image, 3, 3, 320, 240, 0, 0 )
    dlgExStyle( hwnd, dlgExStyle( hwnd ) | 2 )
    
    winShow( hwnd, 5 )
    wait( ( delay < 100 ) ? delay * 1000 : delay )
    winClose( hwnd )

    return( 1 )
END


FUNCTION EndProgram( win )
    win.close()
    return( 1 )
END


FUNCTION Done( )
    gslExecWin.close( )
    return( 1 )
END


