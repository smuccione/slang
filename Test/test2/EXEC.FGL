///////////////////////////////////////////////////////////////////////////////
// main
/////////

local style, win, err, objStat, objTime

TRY

hSmallFont = fontCreate( 'Arial', 12, 0, 0, 0, 0 )
hBigFont   = fontCreate('Arial', 18, 0, 0, 0, 0)
TextColor  = RGB( 0, 0, 128 )
inifile = sysbasepath( ) + '\exec.dat'

//style = 0x00C00000 | 0x00080000 | (0x7FFFFFFF + 1)        // caption, system menu, popup
style = (0x7FFFFFFF + 1)        // caption, system menu, popup
win = new( 'window', 0, 'Executive Screen Launcher', -1, -1, 320, 240, style, RGB( 192, 192, 192 ), RGB( 0, 0, 0 ), 1 )
if ( type( win ) != 'O' )
    logoff( )
    return( 0 )
end
//win.bkframe  = 1
win.bkpaint  = 0
//win.Debug    = 1

gslExecWin = win

win.onOK      = 'sndwarble(1)'
win.onCancel  = { ||EndProgram( win ) }
win.onHelp    = 'notepad.exe c:\config.sys'
win.onPageSet = { ||PageSet( win ) }
win.onLeftClick = { || RunAction( win ) }
win.onRightClick = { || Properties( win ) }

//win.IsSpy = 1

// create some pages
pg_acce = win.pageCreate( 'access',       'execacce.tif' )
pg_comp = win.pageCreate( 'computer',     'execcomp.tif' )
pg_conf = win.pageCreate( 'conference',   'execconf.tif' )
pg_cust = win.pageCreate( 'custom',       'execcust.tif' )
pg_dire = win.pageCreate( 'directory',    'execdire.tif' )
pg_prod = win.pageCreate( 'productivity', 'execprod.tif' )
pg_refe = win.pageCreate( 'reference',    'execrefe.tif' )
pg_util = win.pageCreate( 'utility',      'executil.tif' )

win.Controls( 'rect', '',   1,  229, 320, 10, 128, '', '', hSmallFont, RGB(192,192,192) )

objStat = win.Controls( 'text', 'Executive Screen Launcher',   5,  230, 215, 8, 0, '', '', hSmallFont, 0, 'execStatus' )
objTime = win.Controls( 'text', '', 228,  230,  80, 8,  -2, '', '', hSmallFont, 0, 'execTime' )
win.Controls( 'image', 'execdire.tif', 310,  230,   8, 8, 2, { || win.pageDisplay( 0 + pg_dire ) }, '', hSmallFont, 0, 'execDire' )
//win.Controls( 'image', 'execdire.tif', 311,  231,   6, 6, 2, { || win.pageDisplay( 0 + pg_dire ) }, '', hSmallFont, 0, 'execDire' )

winShow( win.hbkwin, 5 )            // display the background...
sndplaywavefile( 'execstrt.wav' )   // ...play a sound...
splash( '', 'execspla.tif', 2000 )  // ...now the splash screen

// display the dialog box
win.pageDisplay( 0 + pg_acce )

// activate the tooltip function
threadAdd( 'Display Tip', { || DisplayTip( win, objStat.handle, objTime.handle ) } )

win.ProcessEvents( )
win.close( )

fontDestroy( hSmallFont )
fontDestroy( hBigFont )

logoff()

CATCH ( err )
    msgDelay( 3000, 'Error ' + err.errornum + ' at line ' + err.errorline + ' (' + ErrorAsText( err.errornum ) + ')' )
    logoff( )
END
