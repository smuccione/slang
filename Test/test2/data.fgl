CLASS objClientDBF

  // Access Variables:
  //   dbFileName
  //   dbIndexName
  //   dbIndexName2
  //   DataTypes

  // Methods:
  //   New( )
  //   Close( )
  //   Create( )
  //   Get( )
  //   HardClose( )
  //   Init( )
  //   Open( )
  //   Put( )
  //   rlock( )
  //   Reindex( )
  //   Seek( item )
  //   SelectBegin( key, IndexId, dtype )
  //   SelectEnd( )
  //   SelectNextRecord( )
  //   SelectRecords( key, IndexId, dtype )
  //   unlock( )

  PUBLIC:
    local IsOpen, errmsg, LockTimeout, aSelect, aSelectNextRec
    local created, data, dataref, dstatus, dtype, key, lastused, objref
    local password, subkey, usagecnt

    METHOD New( )
        ::IsOpen = 0
		::errmsg = ""
		::LockTimeout = 3
        ::Init( )
        return( 1 )
    END

    METHOD Init( )
        ::created = ""
        ::data = 0
        ::dataref = ""
        ::dstatus = 0
        ::dtype = 0
        ::key = ""
        ::lastused = ""
        ::objref = ""
        ::password = ""
        ::subkey = ""
        ::usagecnt = 0
        return( 1 )
    END


	ACCESS DataTypes
		local aval = {
			"Header",
			"Quote",
			"Application",
			"Endorsement",
			"Payment",
			"Claim"
		}
		return( aval )
	END


    ACCESS dbFileName
        return( 'c:\sdweb\home\insmgmt\admin\insmgmt\data\client.db' )
    END

    ACCESS dbIndexName
        return( 'c:\sdweb\home\insmgmt\admin\insmgmt\data\client.dx' )
    END
    ACCESS dbIndexName2
        return( 'c:\sdweb\home\insmgmt\admin\insmgmt\data\client.dx2' )
    END

    METHOD create( )
        local db_struct = {
            { "KEY", "C", 65, 0 },
            { "SUBKEY", "C", 65, 0 },
            { "OBJREF", "C", 65, 0 },
            { "DATAREF", "C", 65, 0 },
            { "PASSWORD", "C", 20, 0 },
            { "DTYPE", "N", 9, 0 },
            { "DSTATUS", "N", 9, 0 },
            { "CREATED", "C", 20, 0 },
            { "LASTUSED", "C", 20, 0 },
            { "USAGECNT", "N", 6, 0 },
            { "DATA", "B", 20, 0 },
            { "VERIFY", "~", 4, 0 }
        }
        return( dbcreate( ::dbFileName, db_struct ) )
    END

    METHOD open( )
        if ( ! ::IsOpen )
            dbuse( ::dbFileName, "ClientDBF", 1 )
            ClientDBF->dbOpenIndex( ::dbIndexName2 )
            ClientDBF->dbOpenIndex( ::dbIndexName )
        end
        ::IsOpen++
        return( 1 )
    END

    METHOD close( )
        if ( ::IsOpen == 1 )
            ClientDBF->dbClose( )
        end
        ::IsOpen--
        if ( ::IsOpen < 0 )
        	// should never happen unless caller crashes before exiting
        	::IsOpen = 0
        end
        return( 1 )
    END

	METHOD HardClose( )
		::IsOpen = 1
		::close( )
		return( 1 )
	END

	METHOD rlock( )
		local EndTime
		if ( ! ::IsOpen )
			::errmsg = "Database must be open to lock record"
			return( 0 )
		end
		EndTime = seconds( ) + ::LockTimeout
		while ( ! ClientDBF->dbRLock( ) )
			if ( ( seconds( ) > EndTime ) || ( ( seconds( ) + ::LockTimeout ) < EndTime ) )
				::errmsg = "Unable to lock database record"
				return( 0 )
			end
		end
		return( 1 )
	END

	METHOD unlock( )
		if ( ! ::IsOpen )
			::errmsg = "Database must be open to unlock record"
			return( 0 )
		end
		ClientDBF->dbUnLock( )
		return( 1 )
	END

    METHOD seek( item )
        ClientDBF->dbSeek( item )
        return( ClientDBF->dbFound( ) )
    END


	METHOD SelectBegin( key, IndexId, dtype )
		::aSelect = ::SelectRecords( key, IndexId, dtype )
		if ( ! ::aSelect[ 1 ] )
			return( 0 )
		end
		::aSelectNextRec = 1
		return( 1 )	
	END

	METHOD SelectEnd( )
		::aSelect = 0
		::aSelectNextRec = 0
		return( 1 )	
	END

	METHOD SelectNextRecord( )
		if ( ! ::aSelectNextRec )
			return( 0 )
		end
		if ( ! ::aSelectNextRec > len( ::aSelect ) )
			return( 0 )
		end
		
		ClientDBF->dbGoto( ::aSelectNextRec++ )
		
		return( 1 )
	END


	METHOD SelectRecords( key, IndexId, dtype )
		local aval, keylen, _key, IsDataType, i

		IsDataType = ( type( dtype ) == "N" ? dtype : 0 )

		aval[1] = 0
	
		if ( ! ::seek( key ) )
			return( aval )
		end
		
		keylen = len( key )
		_key = upper( key )
		i=1
		while ( ! ClientDBF->dbEOF( ) )
			if ( IndexId == 2 )
				if ( _key == upper( left( ClientDBF->key, keylen ) ) )
					if ( IsDataType )
						if ( dtype == ClientDBF->dtype )
							aval[ i++ ] = ClientDBF->dbRecNo( )
						end
					else
						aval[ i++ ] = ClientDBF->dbRecNo( )
					end
				else
					break
				end
			else
				if ( _key == upper( left( ClientDBF->subkey, keylen ) ) )
					if ( IsDataType )
						if ( dtype == ClientDBF->dtype )
							aval[ i++ ] = ClientDBF->dbRecNo( )
						end
					else
						aval[ i++ ] = ClientDBF->dbRecNo( )
					end
				else
					break
				end
			end
			ClientDBF->dbSkip( )
		end
		
		return( aval )
	END

    METHOD reindex( )
        return( ClientDBF->dbReindex( ) )
    END

    METHOD get( )
        ::created = ClientDBF->created
        ::data = ClientDBF->data
        ::dataref = ClientDBF->dataref
        ::dstatus = ClientDBF->dstatus
        ::dtype = ClientDBF->dtype
        ::key = ClientDBF->key
        ::lastused = ClientDBF->lastused
        ::objref = ClientDBF->objref
        ::password = ClientDBF->password
        ::subkey = ClientDBF->subkey
        ::usagecnt = ClientDBF->usagecnt
        return( 1 )
    END

    METHOD put( )
        ClientDBF->created = ::created
        ClientDBF->data = ::data
        ClientDBF->dataref = ::dataref
        ClientDBF->dstatus = ::dstatus
        ClientDBF->dtype = ::dtype
        ClientDBF->key = ::key
        ClientDBF->lastused = ::lastused
        ClientDBF->objref = ::objref
        ClientDBF->password = ::password
        ClientDBF->subkey = ::subkey
        ClientDBF->usagecnt = ::usagecnt
        return( 1 )
    END

END


CLASS objRefLib

  // Access Variables:
  //   dbFileName
  //   dbIndexName
  //   dbIndexName2
  //   DataTypes

  // Methods:
  //   New( )
  //   Close( )
  //   Create( )
  //   Get( )
  //   HardClose( )
  //   Init( )
  //   Open( )
  //   Put( )
  //   rlock( )
  //   Reindex( )
  //   Seek( item )
  //   SelectBegin( key, IndexId, dtype )
  //   SelectEnd( )
  //   SelectNextRecord( )
  //   SelectRecords( key, IndexId, dtype )
  //   unlock( )

  PUBLIC:
    local IsOpen, errmsg, LockTimeout, aSelect, aSelectNextRec
    local created, data, dataref, dstatus, dtype, key, lastused, objref
    local password, subkey, usagecnt

    METHOD New( )
        ::IsOpen = 0
		::errmsg = ""
		::LockTimeout = 3
        ::Init( )
        return( 1 )
    END

    METHOD Init( )
        ::created = ""
        ::data = ""
        ::dataref = ""
        ::dstatus = 0
        ::dtype = 0
        ::key = ""
        ::lastused = ""
        ::objref = ""
        ::password = ""
        ::subkey = ""
        ::usagecnt = 0
        return( 1 )
    END

	ACCESS DataTypes
		local aval = {
			"Text",
			"Binary",
