function Walk()
	debugBreak()

   println ( "Checking database integrity" );

   dbuse       ( "dmtf\\DMIcomp", "component", 1 )

   while ( !(component->dbeof()) )
      println ( "NAME: ", component->name )
      if ( component->desc )
         println ( "DESC: ", component->desc )
      end
      component->dbskip()
   end

   component->dbclose()
end

function main()
   println ( "Walking..." )
   walk()
end
