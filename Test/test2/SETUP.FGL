STATIC prodname

//LIBRARY sysclass


//
// SYSCLASS.FGL - System Classes
//
// (c) 1996 Advanced Desktop Research, Inc., All Rights Reserved.
//
// Classes in this library:
//
//                    Access  Assign  Method
//    Window     
//      new             -       -       X
//      aliasID         -       -       X       // old
//      AliasFromId     -       -       X
//      bkframe         X       X       -
//      bkimage         X       X       -
//      bkpaint         X       X       -
//      bkwindow        X       X       -
//      close           -       -       X
//      controls        -       -       X
//      CurEventId      -       -       X
//      CurEventObj     -       -       X
//      debug           X       X       -
//      display         -       -       X
//      hicon           X       X       -
//      hide            -       -       X
//      IdFromAlias     -       -       X
//      ObjFromAlias    -       -       X
//      ObjFromId       -       -       X
//      pageControls    -       -       X
//      pageCreate      -       -       X
//      pageDisplay     -       -       X
//      processEvents   -       -       X
//      runBuffer       -       -       X
//      show            -       -       X
//      sound           X       X       -
//      spy             -       -       X
//      TextFromAlias   -       -       X           // get the text assoc with an object from its alias
//      valid           X       -       -
//      
//    WinControl
//      new             -       -       X
//      delete          -       -       X
//      display         -       -       X
//      hide            -       -       X
//
//    WinPages
//      new             -       -       X
//
//    iniFile
//      new             -       -       X
//      GetString       -       -       X
//      SetString       -       -       X
//
