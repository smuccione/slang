<[

CLASS objNotes
  PUBLIC:
    local IsOpen, errmsg
    local date, msg, scope, time

    METHOD New( )
        ::IsOpen = 0
        ::errmsg = ""
        ::Init( )
        return( 1 )
    END

    METHOD Init( )
        ::date = ""
        ::msg = ""
        ::scope = 0
        ::time = ""
        return( 1 )
    END

    ACCESS dbFileName
        return( 'C:\SDWEB\HOME\tristate\data\notes.db' )
    END

    METHOD create( )
        local db_struct = {
            { "DATE", "C", 8, 0 },
            { "TIME", "C", 8, 0 },
            { "MSG", "B", 20, 0 },
            { "SCOPE", "N", 9, 0 }
        }
        return( dbcreate( ::dbFileName, db_struct ) )
    END

    METHOD open( )
        if ( ::IsOpen )
            ::IsOpen++
            return( 1 )
        end

        if ( ! fileExists( ::dbFileName ) )
            ::create( )
        end

        ::IsOpen = 1

        dbuse( ::dbFileName, "Notes", 1 )
        return( 1 )
    END

    METHOD close( )
        if ( ::IsOpen == 1 )
            Notes->dbClose( )
        end
        ::IsOpen--
        return( 1 )
    END

    METHOD seek( item )
        Notes->dbSeek( upper( item ) )
        return( Notes->dbFound( ) )
    END

    METHOD reindex( )
        return( Notes->dbReindex( ) )
    END

    METHOD get( )
        ::date = alltrim( Notes->date )
        ::msg = alltrim( Notes->msg )
        ::scope = Notes->scope
        ::time = alltrim( Notes->time )
        return( 1 )
    END

    METHOD put( )
        Notes->date = ::date
        Notes->msg = ::msg
        Notes->scope = ::scope
        Notes->time = ::time
        return( 1 )
    END

    METHOD validate( )
        return( 1 )
    END

    METHOD CreateNewRecord( key )
        if ( ! ::validate( ) )
            return( 0 )
        end

        ::open( )
        if ( ::seek( key ) )
            ::errmsg = "Record (" + key + ") already exists!"
            ::close( )
            return( 0 )
        end

        Notes->dbAppend( )
        ::put( )

        ::close( )
        return( 1 )
    END

    METHOD GetRecord( key )
        ::open( )

        ::init( )
        if ( ! ::seek( key ) )
            ::errmsg = "Unable to locate record (" + key + ")"
            ::close( )
            return( 0 )
        end

        ::get( )
        ::close( )

        return( 1 )
    END

    METHOD SetRecord( key )
        if ( ! ::validate( ) )
            return( 0 )
        end

        ::open( )

        if ( ! ::seek( key ) )
            ::errmsg = "Unable to locate record (" + key + ")"
            ::close( )
            return( 0 )
        end

        ::put( )
        ::close( )

        return( 1 )
    END

	METHOD ListNotes( )
		local s="", i
		::open( )

		Notes->dbGoBottom( )

		while ( ! Notes->dbBOF( ) )
			::get( )

			s += "<b>" + ::date + " " + timetostr( ::time, 0 ) + "m</b><br>" + ::msg + "<br><br>"

			Notes->dbSkip( -1 )
		end
		if ( right( "        " + s, 8 ) == "<hr><br>" )
			s = left( s, len( s ) - 8 )
		end

		::close( )

		return( s )
	END


END

debugBreak( )

_apGenerate( )

session = new( "session" )

//note = new( "objNotes" )

]>

