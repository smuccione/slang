<[
class base
public:
    local x

    method virtual getY( )
       return 0
    end

    method getResult( )
       return ::getY( )
    end

end

class childX
public:
    inherit base

    method new( x )
       ::x=x
       return ( 1 )
    end

    method getY( ) in base
       return ::x + 5
    end
end

DebugBreak()
foo = new( "childX", 10)
z = foo.getResult( )

]>
