global taskEnd

public function task1()
   println ( "starting task 1" )
   taskWait ( {||taskEnd == 1} )
   println ( "ending   task 1" )
end

public function task2()
   println ( "starting task 2" )
   taskWait ( {||taskEnd == 1} )
   println ( "ending   task 2" )
end

public function task3()
   println ( "starting task 3" )
   taskWait ( {||taskEnd == 1} )
   println ( "ending   task 3" )
end

function main()
   // initialize the semaphore

   taskEnd = 0;

   spawn ( "TASK 1", "task1()" )
   spawn ( "TASK 2", "task2()" )
   spawn ( "TASK 3", "task3()" )

   for ( loop = 0; loop < 50; loop++ )
   end

   tasks = taskList()

   for ( x = 1; x <= amaxi(tasks); x++ )
      println ( "id: ", tasks[x,1], "  thread: ", tasks[x,2],"  name: ", untrim ( tasks[x,3], 10 ), "  nTicks: ", tasks[x,4], "  exclusive: ", tasks[x,5], "  halted: ", tasks[x,6] )
   end

   // signal global semaphore to end the other tasks

   taskEnd = 1;

   // here we delay so the taskSwitch() will get called and the other tasks
   // will get a chance to run (or exit the taskWait() as it were

   for ( loop = 0; loop < 50; loop++ )
   end

   tasks = taskList()

   println ( "-----------------------------------------------------------" )

   for ( x = 1; x <= amaxi(tasks); x++ )
      println ( "id: ", tasks[x,1], "  thread: ", tasks[x,2],"  name: ", untrim ( tasks[x,3], 10 ), "  nTicks: ", tasks[x,4], "  exclusive: ", tasks[x,5], "  halted: ", tasks[x,6] )
   end

   tasks = tasklist()
   for ( x = 3; x <= amaxi(tasks); x++ )
      taskKill ( tasks[x,1] )
   end
end

