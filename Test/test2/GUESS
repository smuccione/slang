local number, low, high, guess

while ( 1 )
  number = random () % 20 + 1

  high = 20
  low  = 1

  repeat
//     print ( "Guess the number (", low, " - ", high, ") ? ")
     print ( "Guess the number (1-20) ? ")
     guess = 1 * input ( 2 )
     println()

     if ( guess < low )
        println ( "You're guess needs to be more then ", low - 1 )
     elseif ( guess > high )
        println ( "You're guess needs to be less then ", high + 1 )
     elseif ( guess < number )
        println ( "You're guess is to low" )
        low = guess + 1
     elseif ( guess > number )
        println ( "You're guess is to high" )
        high = guess - 1
     end
  until ( guess == number )

  println ()
  println ( "Y   Y  OO  U  U   GGGG  OO  TTTTT   IIIII TTTTT  !!")
  println ( "Y   Y O  O U  U   G    O  O   T       I     T    !!")
  println ( " Y Y  O  O U  U   G GG O  O   T       I     T    !!")
  println ( "  Y   O  O U  U   G  G O  O   T       I     T      ")
  println ( "  Y    OO   UU    GGGG  OO    T     IIIII   T    !!")


  println ()
  print   ( "Play again? " )

  if ( upper ( input ("Y" ) ) != 'Y' )
     break
  end
  println ()
end
