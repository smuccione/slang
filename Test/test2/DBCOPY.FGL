function copy ( file )
   local dbfStruct
   local loop
   local cnt
   local x

   src = 'c:\sdweb\home\insmgmt\data\' + file + '.db'
   dst = 'c:\new\' + file + '.db'

   if ( !dbUse ( src, "SRC", 1 ) )
      println ( "error: can't open ", src )
      return(0)
   end

   dbfStruct  = src->dbstruct()

   if ( !dbCreate ( dst, dbfStruct ) )
      println ( "error: can't create ", dst )
   end

   if ( !dbUse ( dst, "DST", 1 ) )
      println ( "error: can't open ", dst )
      return(0)
   end

   printf ( "copying %s -> %s\r\n", src, dst )
   
   cnt = src->dbFieldCount()

   println ( "records to copy - ", src->dbLastRec() )

src->dbGoTo ( 71000 )

   x = 0
   while ( !src->dbEOF () )
      if( ++x % 100 == 0 )
         printf ( "record: %u\r", src->dbRecno() )
      end
      if ( !src->dbisdeleted() )
         dst->dbAppend()
         for ( loop = 1; loop <= cnt; loop++ )
            dst->dbFieldPut ( loop, src->dbFieldGet ( loop ) )
            a = src->dbFieldGet ( loop )
            b = dst->dbFieldGet ( loop )
            
            if ( a != b )
            	DebugBreak()
            end
         end
      end
      src->dbSkip()
   end

	dst->dbGoTop ()
	src->dbGoTop()
   while ( !dst->dbEOF () )
     printf ( "verifying: %u\r", dst->dbRecno() )
	 for ( loop = 1; loop <= cnt; loop++ )
	 	a = src->dbFieldGet ( loop )
		b = dst->dbFieldGet ( loop )            
		if ( a != b )
			DebugBreak()
		end
	 end
	 src->dbSkip()
      dst->dbSkip()
   end

   src->dbClose()
   dst->dbClose()
end

