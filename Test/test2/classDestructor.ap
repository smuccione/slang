<[
	class test
		local x
		
		method new ( x )
			::x = x
			return ( 1 )
		end
		
		method release()
			printf ( "destructor called: %i\r\n", ::x )
		end		
	end
	
	debugBreak()
	
	o1 = test(1)
	o2 = test(2)
	o3 = test(3)
	
	o2.release()
	o1 = null
	
	printf ( "collecting 1 \r\n" );
	omCollect()
	
	
	o3 = null
	
	printf ( "collecting 2 \r\n" );
//	omCollect()
	
	printf ( "done\r\n" )
]>
