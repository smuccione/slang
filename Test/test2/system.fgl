CLASS GlobalParams
  PUBLIC:
  	local datadir, errmsg, prefix, reflib, insdata
  	
  	METHOD new( )
  		return( ::init( ) )
  	END
  	
  	METHOD init( )
  		::datadir = 'c:\sdweb\home\fcd\'
  		::prefix = "ID"
		::errmsg = ""
		::reflib = NIL
		::insdata = NIL
		if ( ! fileExists( ::idDataFile ) )
			::errmsg = "Data file " + ::idDataFile + " does not exist."
		end
  		return( 1 )
  	END

	METHOD GetNextId( )
		local fname = ::idDataFile
		local val = 0 + iniGetString( fname, "CONFIG", "IDVAL", "" )
		if ( ! val )
			val = 100000
			iniSetString( fname, "CONFIG", "IDVAL", "" + val )
		else
			iniSetString( fname, "CONFIG", "IDVAL", "" + ( val ) )
		end
		val++
		return( "" + val )
	END
  	
  	ACCESS idDataFile
  		return( ::datadir + 'data\system.dat' )
  	END

  	ACCESS GetUniqueID
  		local val

  		val = iniGetString( ::idDataFile, "CONFIG", "ID", "" )
  		if ( strempty( val ) )
 			::errmsg = "ID Value set at zero."
  		end
  		iniSetString( ::idDataFile, "CONFIG", "ID", "" + ( 0 + val + 1 ) )
  		
  		return( ::prefix + right( dec2hex( 0 + val ), 6 ) )
  	END

	METHOD GetUniqueOutputFile( )
		local fname, dte, i=1
		
		// admin maintenance - delete old report files
		fname = fileFindFirst( ::datadir + 'reports\output\*.*', 0 )
		dte = jdate( ) - 1	 // delete if 1 day old
		while ( ! strempty( fname ) )
			if ( i > 10 )
				// MOREWORK: Make sure files are deleted faster then created
				break
			end
			fname = ::datadir + 'reports\output\' + fname
			if ( datej( filedate( fname ) ) <= dte )
				fileDelete( fname )
			else
				i++
			end
			fname = fileFindNext( )
		end

		// MOREWORK: Check for available disk space!!!
		
		// get unique filename
//		fname = ::datadir + 'reports\output\' + fileTempName( ::datadir + 'reports\output\d*.htm' )
		fname = fileTempName( ::datadir + 'reports\output\d*.htm' )

		return( fname )
	END

	METHOD NormalizeDate( dte )
		LOCAL m, d, y

		if ( strempty( dte ) )
			return( dte )
		end

		dte = alltrim( chrswap( dte, "/", "-" ) )
		m = right( "0" + strextract( dte, "-", 1 ), 2 )
		d = right( "0" + strextract( dte, "-", 2 ), 2 )
		y = right( "20" + strextract( dte, "-", 3 ), 4 )
		
		return( m + "-" + d + "-" + y )
	END

	METHOD NormalizeNumber( _val )
		local val
		
		val = "" + _val
		val = strswap( val, ",", "" )
		val = strswap( val, " ", "" )
		val = strswap( val, "$", "" )
		
		return( 0.00 + val )
	END

	METHOD CreateDateKey( pd )
		local dte = ::NormalizeDate( pd )
		return( strextract( dte, "-", 3 ) + strextract( dte, "-", 1 ) + strextract( dte, "-", 2 ) )
	END

