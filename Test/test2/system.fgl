CLASS Mortgage
  PUBLIC:
  	local yrs, interest, amount
  	local FNMAmax, FHAmax
  	
  	METHOD new( )
  		::init( )
  		return( 1 )
  	END
  	
  	METHOD init( )
  		::yrs = 0
  		::interest = 0.00
  		::amount = 0
  		
  		::FNMAmax = 384900
  		::FHAmax = 144336
  		return( 1 )
  	END
  	
  	METHOD CalcMoPayment( amount, yrs, interest )
  		local rate, months, a, b, c

		if ( type( amount ) == "N" )
			::amount = 0.00 + amount
		end
		if ( type( yrs ) == "N" )
			::yrs = 0.00 + yrs
		end
		if ( type( interest ) == "N" )
			::interest = 0.00 + interest
		end
		
		months = ::yrs * 12
		rate = ( ::interest / 100 ) / 12

		a = ( ::amount *  ( ( 1 + rate ) ** months ) * rate )
		b = ( ( rate + 1 ) ** months ) - 1
		c = a / b

		return( c )
  	END
  	
	METHOD DisplayPaymentGrid( g, amount, _class, increment )
		local s, r, t

		s = "<table border=1 width=100% cellspacing=0 cellpadding=2 class=" + _class + ">\r\n"
		s += " <tr bgcolor=#F0F0F0><td align=center bgcolor=#E0E0E0>rate/term</td><td align=center>10</td><td align=center>15</td><td align=center>20</td><td align=center>25</td><td align=center>30</td></tr>\r\n"

		for ( r=5; r<=10; r+= increment )

			s += " <tr><td bgcolor=#F0F0F0 align=center>" + g.DollarFormat( r ) + "</td>"
			for ( t=10; t<=30; t+=5 )
				s += "<td align=right>" + g.DollarFormat( ::CalcMoPayment( amount, t, r ) ) + "</td>"
			end
			s += "</tr>\r\n"		
		
		end
		
		s += "</table>\r\n"
		
		return( s )
	END

	METHOD DisplayTotalInterestGrid( g, amount, _class, increment )
		local s, r, t, mo, x

		s = "<table border=1 width=100% cellspacing=0 cellpadding=2 class=" + _class + ">\r\n"
		s += " <tr bgcolor=#F0F0F0><td align=center bgcolor=#E0E0E0>rate/term</td><td align=center>10</td><td align=center>15</td><td align=center>20</td><td align=center>25</td><td align=center>30</td></tr>\r\n"

		for ( r=5; r<=10; r+= increment )

			s += " <tr><td bgcolor=#F0F0F0 align=center>" + g.DollarFormat( r ) + "</td>"
			for ( t=10; t<=30; t+=5 )
				mo = ::CalcMoPayment( amount, t, r )
				x = mo * 12 * t
				s += "<td align=right>" + g.DollarFormat( x - amount, 0, 0 ) + "</td>"
			end
			s += "</tr>\r\n"		
		
		end
		
		s += "</table>\r\n"
		
		return( s )
	END

	METHOD DetermineAvailablePrograms( amount, _class )
		local s
		
		s = "<b>Available Mortgage Programs:<br><table bgcolor=#E0E0E0 border=1 width=100% cellspacing=0 cellpadding=20 class=" + _class + ">\r\n"
		s += " <tr><td>"

		s += "  <ul>\r\n"
		s += "   <li><b><u>Conventional Programs</u>:</b><br>\r\n"
		s += " &nbsp; &nbsp; &nbsp; Federal National Mortgage Association (FNMA) [Fannie Mae] " + ( amount > ::FNMAmax ? "INELIGIBLE" : "" ) + "<br>\r\n"
		s += " &nbsp; &nbsp; &nbsp; Federal Home Loan Mortgage Corporation (FHLMC) [Freddie Mac]<br>\r\n"
		s += " &nbsp; &nbsp; &nbsp; Government National Mortgage Association (GNMA) [Ginnie Mae]<br>\r\n"
		s += "<br>\r\n"		

		s += "   <li><b><u>Government Programs</u>:</b><br>\r\n"
		s += " &nbsp; &nbsp; &nbsp; Federal Housing Association (FHA) " + ( amount > ::FHAmax ? "INELIGIBLE" : "" ) + "<br>\r\n"
		s += " &nbsp; &nbsp; &nbsp; Veterans Administration (VA) Subject to restrictions<br>\r\n"
		s += "<br>\r\n"		
		
		s += "   <li><b><u>Non-Conforming</u>:</b><br>\r\n"
		s += " &nbsp; &nbsp; &nbsp; Private Mortgage - No Down Payment, No Income Verification, No Asset Verification, Poor Credit, Etc...<br>\r\n"
		
		s += "  </ul>\r\n"
		s += "DISCLAIMER: Each mortgage program has individual requirements. Additional information may be required to accurately assess program compatibility. Some programs may not apply.\r\n"
		
		s += " </td></tr>\r\n"
		s += "</table>\r\n"
		
		return( s )	
	END
  	
 END
  	
  		
  		
  		







