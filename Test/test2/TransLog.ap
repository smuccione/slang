<[

FUNCTION showLog( session, type )
		local loop		

		log = session.GetLog( type)

		for ( loop = 0; loop < len ( log ); loop++ )
			! log[loop] + "  " + "<br>"
		end
END


session = new( "session" )

]>
<html>
<head>
<title>CornerOFFICE Transaction Server Log</title>
<meta http-equiv="Content-Type" content="text/html; charset=iso-8859-1">
<style>
  A { COLOR: #FFFFFF; FONT-FAMILY: Arial, helvetica, sans-serif; text-decoration: none; }
