  <tr>
   <td width=300><img src="CornerOfficeLogo.jpg" border=0 width=200 height=57></td>
   <td width=* align=right class=bigtxt nowrap><b><font color="#72C6F2">System Status Window</b></font></td>
  </tr>
 </table><br>
 <input type=button value="<<< Back   " onClick="history.back( );" class=btn>
