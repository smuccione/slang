			1 = "Other"
			2 = "Unknown"
			3 = "Enabled"
			4 = "Disabled"
		End ENUM
		Value = "Disabled"
	End Attribute
	Start Attribute
		Name = "Ring/Event Resume"
		ID = 4
		Description = "Enables system to resume operation when a modem ring occurs on "
			  "a serial port or a wakeup occurs on a PC Card" 
		Access = Read-Only
		Storage = Specific
		Type = Start ENUM
			1 = "Other"
			2 = "Unknown"
			3 = "Enabled"
			4 = "Disabled"
		End ENUM
		Value = "Disabled"
	End Attribute
	Start Attribute
		Name = "Alarm Resume"
		ID = 5
		Description = "Enables system to resume operation from suspend/standby mode "
			  "at a time determined by an application program." 
		Access = Read-Only
		Storage = Specific
		Type = Start ENUM
			1 = "Other"
			2 = "Unknown"
			3 = "Enabled"
			4 = "Disabled"
		End ENUM
		Value = "Disabled"
	End Attribute
End Group
//////////////////////////////////////////////////////////////////////
