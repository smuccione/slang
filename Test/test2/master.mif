			5 = "ACPI 1.0"
		End ENUM
		Value = "Unknown"
	End Attribute
	Start Attribute
		Name = "Reduced CPU Clock Speed "
		ID = 2
		Description = " Defines whether to enable CPU to slow down when possible"
		Access = Read-Only
		Storage = Specific
