			"slots are in effect permanently occupied expansion "
			"sites. This attribute establishes which category of physical "
			"slot this table entry is defining."
		Access = Read-Only
		Storage = Common
		Type = Start ENUM
			1 = "Other"
			2 = "Unknown"
			3 = "Bus Connector"
			4 = "PCMCIA Slot"
			5 = "Motherboard"
		End ENUM
		Value = 1
	End Attribute
	Start Attribute
		Name = "Virtual Slot"
		ID = 7
		Description = "This attribute indicates whether this is a 'virtual slot' or "
			"not. A 'virtual slot' is an expansion site that is "
			"permanently occupied because of the level of integration of an "
			"expandable component. An example of a virtual slot is an I/O "
			"bus position taken up by a LAN controller that is integrated "
			"onto a motherboard. A slot with the 'Slot Category' of "
			"Motherboard is typically a Virtual Slot."
		Access = Read-Only
		Storage = Common
		Type = Start ENUM
			0 = "False"
			1 = "True"
			2 = "Unknown"
		End ENUM
		Value = 1
	End Attribute
	Start Attribute
		Name = "Resource User ID"
		ID = 8
		Description = "Value used to locate the rows in the System Resources 2 table "
			"for the resources associated with this slot or expansion "
			"site. 0 = 'unspecified'." 
		Access = Read-Only
		Storage = Common
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Vcc Mixed Voltage Support"
		ID = 9
		Description = "Device Vcc Mixed Voltage support. "
			"This is a bit field with the following definitions: \n "
			"Bit 0 (2^0), if set, indicates 3.3V support \n "
			"Bit 1 (2^1), if set, indicates 5V support "
		Access = Read-Only
		Storage = Specific
		Type = Integer64
		Value = 0
	End Attribute
	Start Attribute
		Name = "Vpp Mixed Voltage Support"
		ID = 10
		Description = "Device Vpp Mixed Voltage support. "
			"This is a bit field with the following definitions: \n "
			"Bit 0 (2^0), if set, indicates 3.3V support \n " 
			"Bit 1 (2^1), if set, indicates 5V support \n " 
			"Bit 2 (2^2), if set, indicates 12V support"
		Access = Read-Only
		Storage = Specific
		Type = Integer64
		Value = 0
	End Attribute
	Start Attribute
		Name = "Slot Thermal Rating"
		ID = 11
		Description = "The maximum thermal dissipation of the slot in milliwatts."
		Access = Read-Only
		Storage = Specific
		Type = Integer
		Value = 0
	End Attribute
End Group
//////////////////////////////////////////////////////////////////////
// "DMTF|System Slot|005"
//
// Supercedes:	   DMTF|System Slot|004
// Superceded By: ..---
//
//////////////////////////////////////////////////////////////////////

Start Group
	Name = "System Slot"
	Class = "DMTF|System Slot|005"
	ID = 235
	Description = "This group defines the attributes for the different system expansion "
	  "slots supported in this system."
	Key = 1
	Pragma = "SNMP:1.3.6.1.4.1.412.2.4.18 ;"

	Start Attribute
		Name = "Slot Index"
		ID = 1
		Description = "An index into the system slot table. This is the hardware ID "
			"number for each expansion slot, whether it is occupied or not "
			"(starting with 1)." 
		Access = Read-Only
		Storage = Common
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Slot Type"
		ID = 2
		Description = "The bus type supported in this slot. "
			"This is a bit field with the following definitions: \n "
			"Bit 0 (2^0), if 1, it is a long-length card; \n "
			"  if 0, it is a short-length card, \n " 
			"Bit 1 (2^1) if set, indicates ISA, \n " 
			"Bit 2 (2^2) indicates EISA, \n " 
			"Bit 3 (2^3) indicates MCA, \n " 
			"Bit 4 (2^4) indicates PCI, \n " 
			"Bit 5 (2^5) indicates VL, \n " 
			"Bit 6 (2^6) indicates PCMCIA, \n " 
			"Bit 7 (2^7) refers to NuBus, \n " 
			"Bit 8 (2^8) indicates PC-98/C20, \n " 
			"Bit 9 (2^9) indicates PC-98/C24, \n " 
			"Bit 10 (2^10) indicates PC-98/E, \n " 
			"Bit 11 (2^11) indicates PC-98/Local Bus \n " 
			"Bit 12 (2^12) indicates PC-98/Card slot. \n " 
			"Bit 13 (2^13), if set, indicates PC Card-16 support \n " 
			"Bit 14 (2^14), if set, indicates CardBus support \n " 
			"Bit 15 (2^15), if set, indicates ZV Port support \n " 
			"Bit 16 (2^16), if set, indicates PC Card Modem Ring Resume support \n" 
			"Bit 17 (2^17), if set, indicates AGP slot \n" 
			"Bit 18 (2^18), if set, indicates a PCI 66MHz capable slot \n" 
			"Bit 19 (2^19), if set, indicates a Hot-plug capable slot \n" 
		Access = Read-Only
		Storage = Common
		Type = Integer64
		Value = 0
	End Attribute
	Start Attribute
		Name = "Slot Width"
		ID = 3
		Description = "The maximum bus width of cards accepted in this slot."
		Access = Read-Only
		Storage = Common
		Type = Start ENUM
			1 = "Other"
			2 = "Unknown"
			3 = "8 bit card"
			4 = "16 bit card"
			5 = "32 bit card"
			6 = "64 bit card"
			7 = "128 bit card"
		End ENUM
		Value = 1
	End Attribute
	Start Attribute
		Name = "Current Usage"
		ID = 4
		Description = "Is this slot is currently in use?"
		Access = Read-Only
		Storage = Common
		Type = Start ENUM
			1 = "Other"
			2 = "Unknown"
			3 = "Available"
			4 = "In Use"
		End ENUM
		Value = 1
	End Attribute
	Start Attribute
		Name = "Slot Description"
		ID = 5
		Description = "The card currently occupying this slot."
		Access = Read-Only
		Storage = Specific
		Type = DisplayString(80)
		Value = ""
	End Attribute
	Start Attribute
		Name = "Slot Category"
		ID = 6
		Description = "The word 'slot' is used to refer to bus slots. The last case "
			"(motherboard) refers to situations where a functional element "
			"is integrated onto, say, a motherboard and connects to a bus "
			"without a connector. It still takes up an expansion site on "
			"the bus but this is termed a 'virtual slot' as opposed to a "
			"physical slot (see the attribute 'Virtual Slot'). Virtual "
			"slots are in effect permanently occupied expansion "
			"sites. This attribute establishes which category of physical "
			"slot this table entry is defining."
		Access = Read-Only
		Storage = Common
		Type = Start ENUM
			1 = "Other"
			2 = "Unknown"
			3 = "Bus Connector"
			4 = "PCMCIA Slot"
			5 = "Motherboard"
		End ENUM
		Value = 1
	End Attribute
	Start Attribute
		Name = "Virtual Slot"
		ID = 7
		Description = "This attribute indicates whether this is a 'virtual slot' or "
			"not. A 'virtual slot' is an expansion site that is "
			"permanently occupied because of the level of integration of an "
			"expandable component. An example of a virtual slot is an I/O "
			"bus position taken up by a LAN controller that is integrated "
			"onto a motherboard. A slot with the 'Slot Category' of "
			"Motherboard is typically a Virtual Slot."
		Access = Read-Only
		Storage = Common
		Type = Start ENUM
			0 = "False"
			1 = "True"
			2 = "Unknown"
		End ENUM
		Value = 1
	End Attribute
	Start Attribute
		Name = "Resource User ID"
		ID = 8
		Description = "Value used to locate the rows in the System Resources 2 table "
			"for the resources associated with this slot or expansion "
			"site. 0 = 'unspecified'." 
		Access = Read-Only
		Storage = Common
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Vcc Mixed Voltage Support"
		ID = 9
		Description = "Device Vcc Mixed Voltage support. "
			"This is a bit field with the following definitions: \n "
			"Bit 0 (2^0), if set, indicates 3.3V support \n "
			"Bit 1 (2^1), if set, indicates 5V support "
		Access = Read-Only
		Storage = Specific
		Type = Integer64
		Value = 0
	End Attribute
	Start Attribute
		Name = "Vpp Mixed Voltage Support"
		ID = 10
		Description = "Device Vpp Mixed Voltage support. "
			"This is a bit field with the following definitions: \n "
			"Bit 0 (2^0), if set, indicates 3.3V support \n " 
			"Bit 1 (2^1), if set, indicates 5V support \n " 
			"Bit 2 (2^2), if set, indicates 12V support"
		Access = Read-Only
		Storage = Specific
		Type = Integer64
		Value = 0
	End Attribute
	Start Attribute
		Name = "Slot Thermal Rating"
		ID = 11
		Description = "The maximum thermal dissipation of the slot in milliwatts."
		Access = Read-Only
		Storage = Specific
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Operational Group Index"
		ID = 12
		Description = "The index into the Operational State table for this device."
		Access = Read-Only
		Storage = Common
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Slot Power State"
		ID = 13
		Description = "The current power state of the slot."
		Access = Read-Only
		Storage = Common
		Type = Start ENUM
			0x01 = "Unknown"
			0x02= "Off"
			0x03= "On"
		End ENUM
		Value = 1
	End Attribute
	Start Attribute
		Name = "Slot Fault State"
		ID = 14
		Description = "The current fault state of the slot."
		Access = Read-Only
		Storage = Common
		Type = Start ENUM
			0x01 = "Unknown"
			0x02 = "OK"
			0x03 = "Failed"
		End ENUM
		Value = 1
	End Attribute
	Start Attribute
		Name = "Slot Switch State"
		ID = 15
		Description = "State of the switch than enables hot-plug."
		Access = Read-Only
		Storage = Common
		Type = Start ENUM
			0x01 = "Unknown"
			0x02 = "Closed"
			0x03 = "Opened"
		End ENUM
		Value = 1
	End Attribute
End Group
