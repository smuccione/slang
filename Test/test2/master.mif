		Name = "Sub-Identifier"
		ID = 4
		Description = "The sub-identifier for this storage device (e.g., the "
			  "device's SCSI logical unit number)."
		Access = Read-Only
		Storage = Specific
		Type = String(256)
		Value = ""
	End Attribute
	Start Attribute
		Name = "Media Data Block Size"
		ID = 5
		Description = "The size in bytes of the data blocks used on the storage "
		  "media.  If the media block size is unknown or not consistent "
		  "across the media, then this value shall be zero. "
		Access = Read-Only
		Storage = Specific
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Formatted Media Capacity"
		ID = 6
		Description = "The total size in bytes of this storage media after it has "
		  "been formatted. "
		Access = Read-Only
		Storage = Specific
		Type = Integer64
		Value = 0
	End Attribute
	Start Attribute
		Name = "Removable Device"
		ID = 7
		Description = "If true, then this storage device is removable (e.g.: PCMCIA "
		  "device)."
		Access = Read-Only
		Storage = Common
		Type = Start Enum
			0x00 = "False"
			0x01 = "True"
			0x02 = "Unknown"
		End Enum
		Value = 0x02
	End Attribute
	Start Attribute
		Name = "Device Loaded"
		ID = 8
		Description = "If true, then the storage device is loaded.  If the device is "
		  "not removable, then this value shall be 'TRUE'. "
		Access = Read-Only
		Storage = Common
		Type = Start Enum
			0x00 = "False"
			0x01 = "True"
			0x02 = "Unknown"
		End Enum
		Value = 0x02
	End Attribute
	Start Attribute
		Name = "Removable Media"
		ID = 9
		Description = "If true, then the media in this storage device is removable. "
		Access = Read-Only
		Storage = Common
		Type = Start Enum
			0x00 = "False"
			0x01 = "True"
			0x02 = "Unknown"
		End Enum
		Value = 0x02
	End Attribute
	Start Attribute
		Name = "Media Loaded"
		ID =10
		Description = "If true, the media in this storage device is loaded.  If the "
			  "media is not removable, then this value shall be 'TRUE' "
		Access = Read-Only
		Storage = Common
		Type = Start Enum
			0x00 = "False"
			0x01 = "True"
			0x02 = "Unknown"
		End Enum
		Value = 0x02
	End Attribute
	Start Attribute
		Name = "Compression"
		ID = 11
		Description = "If true, the storage device supports compression."
		Access = Read-Only
		Storage = Common
		Type = Start Enum
			0x00 = "False"
			0x01 = "True"
			0x02 = "Unknown"
		End Enum
