// 
//////////////////////////////////////////////////////////////////////

Start Group
	Name = "Out-of-Band Remote Access"
	Class = "DMTF|Out-of-Band Remote Access|001"
	ID = 128
	Description = "This defines the attributes and policy settings of a special "
	  "hardware facility called Out-of-Band Remote Access, which may be used "
	  "to gain remote accessto a hardware system when the operating system "
	  "is not available due to power down status, hardware failures, or boot "
	  "failures."
	Pragma = "SNMP:1.3.6.1.4.1.412.2.4.60 ;"

	Start Attribute
		Name = "Out-of-Band Function Manufacturer Name"
		ID = 1
		Description = "This string attribute provides the name of the manufacturer "
			  "of the out-of-band access facility in the system. This may be "
			  "the name of the system manufacturer or the name of the add-in "
			  "that carries the out-of-band function." 
		Access = Read-Only
		Storage = Specific
		Type = DisplayString(64)
		Value = ""
	End Attribute
	Start Attribute
		Name = "Out-of-Band Function Description String"
		ID = 2
		Description = "This is a user-settable string that contains a description of "
			  "the out-of-band remote access facility in the system." 
		Access = Read-Only
		Storage = Specific
		Type = DisplayString(64)
		Value = ""
	End Attribute
	Start Attribute
		Name = "Outbound Out-of-Band Connection Enabled"
		ID = 3
		Description = "Defines whether the Out-of-Band Remote Access facility is "
			  "allowed to initiate outbound connections to contact an alert "
			  "management facility when critical conditions occur." 
		Access = Read-Write
		Storage = Common
		Type = Start ENUM
			0 = "False"
			1 = "True"
			2 = "Unknown"
		End ENUM
		Value = 1
	End Attribute
	Start Attribute
		Name = "Inbound Out-of-Band Connection Enabled"
		ID = 4
		Description = "Defines whether the Out-of-Band Remote Access facility is "
			  "allowed to receive incoming connections for the purpose of "
			  "remote operations or problem management." 
		Access = Read-Write
		Storage = Common
		Type = Start ENUM
			0 = "False"
			1 = "True"
			2 = "Unknown"
		End ENUM
		Value = 1
	End Attribute
End Group
