Start Group
	Name = "Process Information"
	ID = 161
	Class = "DMTF|Process Information|001"
	Description = "This group contains a row for each of the currently running processes on a system."
	Key = 1
	Pragma = "SNMP:1.3.6.1.4.1.412.2.11.7 ;"

	Start Attribute
		Name = "Process ID"
		ID = 1 
		Description = "The process ID of a currently executing process and the index to the Process Table."
		Access = read-only
		Storage = Specific
		Type = String(6)
		Value = ""
	End Attribute
	Start Attribute
		Name = "Parent Process ID"
		ID = 2
		Description = "The parent process ID of this executing process."
		Access = read-only
		Storage = Specific
		Type = String(6)
		Value = ""
	End Attribute
	Start Attribute
		Name = "Process Group ID"
		ID = 3
		Description = "The Group ID of this currently executing process."
		Access = read-only
		Storage = Specific
		Type = String(6)
		Value = ""
	End Attribute
	Start Attribute
		Name = "Real User ID"
		ID = 4
		Description = "The Real User ID of this currently executing process."
		Access = read-only
		Storage = Specific
		Type = Integer64
		Value = 0
	End Attribute
	Start Attribute
		Name = "Process TTY"
		ID = 5
		Description = "The TTY currently associated with this process."
		Access = read-only
		Storage = Specific
		Type = DisplayString(32)
		Value = ""
	End Attribute
	Start Attribute
		Name = "Process Name"
		ID = 6
		Description = "This is the process name. It is the executed command without the pathname."
		Access = read-only
		Storage = Specific
		Type = DisplayString(256)
		Value = ""
	End Attribute
	Start Attribute
		Name = "Module Path"
		ID = 7
		Description = "The executing process' command path.  This is the path up "
		  "to and not including the command name"
		Access = Read-only
		Storage = Specific
		Type = DisplayString(2048)
		Value = ""
	End Attribute
	Start Attribute
		Name = "Parameters"
		ID = 8
		Description = "The operating system parameters provided to the executing process."
		  " Typically a user specifies these and are programmatically accessed as "
		  "argument[1]...argument[n]."
		Access = read-only
		Storage = Specific
		Type = DisplayString(1024)
		Value = ""
	End Attribute
	Start Attribute
		Name = "Process State"
		ID = 9
		Description = "The process state."
		Access = read-only
		Storage = Specific
		Type = Start Enum
			0x00 = "Nonexistent"
			0x01 = "Sleeping"
			0x02 = "Waiting"
			0x03 = "Running"
			0x04 = "Intermediate"
			0x05 = "Terminated"
			0x06 = "Stopped"
			0x07 = "Growing"
		End Enum
		Value = "Nonexistent" 
	End Attribute
	Start Attribute
		Name = "Process Priority"
		ID = 10
		Description = "The process' schedule priority."
		Access = Read-only
		Storage = Specific
		Type = Integer64
		Value = 0
	End Attribute
	Start Attribute
		Name = "Process Nice Value"
		ID = 11
		Description = "The process's nice value.  Used to compute its priority."
		Access = Read-only
		Storage = Specific
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Process CPU Time"
		ID = 12
		Description = "The percentage of a CPU's time this process is consuming."
		Access = read-only
		Storage = Specific
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Process System Time"
		ID = 13
		Description = "The number of seconds that this process has spent executing operating system code."
		Access = read-only
		Storage = Specific
		Type = Integer64
		Value = 0
	End Attribute
	Start Attribute
		Name = "Process User Time"
		ID = 14
		Description = "The number of seconds that this process has spent executing user code."
		Access = read-only
		Storage = Specific
		Type = Integer64
		Value = 0
	End Attribute
	Start Attribute
		Name = "Process Real Text"
		ID = 15
		Description = "The number of Kbytes of real text space used by the process."
		Access = read-only
		Storage = Specific
		Type = Integer64
		Value = 0
	End Attribute
	Start Attribute
		Name = "Process Real Data"
		ID = 16
		Description = "The number of Kbytes real data space used by the process."
		Access = read-only
		Storage = Specific
		Type = Integer64
		Value = 0
	End Attribute
	Start Attribute
		Name = "Process Real Stack"
		ID = 17
		Description = "The number of Kbytes real stack space used by the process."
		Access = read-only
		Storage = Specific
		Type = Integer64
		Value = 0
	End Attribute
	Start Attribute
		Name = "Process Virtual Text"
		ID = 18
		Description = "The number of Kbytes of virtual text space used by the process."
		Access = Read-only
		Storage = Specific
		Type = Integer64
		Value = 0
	End Attribute
	Start Attribute
		Name = "Process Virtual Data"
		ID = 19
		Description = "The number of Kbytes of virtual data space used by the process."
		Access = Read-only
		Storage = Specific
		Type = Integer64
		Value = 0
	End Attribute
	Start Attribute
		Name = "Process Virtual Stack"
		ID = 20
		Description = "The number of Kbytes of virtual stack space used by the process."
		Access = Read-only
		Storage = Specific
		Type = Integer64
		Value = 0
	End Attribute
	Start Attribute
		Name = "Process Virtual Shared Memory"
		ID = 21
		Description = "The number of Kbytes of virtual shared memory used by the process."
		Access = read-only
		Storage = Specific
		Type = Integer64
		Value = 0
	End Attribute
	Start Attribute
		Name = "Process Virtual Memory Mapped File Size"
		ID = 22
		Description = "The number of Kbytes of virtual space used for memory mapped files by the process."
		Access = read-only
		Storage = Specific
		Type = Integer64
		Value = 0
	End Attribute
