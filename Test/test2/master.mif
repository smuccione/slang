//////////////////////////////////////////////////////////////////////
// "DMTF|Mass Storage Association|001"
// 
// Supercedes:	---
// Superceded By: DMTF|Mass Storage Association|002
// Dependent Groups:   None
// 
//////////////////////////////////////////////////////////////////////
// Each mass storage association has a type field which describes the form
// of the relationship. Mass storage associations which are of type
// "physical organization" are those which connect components which form
// the physical data path to the target physical storage device. Those of
// type "Logical Organization" form the address space which is used to
// control the destination of the data. Each mass storage association
// contains a pair of objects.  Each object contains an identifier for
// the table which holds the component and the index into the table.
Start Group

	Name = "Mass Storage Association"
	ID = 89
	Class = "DMTF|Mass Storage Association|001"
	Description = "Mass storage associations define the relationships between the "
	  "various components of the Storage Subsystem." 
	Key = 1
	Pragma = "SNMP:1.3.6.1.4.1.412.2.10.12 ;"
	
	Start Attribute
		Name = "Association Index"
		ID = 1
		Description = "An index into the Association table."
		Access = Read-Only
		Storage = Common
		Type = Integer
		Value = -1
	End Attribute
	Start Attribute
		Name = "Type"
		ID = 2
		Description = "This field specifies the type of the association.  One of the "
		  "following strings shall be used to represent a known Mass "
		  "Storage Association type: 'Physical Organization', 'Logical "
		  "Organization', 'Logical to Physical Organization', "
		  "'Redundancy Organization', 'Spare Organization', 'Cache', "
		  "'FRU', 'Operational State', 'Statistical', 'SubComponent "
		  "Software', or 'Worldwide Identifier'." 
		Access = Read-Only
		Storage = Common
		Type = DisplayString
		Value = ""
	End Attribute
	Start Attribute
		Name = "Reference 1"
		ID = 3
		Description = "A reference to an object.  The Mass Storage references shall "
		  "use the format of 'x-dmi//<locator>/dmi/row; cid=<>; gid=<>; "
		  "key=<>'." 
		Access = Read-Only
		Storage = Common
		Type = DisplayString
		Value = ""
	End Attribute
	Start Attribute
		Name = "Reference 2"
		ID = 4
		Description = "A reference to an object.  The Mass Storage references shall "
		  "use the format of 'x-dmi//<locator>/dmi/row; cid=<>; gid=<>; "
		  "key=<>'." 
		Access = Read-Only
		Storage = Common
		Type = DisplayString
		Value = ""
	End Attribute
End Group
