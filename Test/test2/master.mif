	Start Attribute
		Name = "Bus Port Association Index"
		ID = 1
		Description = "An index into the Bus Port Association table.  This index is "
		  "the same as the index in the Association group that defines "
		  "the bus port association." 
		Access = Read-Only
		Storage = Common
		Type = Integer
		Value = -1
	End Attribute
	
	Start Attribute
		Name = "Negotiated Speed"
		ID =2
		Description = "The maximum burst transfer rate, in millions of bytes, which "
		  "was negotiated between the two associated bus ports." 
		Access = Read-Only
		Storage = Specific
		Type = Integer
		Value = 0
	End Attribute
	
	Start Attribute
		Name = "Negotiated Width"
		ID = 3
		Description = "The width, in bits, of the bus ports data path which was "
		  "negotiated between the two associated bus ports."
		Access = Read-Only
		Storage = Specific
		Type = Integer
		Value = 0
	End Attribute
	
End Group
//////////////////////////////////////////////////////////////////////
// "DMTF|Cache Performance Table|001"
// 
// Supercedes:	---
// Superceded By:  DMTF|Cache Performance Table|002
// 
//////////////////////////////////////////////////////////////////////
Start Group
	Name = "Cache Performance table"
	Class = "DMTF|Cache Performance Table|001"
	ID = 31
	Description = "This is a table of entries for cache performance for all components "
	  "in the system that implement a cache."
	Key = 1
Pragma = "SNMP:1.3.6.1.4.1.412.2.4.61 ;"

	Start Attribute
		Name = "Cache index"
		ID = 1
		Description = "Index into the System Cache table"
		Access = Read-Only
		Storage = Common
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Millisecond counter"
		ID = 2
		Description = "32 bit counter that gets incremented every millisecond"
		Access = Read-Only
		Storage = Common
		Type = Counter
		Value = 0
	End Attribute
	Start Attribute
		Name = "Cache Access Count"
		ID = 3
		Description = "64 bit counter that counts the number of times the cache has "
		  "been accessed. A value of 0x8000000000000000 denotes "
		  "'unknown'."
		Access = Read-Only
		Storage = Common
		Type = Counter64
		Value = 0
	End Attribute
	Start Attribute
		Name = "Cache Hit Count"
		ID = 4
		Description = "64 bit counter that counts the number of times there was a "
			  "cache hit. i.e. memory being accessed was in the Cache. A "
			  "value of 0x8000000000000000 denotes 'unknown'."
		Access = Read-Only
		Storage = Common
		Type = Counter64
		Value = 0
	End Attribute
End Group
//////////////////////////////////////////////////////////////////////
// "DMTF|Cache Performance Table|002"
// 
// Supercedes:	   DMTF|Cache Performance Table|001
// Superceded By:---
// 
//////////////////////////////////////////////////////////////////////
Start Group
	Name = "Cache Performance table"
	Class = "DMTF|Cache Performance Table|002"
	ID = 32
	Description = "This is a table of entries for cache performance for all components "
	  "in the system that implement a cache."
	Key = 1
	Pragma = "SNMP:1.3.6.1.4.1.412.2.4.61 ;"

	Start Attribute
		Name = "Cache index"
		ID = 1
