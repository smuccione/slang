	ID = 142
	Description = "This global table describes all of the expansion sites in this "
	  "expandable component in the system.  The unique index of each expansion "
	  "site is the key into this table. Card/Bus slots, disk bays, hot-plug "
	  "power supply bays, etc., are all examples of expansion sites." 
	Key = 1
	Pragma = "SNMP:1.3.6.1.4.1.412.2.4.65 ;"

	Start Attribute
		Name = "Expansion Site Index"
		ID = 1
		Description = "The unique integer index into Physical Expansion Sites table."
		Access = Read-Only
		Storage = Common
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Expansion Site Type"
		ID = 2
		Description = "This attribute describes the type of expansion site that is "
			  "being defined by this entry in the Physical Expansion "
			  "Sites Table."
		Access = Read-Only
		Storage = Common
		Type = Start ENUM
			1 = "Other"
			2 = "Unknown"
			3 = "Bus Slot"
			4 = "Drive Bay"
			5 = "Power Unit Bay"
			6 = "Subchassis Slot"
			7 = "PCMCIA Slot"
			8 = "Device Bay"
		End ENUM
		Value = 1
	End Attribute
	Start Attribute
		Name = "Virtual Expansion Site"
		ID = 3
		Description = "This attribute indicates whether this is a 'virtual' "
			  "expansion site or not. A virtual expansion site is one that "
			  "is permanently occupied because of the level of integration "
			  "of an expandable component. An example of a virtual expansion "
			  "site is an I/O bus load taken up by a LAN controller that is "
			  "integrated onto a motherboard." 
		Access = Read-Only
		Storage = Common
		Type = Start ENUM
			0 = "False"
			1 = "True"
		End ENUM
		Value = 1
	End Attribute
	Start Attribute
		Name = "Expansion Site Name"
		ID = 4
		Description = "Name chosen by the vendor of this component to name this "
			  "particular expansion site within this component, e.g. 'Slot "
			  "6', 'DriveBay 1'." 
		Access = Read-Only
		Storage = Common
		Type = DisplayString(64)
		Value = ""
	End Attribute
	Start Attribute
		Name = "Expansion Site Description"
		ID = 5
		Description = "This is a vendor-settable string that describes the expandable "
			  "site in whatever way is desired." 
		Access = Read-Only
		Storage = Specific
		Type = DisplayString(64)
		Value = ""
	End Attribute
	Start Attribute
		Name = "Expansion Site Currently Occupied"
		ID = 6
		Description = "A boolean whose value indicates whether this Expansion Site is "
			  "currently occupied or not." 
		Access = Read-Only
		Storage = Common
		Type = Start ENUM
			0 = "False"
			1 = "True"
		End ENUM
		Value = 1
	End Attribute
	Start Attribute
		Name = "Expansion Site Insertion Properties"
		ID = 7
		Description = "This attribute indicates the insertion properties of this "
			  "expansion site (Hot, Warm, Cold) which describes if the site "
			  "must be powered OFF before a connection may be made.  An "
			  "example of a hot insertion expansion site would be a hot-plug "
			  "power supply bay while a bus slot like PCI is a cold "
			  "insertion expansion site.  Warm insertion allows power to be "
			  "ON but no activity present." 
		Access = Read-Only
		Storage = Common
		Type = Start ENUM
			1 = "Other"
			2 = "Unknown"
			3 = "Hot"
			4 = "Warm"
			5 = "Cold"
		End ENUM
		Value = "Unknown"
	End Attribute
	Start Attribute
		Name = "Expansion Site Properties Table Reference"
		ID = 8
		Description = "Reference to Expansion Site Properties Table"
		Access = Read-Only
		Storage = Specific
		Type = DisplayString(64)
		Value = ""
	End Attribute
End Group
//////////////////////////////////////////////////////////////////////
// "DMTF|Physical Extent|001"
// 
// Supercedes:	---
// Superceded By:---
// Dependent Groups:   Volume Set
//             Redundancy Group
// 
//////////////////////////////////////////////////////////////////////
Start Group
	Name = " Physical Extent"
	ID = 143
	Class = "DMTF|Physical Extent|001"
	Description = "A p_extent defines the consecutive addressable logical block "
	  "addresses on a single storage device.  In addition, the group "
	  "contains the redundancy group mapping information." 
	Key = 1
	Pragma = "SNMP:1.3.6.1.4.1.412.2.10.6 ;"
	
	Start Attribute
		Name = "Physical Extent Index"
		ID = 1
		Description = "An index into the Physical Extent table."
		Access = Read-Only
		Storage = Common
		Type = Integer
		Value = -1
	End Attribute
	Start Attribute
		Name = "Start Address"
		ID = 2
		Description = "The starting LBA on a storage device from which this p_extent "
		  "is derived."
		Access = Read-Only
		Storage = Specific
		Type = Integer64
		Value = 0
	End Attribute
	Start Attribute
		Name = "Number of Blocks"
		ID = 3
		Description = "The total number of consecutive blocks contained in this "
		  "p_extent."
		Access = Read-Only
		Storage = Specific
		Type = Integer64
		Value = 0
	End Attribute
	Start Attribute
		Name = "Block Size"
		ID = 4
		Description = "The size in bytes of the blocks which form this p_extent. A "
		  "value of zero shall represent a variable block size."
		Access = Read-Only
		Storage = Specific
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Granularity Unit"
		ID = 5
		Description = "This field specifies the units in which the following check "
		  "data and user data fields are given."
		Access = Read-Only
		Storage = Common
		Type = Start Enum
			0x01 = "Other"
			0x02 = "Unknown"
			0x03 = "Bits"
			0x04 = "Bytes"
			0x05 = "16 bit words"
			0x06 = "32 bit double words"
			0x07 = "blocks"
		End Enum
		Value = 0x02
	End Attribute
	Start Attribute
		Name = "Start Check Data Interleave"
		ID = 6
