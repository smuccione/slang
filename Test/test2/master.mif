//////////////////////////////////////////////////////////////////////
// "DMTF|Physical Expansion Site Table|001"
// 
// Supercedes:	---
// Superceded By:  DMTF|Physical Expansion Site Table|002
// 
//////////////////////////////////////////////////////////////////////

Start Group
	Name = "Physical Expansion Sites Table"
	Class = "DMTF|Physical Expansion Site Table|001"
	ID = 141
	Description = "This global table describes all of the expansion sites in this "
	  "expandable component in the system. The unique index of each "
	  "expansion site is the key into this table. Card/Bus slots, disk bays, "
	  "hot-plug power supply bays, etc., are all examples of expansion "
	  "sites."
	Key = 1
	Pragma = "SNMP:1.3.6.1.4.1.412.2.4.65 ;"

	Start Attribute
		Name = "Expansion Site Index"
		ID = 1
		Description = "The unique integer index into Physical Expansion Sites "
			  "table." 
		Access = Read-Only
		Storage = Common
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Expansion Site Type"
		ID = 2
		Description = "This attribute describes the type of expansion site that is "
			  "being defined by this entry in the Physical Expansion "
			  "Sites Table." 
		Access = Read-Only
		Storage = Common
		Type = Start ENUM
			1 = "Other"
			2 = "Unknown"
			3 = "Bus Slot"
			4 = "Drive Bay"
			5 = "Power Unit Bay"
			6 = "Subchassis Slot"
			7 = "PCMCIA Slot"
		End ENUM
		Value = 1
	End Attribute
	Start Attribute
		Name = "Virtual Expansion Site"
		ID = 3
		Description = "This attribute indicates whether this is a 'virtual' "
			  "expansion site or not.  A virtual expansion site is one that "
			  "is permanently occupied because of the level of integration "
			  "of an expandable component.  An example of a virtual "
			  "expansion site is an I/O bus load taken up by a LAN "
			  "controller that is integrated onto a motherboard." 
		Access = Read-Only
		Storage = Common
		Type = Start ENUM
			0 = "False"
			1 = "True"
		End ENUM
		Value = 1
	End Attribute
	Start Attribute
		Name = "Expansion Site Name"
		ID = 4
		Description = "Name chosen by the vendor of this component toname this "
			  "particular expansion site within this component, e.g. 'Slot "
			  "6', 'DriveBay 1'." 
		Access = Read-Only
		Storage = Common
		Type = DisplayString(64)
		Value = ""
	End Attribute
	Start Attribute
		Name = "Expansion Site Description"
		ID = 5
		Description = "This is a vendor-settable string that describes the expandable "
			  "site in whatever way is desired." 
		Access = Read-Only
		Storage = Specific
		Type = DisplayString(64)
		Value = ""
	End Attribute
	Start Attribute
		Name = "Expansion Site Currently Occupied"
		ID = 6
		Description = "A boolean whose value indicates whether this Expansion Site "
			  "is currently occupied or not." 
		Access = Read-Only
		Storage = Common
		Type = Start ENUM
			0 = "False"
			1 = "True"
		End ENUM
		Value = 1
	End Attribute
End Group
