			1 = "Other"
			2 = "Unknown"
			3 = "Enabled"
			4 = "Disabled"
		End ENUM
		Value = "Disabled"
	End Attribute
	Start Attribute
		Name = "Override AC"
		ID = 3
		Description = "Enables/Disables power savings when AC is connected"
