// Superceded By:---
// 
//////////////////////////////////////////////////////////////////////
Start Group
	Name = "System Reset"
	Class = "DMTF|System Reset|001"
	ID = 219
	Description = "This group defines whether Automatic System Reset functions "
	  "are available (Capability) and enabled (Status). If the system has a "
	  "watchdog Timer and the timer is not reset (Timer Reset) before the "
	  "Interval elapses, an automatic system reset will occur. The system "
	  "will re-boot according to the Boot Option. This function may repeat "
	  "until the Limit is reached, at which time the system will re-boot "
	  "according to the Boot Option at Limit."
	Pragma = "SNMP:1.3.6.1.4.1.412.2.4.48 ;"

	Start Attribute
		Name = "Automatic System Reset Capability"
		ID = 1
		Description = "Indicates whether Automatic System Reset Capability is "
			  "available for the current operating system." 
		Access = Read-Only
		Storage = Common
		Type = Start ENUM
			1 = "Other"
			2 = "Unknown"
			3 = "Available"
			4 = "Not Available"
		End ENUM
		Value = 1
	End Attribute
	Start Attribute
		Name = "Automatic System Reset Status"
		ID = 2
		Description = "Indicates whether Automatic System Reset is enabled by the "
			  "user." 
		Access = Read-Write
		Storage = Common
		Type = Start ENUM
			1 = "Other"
			2 = "Unknown"
			3 = "Enabled"
			4 = "Disabled"
		End ENUM
		Value = 1
	End Attribute
	Start Attribute
		Name = "Automatic System Reset Boot Option"
		ID = 3
		Description = "Indicates whether Automatic System Reset will boot to the "
			  "operating system, boot to utilities, or not re-boot. This is "
			  "the action to be taken following a reset." 
		Access = Read-Write
		Storage = Common
		Type = Start ENUM
			1 = "Other"
			2 = "Unknown"
			3 = "Operating System"
			4 = "Utilities"
			5 = "Do not re-boot"
		End ENUM
		Value = 1
	End Attribute
	Start Attribute
		Name = "Automatic System Reset Count"
		ID = 4
		Description = "The number of Automatic System Resets since last intentional "
			  "reset. A value of 0x80000000 denotes 'unknown'." 
		Access = Read-Write
		Storage = Common
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Automatic System Reset Limit"
		ID = 5
		Description = "The number of consecutive times the Automatic System Reset "
			  "will be attempted. A value of 0x80000000 denotes 'unknown'." 
		Access = Read-Write
		Storage = Common
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Automatic System Reset Boot Option at Limit"
		ID = 6
		Description = "Indicates the action to be taken when the Automatic System "
			  "Reset Limit is reached." 
		Access = Read-Write
		Storage = Common
		Type = Start ENUM
			1 = "Other"
			2 = "Unknown"
			3 = "Operating System"
			4 = "Utilities"
			5 = "Do not re-boot"
		End ENUM
		Value = 1
	End Attribute
	Start Attribute
		Name = "Automatic System Reset Timer"
		ID = 7
		Description = "Indicates whether this system has a watchdog timer."
		Access = Read-Write
		Storage = Common
		Type = Start ENUM
			0 = "False"
			1 = "True"
			2 = "Unknown"
		End ENUM
		Value = 1
	End Attribute
	Start Attribute
		Name = "Automatic System Reset Timer Interval"
		ID = 8
		Description = "The number of minutes to use for watchdog timer. If the timer "
			  "is not reset within this interval, the automatic system reset "
			  "timeout will begin. A value of 0x80000000 denotes 'unknown'." 
		Access = Read-Write
		Storage = Common
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Automatic System Reset Timer Reset"
		ID = 9
		Description = "Initiate the reset of the automatic system reset watchdog "
			  "timer. Setting this attribute to True will cause the watchdog "
			  "timer to reset." 
		Access = Read-Write
		Storage = Common
		Type = Start ENUM
			0 = "False"
			1 = "True"
			2 = "Unknown"
		End ENUM
		Value = 1
	End Attribute
	Start Attribute
		Name = "System Reset Timeout"
		ID = 10
		Description = "This attribute identifies the number of minutes before the "
			  "re-boot is initiated. It is used after system power cycle, "
			  "system reset (local or remote), and automatic system reset. A "
			  "value of 0x80000000 denotes 'unknown'." 
		Access = Read-Write
		Storage = Common
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "System Reset Boot Option"
		ID = 11
		Description = "Indicates whether to boot to the operating system or the "
			  "utilities when a system reset or system power cycle is "
			  "performed, either locally or remotely." 
		Access = Read-Write
		Storage = Common
		Type = Start ENUM
			1 = "Other"
			2 = "Unknown"
			3 = "Operating System"
			4 = "Utilities"
			5 = "Do not re-boot"
		End ENUM
		Value = 1
	End Attribute
End Group
