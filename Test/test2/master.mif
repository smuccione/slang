		Name = "Temperature Probe Minimum"
		ID = 10
		Description = "The minimum temperature reading specified to be readable "
			  "by this probe in 1/10th degrees C. 0x80000000 denotes "
			  "'unknown'."
		Access = Read-Only
		Storage = Common
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Temperature Reading Lower Threshold - Non-critical"
		ID = 11
		Description = "The lower non-critical threshold for the temperature reading "
			  "set by the user, in 1/10th degrees C. 0x80000000 denotes "
			  "'unknown'."
		Access = Read-Write
		Storage = Common
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Temperature Reading Upper Threshold - Non-critical"
		ID = 12
		Description = "The upper non-critical threshold for the temperature probe, "
			  "in 1/10th degrees C. 0x80000000 denotes 'unknown'." 
		Access = Read-Write
		Storage = Common
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Temperature Reading Lower Threshold - Critical"
		ID = 13
		Description = "The lower critical threshold for the temperature probe, in "
			  "1/10 degrees C. 0x80000000 denotes 'unknown'." 
		Access = Read-Write
		Storage = Common
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Temperature Reading Upper Threshold - Critical"
		ID = 14
		Description = "The upper critical threshold for the temperature probe, in "
			  "/10th degrees C. 0x80000000 denotes 'unknown'." 
		Access = Read-Write
		Storage = Common
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Temperature Reading Lower Threshold - Non-recoverable"
		ID = 15
		Description = "The lower non-recoverable threshold for the temperature "
			  "probe, in 1/10th degrees C. 0x80000000 denotes 'unknown'." 
		Access = Read-Write
		Storage = Common
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Temperature Reading Upper Threshold - Non-recoverable"
		ID = 16
		Description = "The upper non-recoverable threshold for the temperature "
			  "probe, in 1/10th degrees C. 0x80000000 denotes 'unknown'." 
		Access = Read-Write
		Storage = Common
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Temperature Probe Resolution"
		ID = 17
		Description = "The resolution for the reading from this temperature probe, "
			  "in tenths of 1/10th degrees C. '0x80000000 denotes "
			  "'unknown'."
		Access = Read-Write
		Storage = Common
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Temperature Probe Tolerance"
		ID = 18
		Description = "The tolerance for the reading from this temperature probe, in "
			  "plus/minus 1/10 degrees C. 0x80000000 denotes 'unknown'." 
		Access = Read-Write
		Storage = Common
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Temperature Probe Accuracy"
		ID = 19
		Description = "The accuracy for the reading from this temperature probe, in "
			  "plus/minus hundredths of a percent. 0x80000000 denotes "
			  "'unknown' or'unsupported'."
		Access = Read-Write
		Storage = Common
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "FRU group Index"
		ID = 20
		Description = "Index into the FRU table. A value of -1 indicates that this "
			  "device is not an FRU." 
		Access = Read-Only
		Storage = Common
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Operational group Index"
		ID = 21
		Description = "Index into the Operational State table"
		Access = Read-Only
		Storage = Common
		Type = Integer
		Value = 0
	End Attribute
End Group
