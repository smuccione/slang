	Name = "Partition"
	Class = "DMTF|Partition|001"
	ID = 134
	Description = "This group describes the partitions on particular disks."
	Key = 1
	Pragma = "SNMP:1.3.6.1.4.1.412.2.4.24 ;"

	Start Attribute
		Name = "Partition Index"
		ID = 1
		Description = "The index into the partition table."
		Access = Read-Only
		Storage = Common
		Type = Integer
		Value = 0
