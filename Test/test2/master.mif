		Access = Read-Only
		Storage = Common
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Millisecond counter"
		ID = 2
		Description = "32 bit counter that gets incremented every millisecond"
		Access = Read-Only
		Storage = Common
		Type = Counter
		Value = 0
	End Attribute
	Start Attribute
		Name = "Cache Access Count"
		ID = 3
		Description = "64 bit counter that counts the number of times the cache has "
			  "been accessed. A value of 0x8000000000000000 denotes "
			  "'unknown'."
		Access = Read-Only
		Storage = Common
		Type = Counter64
		Value = 0
	End Attribute
	Start Attribute
		Name = "Cache Hit Count"
		ID = 4
		Description = "64 bit counter that counts the number of times there was a "
			  "cache hit. i.e. memory being accessed was in the Cache. A "
			  "value of 0x8000000000000000 denotes 'unknown'."
		Access = Read-Only
		Storage = Common
		Type = Counter64
		Value = 0
	End Attribute
	Start Attribute
		Name = "Partial Hit Count"
		ID = 5
		Description = "Counts the number of times there was a partial cache hit.  A "
			  "value of 0x8000000000000000 denotes 'unknown' or "
			  "'unsupported'."
		Access = Read-Only
		Storage = Specific
		Type = Counter64
		Value = 0
	End Attribute
	Start Attribute
		Name = "Hit Data Size"
		ID = 6
		Description = "On a partial hit the number of bytes that were available in "
			  "cache.  A value of 0x8000000000000000 denotes 'unknown' or "
			  "'unsupported'."
		Access = Read-Only
		Storage = Specific
		Type = Integer64
		Value = 0
	End Attribute
	Start Attribute
		Name = "Valid Usage"
		ID = 7
		Description = "The amount of cache currently holding valid data, in "
			  "kilobytes. A value of 0x80000000 denotes 'unknown' or "
			  "'unsupported'."
		Access = Read-Only
		Storage = Specific
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Dirty Usage"
		ID = 8
		Description = "The amount of cache data, in kilobytes, not yet written to "
			  "media. A value of 0x80000000 denotes 'unknown' or "
			  "'unsupported'."
		Access = Read-Only
		Storage = Specific
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Time of Last Detected Fault"
		ID = 9
		Description = "The number of seconds that have passed between power on the "
			  "last detected cache fault or failure."
		Access = Read-Only
		Storage = Specific
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Last Fault/Failure Detected"
		ID = 10
		Description = "The vendor-unique fault code associated with the most recent "
			  "fault or failure detected with this cache." 
		Access = Read-Only
		Storage = Specific
		Type = Integer
		Value = 0
	End Attribute
End Group
