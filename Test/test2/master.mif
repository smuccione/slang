	Class = "DMTF|Portable Battery|001"
	ID = 150
	Description = "This group defines general information about the portable battery(s) "
	  "in the system " 
	Key = 1
	Pragma = "SNMP:1.3.6.1.4.1.412.2.8.1 ;"

	Start Attribute
		Name = "Portable Battery Index"
		ID = 1
		Description = "The index into the portable battery table."
		Access = Read-Only
		Storage = Specific
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Portable Battery Location"
		ID = 2
		Description = "The location of the battery"
		Access = Read-Only
		Storage = Specific
		Type = DisplayString(64)
		Value = ""
	End Attribute
	Start Attribute
		Name = "Portable Battery Manufacturer"
		ID = 3
		Description = "The name of the company that manufactured the battery."
		Access = Read-Only
		Storage = Specific
		Type = DisplayString(64)
		Value = ""
	End Attribute
	Start Attribute
		Name = "Portable Battery Manufacture Date"
		ID = 4
		Description = "The battery manufacture date."
		Access = Read-Only
		Storage = Specific
		Type = Date
		Value = ""
	End Attribute
	Start Attribute
		Name = "Portable Battery Serial Number"
		ID = 5
		Description = "The serial number for this battery."
		Access = Read-Only
		Storage = Specific
		Type = DisplayString(64)
		Value = ""
	End Attribute
	Start Attribute
		Name = "Portable Battery Device Name"
		ID = 6
		Description = "Device name for this battery.  For instance, Duracell DR-36."
		Access = Read-Only
		Storage = Specific
		Type = DisplayString(64)
		Value = ""
	End Attribute
	Start Attribute
		Name = "Portable Battery Device Chemistry"
		ID = 7
		Description = "The battery chemistry.  For instance, Lithium-ion or Nickel "
			  "metal hydride." 
		Access = Read-Only
		Storage = Specific
		Type = Start ENUM
			1 = "Other"
			2 = "Unknown"
			3 = "Lead Acid"
			4 = "Nickel Cadmium"
			5 = "Nickel Metal Hydride"
			6 = "Lithium-ion"
			7 = "Zinc air"
			8 = "Lithium Polymer"
		End ENUM
		Value = "Unknown"
	End Attribute
	Start Attribute
		Name = "Portable Battery Design Capacity"
		ID = 8
		Description = "The design capacity of the battery in mWatt-hours. If this "
			  "attribute is not supported, value = 0x80000000" 
		Access = Read-Only
		Storage = Specific
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Portable Battery Design Voltage"
		ID = 9
		Description = "The design voltage of the battery in mVolts. If this attribute "
			  "is not supported, value = 0x80000000" 
		Access = Read-Only
		Storage = Specific
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Smart Battery Version"
		ID = 10
		Description = "The Smart Battery Data Specification version number supported "
		   "by this battery. If the battery does not support this function, "
		   "the value should be left blank."
		Access = Read-Only
		Storage = Specific
		Type = DisplayString(64)
		Value = ""
	End Attribute
	Start Attribute
		Name = "Full Charge Capacity"
		ID = 11
		Description = "The full charge capacity of the battery in mWatt-hours. "
		  "Comparison of this value to the battery Design Capacity "
		  "determines when the battery requires replacement.  The battery "
		  "industry has defined a battery's end of life to be when the "
		  "Full Charge Capacity falls below 80% of the Design "
		  "Capacity.  If this attribute is not supported, value = -1."
		Access = Read-Only
		Storage = Specific
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Remaining Capacity"
		ID = 12
		Description = "The battery's remaining capacity in mWatt-hours. This value "
			  "is used with Design Capacity or Full Charge Capacity to "
			  "calculate fuel gauge information.  If this attribute is not "
			  "supported, value = -1. "
		Access = Read-Only
		Storage = Specific
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Maximum Error"
		ID = 13
		Description = "The maximum error (as a percentage) in the Watt-hour data "
			  "reported by the battery. The maximum error indicates the "
			  "upper bound on how much additional energy the battery may "
			  "have above the energy it reports having. When this value "
			  "exceeds some value, for instance, 10%, some action must be "
			  "taken (for instance, fully discharge then fully charge the "
			  "battery) within some specified time (for instance, within two "
			  "recharge cycles of the battery). If the action is not taken "
			  "within the time frame, the error value will continue to "
			  "rise. If this attribute is not supported, value = -1 "
		Access = Read-Only
		Storage = Specific
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Portable Battery Charging Status"
		ID = 14
		Description = " The charging battery status"
		Access = Read-Only
		Storage = Specific
		Type = Start ENUM
			1 = "Other"
			2 = "Unknown"
			3 = "High"
			4 = "Low"
			5 = "Critical"
			6 = "Charging"
			7 = "Charging and High"
			8 = "Charging and Low"
			9 = "Charging and Critical"
			10 = "No System Battery"
		End ENUM
		Value = "Unknown"
	End Attribute
	Start Attribute
		Name = "Remaining Battery Time"
		ID = 15
		Description = "The remaining battery time in minutes, at the current average "
			  "system power consumption level." 
		Access = Read-Only
		Storage = Specific
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Remaining Time to Full Battery"
		ID = 16
		Description = "The remaining time to charge the battery fully in minutes,at "
			  "the current average system power consumption level and "
			  "charging rate" 
		Access = Read-Only
		Storage = Specific
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Power Unit Index"
		ID = 17
		Description = "This is the ID of the Power Unit (logical portable battery) to "
			  "which this Portable Battery belongs. This value matches up "
			  "with the Power Unit Table Index attribute defined in the Power "
			  "Unit Global Table." 
		Access = Read-Only
		Storage = Common
		Type = Integer
		Value = 0
	End Attribute
End Group
