// Superceded By:---
// Dependent Groups:   Storage Device
// 
//////////////////////////////////////////////////////////////////////
// This group defines events that are generated by Storage Devices.

Start Group
	Name = "Storage Devices Events"
	ID = 276
	Class = "EventGeneration|DMTF^^Storage Devices|001"
	Description = "Storage Devices events."
	Key = 5
	Pragma = "SNMP:1.3.6.1.4.1.412.2.10.1 ;"
	
	Start Attribute
		Name = "Storage Devices Event Type"
		ID = 1
		Description = "The type of Storage Devices event that has occurred."
		Access = Read-Only
		Storage = Specific
		Type = Start Enum
			0x01 = "Rebuild in Progress"
			0x02 = "Storage Device Readying"
			0x03 = "Storage Device Error"
			0x04 = "Self-Monitoring Warning"
		End Enum
		Value = 0x02
	End Attribute
	Start Attribute
		Name = "Event Severity"
		ID = 2
		Description = "The severity of this event."
		Access = Read-Only
		Storage = Specific
		Type = Start ENUM
			1 = "Monitor"
			2 = "Information"
			4 = "OK"
			8 = "Non-Critical"
			16 = "Critical"
			32 = "Non-Recoverable"
		End ENUM
		Value = 0x02	End Attribute	Start Attribute		Name = "Event Is State Based"		ID = 3		Description = "The value of this attribute determines whether the Event "		  "being reported is a state-based Event or not.  If the value "
		  "of this attribute is TRUE then the Event is state-based. "
		  "Else the Event is not state-based "
		Access = Read-Only
		Storage = Common
		Type = Start Enum
			0x00 = "False"
			0x01 = "True"
		End Enum
		Value = 0x00
	End Attribute
	Start Attribute
		Name = "Event State Key"
		ID = 4
		Description = "This attribute holds the key identifying a row of the Event "
		  "State group within the Component in which the event generator "
		  "group is located.  The Current State attribute within the row "
		  "contains the current state of this state-based event.  The "
		  "current state can be one of the four severities: OK, "
		  "Non-Critical, Critical, and Non-Recoverable. "
		Access = Read-Only
		Storage = Specific
		Type = Integer
		Value = 0x00
	End Attribute
	Start Attribute
		Name = "Associated Group"
		ID = 5
		Description = "The class name of the group that is associated with the "
		  "events defined in this EventGeneration group."
		Access = Read-Only
		Storage = Common
		Type =  String(40)
		Value = "DMTF|Storage Devices|001"
	End Attribute
	Start Attribute
		Name = "Event System"
		ID = 6
		Description = "The major functional aspect of the product causing the fault."
		Access = Read-Only
		Storage = Specific
		Type = Start Enum
			0x01 = "Other"
			0x02 = "Unknown"
		// Remaining values to be determined by the Instrumentation
		End Enum
		Value = 0x02
	End Attribute
	Start Attribute
		Name = "Event SubSystem"
		ID = 7
		Description = "The minor functional aspect of the product causing the fault."
		Access = Read-Only
		Storage = Specific
		Type = Start Enum
			0x01 = "Other"
			0x02 = "Unknown"
		// Remaining values to be determined by the Instrumentation
		End Enum
		Value = 0x02
	End Attribute
End Group
//////////////////////////////////////////////////////////////////////
// "EventGeneration|DMTF^^Structure Dependency Table|001"
// 
// Supercedes:	---
// Superceded By:---
// 
//////////////////////////////////////////////////////////////////////

Start Group
	Name = "Event Generation"
	Class = "EventGeneration|DMTF^^Structure Dependency Table|001"
	ID = 277
	Key = 5
	Pragma = "SNMP:1.3.6.1.4.1.412.2.4.68 ;"

	Start Attribute
		Name = "Event Type"
		ID = 1
		Description = "The type of event that has occurred."
		Access = Read-Only
		Storage = Specific
		Type = Start ENUM
			1 = "Power Supply Status Change"
			2 = "Cooling Device Status Change"
			3 = "Physical Device Status Change"
			4 = "Logical Device Status Change"
			5 = "System Up"
			6 = "Battery Status Change"
			7 = "Container Security Breach"
			8 = "Initialization Failure"
			9 = "Configuration Error"
		End ENUM
		Value = 1
	End Attribute
	Start Attribute
		Name = "Event Severity"
		ID = 2
		Description = "The severity of this event."
		Access = Read-Only
		Storage = Specific
		Type = Start ENUM
			1 = "Monitor"
			2 = "Information"
			4 = "OK"
			8 = "Non-Critical"
			16 = "Critical"
			32 = "Non-Recoverable"
		End ENUM
		Value = 1
	End Attribute
	Start Attribute
		Name = "Is Event State-Based?"
		ID = 3
		Description = "The value of this attribute determines whether the Event "
			  "being reported is a state-based Event or not. If the value of "
			  "this attribute is TRUE then the Event is "
			  "state-based. Otherwise the Event is not state-based." 
		Access = Read-Only
		Storage = Specific
		Type = Start ENUM
			0 = "False"
			1 = "True"
		End ENUM
		Value = 1
	End Attribute
	Start Attribute
		Name = "Event State Key"
		ID = 4
		Description = "A unique, single integer key into the EventState group if "
			  "this is a state-based Event.  If this is not a state-based "
			  "Event then this attribute's value is not defined." 
		Access = Read-Only
		Storage = Common
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Associated Group"
		ID = 5
		Description = "The class name of the group that is associated with the "
			  "events defined in this EventGeneration group." 
		Access = Read-Only
		Storage = Common
		Type = DisplayString(64)
		Value = ""
	End Attribute
	Start Attribute
		Name = "Event System"
		ID = 6
		Description = "The major functional aspect of the product causing the fault."
		Access = Read-Only
		Storage = Specific
		Type = Start ENUM
			0 = "Other"
			1 = "Unknown"
		End ENUM
		Value = 1
	End Attribute
	Start Attribute
		Name = "Event Subsystem"
		ID = 7
		Description = "The minor functional aspect of the product causing the fault."
		Access = Read-Only
		Storage = Specific
		Type = Start ENUM
			0 = "Other"
			1 = "Unknown"
		End ENUM
		Value = 1
	End Attribute
End Group
