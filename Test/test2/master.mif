		Name = "Event Severity"
		ID = 2
		Description = "The severity of this event."
		Access = Read-Only
		Storage = Specific
		Type = Start ENUM
			1 = "Monitor"
			2 = "Information"
			4 = "OK"
			8 = "Non-Critical"
			16 = "Critical"
			32 = "Non-Recoverable"
		End ENUM
		Value = 0x01	End Attribute	Start Attribute
		Name = "Event Is State Based"
		ID = 3
		Description = "The value of this attribute determines whether the Event "
		  "being reported is a state-based Event or not.  If the value "
