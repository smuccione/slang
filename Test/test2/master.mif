/////////////////////////////////////////////////////////////////////
/// "DMTF|Aggregate Physical Extent|001"//
// Supercedes:	---
// Superceded By:---
// Dependent Groups:   Volume Set//
//////////////////////////////////////////////////////////////////////
Start Group
	Name = " Aggregate Physical Extent "
	ID = 4
	Class = "DMTF|Aggregate Physical Extent|001"
	Description = "Summary information about the addressable logical blocks which are in "
	   "the same redundancy group and reside on the same physical device." 
	Key = 1
	Pragma = "SNMP:1.3.6.1.4.1.412.2.10.7 ;"
	
	Start Attribute
		Name = "Aggregate Physical Extent Index"
		ID = 1
		Description = "An index into the Aggregate Physical Extent table."
		Access = Read-Only
		Storage = Common
		Type = Integer
		Value = -1
	End Attribute
	Start Attribute
		Name = "Number of Blocks"
		ID = 2
		Description = "The total number of blocks (including the check data blocks) "
		  "contained in this aggregate p_extent.  The block size is the "
		  "same as the storage device associated with this aggregate "
		  "p_extent.  Note: If no redundancy group is associated with an "
		  "aggregate p_extent, then this indicates the number of "
		  "p_extent blocks that are available." 
		Access = Read-Only
		Storage = Specific
		Type = Integer64
		Value = 0
	End Attribute
	Start Attribute
		Name = "Number of Blocks of Check Data"
		ID =3
		Description = "The number of blocks contained in this aggregate p_extent to "
		  "be used as check data.  If the Aggregate p_extent is "
		  "available, then this value shall be zero." 
		Access = Read-Only
		Storage = Specific
		Type = Integer64
		Value = 0
	End Attribute
End Group
//////////////////////////////////////////////////////////////////////
