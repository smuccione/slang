//////////////////////////////////////////////////////////////////////
// "DMTF|Power Management Table|001"
// 
// Supercedes:	---
// Superceded By:---
// 
//////////////////////////////////////////////////////////////////////

Start Group
	Name = "Power Management Table"
	Class = "DMTF|Power Management Table|001"
	ID = 154
	Description = "This group defines the power management state of components and groups "
	  "within the system" 
	Key = 1
	Pragma = "SNMP:1.3.6.1.4.1.412.2.8.7 ;"

	Start Attribute
		Name = " Power Management Enabled/Disabled "
		ID = 1
		Description = "Enabled/Disabled state of power management on this device."
		Access = Read-Only
		Storage = Specific
		Type = Start ENUM
			1 = "Other"
			2 = "Unknown"
			3 = "Enabled"
			4 = "Disabled"
		End ENUM
		Value = "Disabled"
	End Attribute
	Start Attribute
		Name = "Current Power Management State"
		ID = 2
		Description = "The current PM state (D0,D1,D2,D3)."
		Access = Read-Only
		Storage = Specific
		Type = Start ENUM
			1 = "Other"
			2 = "Unknown"
			3 = "D0 - Working/Fully ON"
			4 = "D1 - Sleeping"
			5 = "D2 - Non-volatile sleep/Soft Off"
			6 = "D3 - OFF"
		End ENUM
		Value = "Unknown"
	End Attribute
	Start Attribute
		Name = "D1 Timer value "
		ID = 3
		Description = "The time-out value in milliseconds to go from D0 (full ON) to "
				  "D1 state.  If D1 state is not supported the value is -1. If "
			  "the transition is not controlled by a timer then the value is "
			  "0." 
		Access = Read-Only
		Storage = Specific
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "D2 Timer value "
		ID = 4
		Description = "The time-out value in milliseconds to go from the next higher  "
			  "supported state (either D0 or D1) to the D2 state.  If "
			  "D2 state is not supported the value is -1.  If the transition "
			  "is not controlled by a timer then the value is 0."
		Access = Read-Only
		Storage = Specific
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "D3 Timer value "
		ID = 5
		Description = "The time-out value in milliseconds to go from the next higher "
				  "supported state (either D0, D1, or D2) to the D3 state. If D3 "
			  "state is not supported the value is -1 meaning the device "
			  "can never be turned off. If the transition is not controlled "
			  "by a timer then the value is 0." 
		Access = Read-Only
		Storage = Specific
		Type = Integer
		Value = 0
	End Attribute
End Group
