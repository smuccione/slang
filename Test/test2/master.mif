//////////////////////////////////////////////////////////////////////
// "DMTF|Diagnostic Function Group|001"
// 
// Supercedes:	---
// Superceded By:---
// 
//////////////////////////////////////////////////////////////////////
Start Group
	Name = "Diagnostic Function Group"
	Class = "DMTF|Diagnostic Function Group|001"
	ID = 44
	Description = "This group defines the diagnostic functions that are provided by this "
	  "component for analyzing potential failures within the component. A "
	  "diagnostic function could be an actual test run against the "
	  "component, the results of a self-test of the component, an analysis "
	  "of failure information captured during a failure of the component, or "
	  "an analysis of the current state of the component." 
	Key = 1
	Pragma = "SNMP:1.3.6.1.4.1.412.2.4.56 ;"

	Start Attribute
		Name = "Diagnostic Function Table Index"
		ID = 1
		Description = "A unique identifier for this specific diagnostic function."
		Access = Read-Only
		Storage = Common
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Diagnostic Function Name"
		ID = 2
		Description = "A specific descriptive name of the diagnostic function, "
			  "including version information, if relevant." 
		Access = Read-Only
		Storage = Specific
		Type = DisplayString(64)
		Value = ""
	End Attribute
	Start Attribute
		Name = "Diagnostic Function Description"
		ID = 3
		Description = "A description of what this diagnostic function does."
		Access = Read-Only
		Storage = Specific
		Type = DisplayString(64)
		Value = ""
	End Attribute
	Start Attribute
		Name = "Exclusive Access Required"
		ID = 4
		Description = "Indicates whether this diagnostic function requires exclusive "
			  "access to the device or component, implying that the user or "
			  "management application must take some action within the "
			  "operating system to ensure that the device or component "
			  "cannot be used by any other function."
		Access = Read-Only
		Storage = Common
		Type = Start ENUM
			0 = "False"
			1 = "True"
		End ENUM
		Value = 1
	End Attribute
	Start Attribute
		Name = "Prerequisite Conditions"
		ID = 5
		Description = "Indicates what conditions must be met before this diagnostic "
			  "function can be run." 
		Access = Read-Only
		Storage = Common
		Type = Start ENUM
			1 = "Other"
			2 = "Unknown"
			3 = "No prerequisites"
			4 = "Wrap plug installed"
			5 = "No media installed"
			6 = "Scratch media installed"
			7 = "Test media installed"
			8 = "System reference diskette installed"
		End ENUM
		Value = 1
	End Attribute
	Start Attribute
		Name = "Prerequisite diagnostic function"
		ID = 6
		Description = "If non-0, this specifies the ID of another diagnostic "
			  "function that must be run immediately prior to this one." 
		Access = Read-Only
		Storage = Common
		Type = Integer
		Value = 0
	End Attribute
End Group
//////////////////////////////////////////////////////////////////////
// "DMTF|Diagnostic Request Group|001"
// 
// Supercedes:	---
// Superceded By:---
// 
//////////////////////////////////////////////////////////////////////
Start Group
	Name = "Diagnostic Request Group"
	Class = "DMTF|Diagnostic Request Group|001"
	ID = 45
	Description = "This group defines the attributes which a management application "
	  "uses to request an actual diagnostic analysis." 
	Pragma = "SNMP:1.3.6.1.4.1.412.2.4.57 ;"

	Start Attribute
		Name = "Diagnostic Function Reserve Key"
		ID = 1
		Description = "Indicates whether the interface to this component's "
			  "diagnostic functions is reserved. A zero value returned on a "
			  "get indicates that a reserve is already in effect.  A non-zero "
			  "value indicates that no reserve was in effect, and the "
			  "returned value may be used as a reserve key."
		Access = Read-Write
		Storage = Common
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Diagnostic Function Request"
		ID = 2
		Description = "The ID of the specific diagnostic function which is being "
			  "requested. If the interface is reserved, a set request to this "
			  "attribute should also set the Diagnostic Function Reserve Key "
			  "with the reserve key value." 
		Access = Read-Write
		Storage = Common
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Diagnostic Function Result"
		ID = 3
		Description = "The integer-based result code of the last diagnostic function run."
		Access = Read-Only
		Storage = Common
		Type = Integer
		Value = 0
	End Attribute
End Group
//////////////////////////////////////////////////////////////////////
// "DMTF|Diagnostic Results FRU Call|001"
// 
// Supercedes:	---
// Superceded By:---
// 
//////////////////////////////////////////////////////////////////////
Start Group
	Name = "Diagnostic Results FRU Call"
	Class = "DMTF|Diagnostic Results FRU Call|001"
