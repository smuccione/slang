			7 = "Most Frequently Used (MFU)"
			8 = "Data Dependent Multiple Algorithms"
		End ENUM
		Value = 1
	End Attribute
	Start Attribute
		Name = "Read Policy"
		ID = 13
		Description = "The policy that shall be employed by the cache for handling "
