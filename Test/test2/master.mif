		Name = "DMA Address Size"
		ID = 3
		Description = "The width of the DMA address."
		Access = Read-Only
		Storage = Common
		Type = Start ENUM
			1 = "Other"
			2 = "Unknown"
			3 = "8-bit"
			5 = "16-bit"
			6 = "32-bit"
			7 = "64-bit"
		End ENUM
		Value = 1
	End Attribute
