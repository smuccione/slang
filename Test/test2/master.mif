		Storage = Common
		Type = Start ENUM
			1 = "Other"
			2 = "Unknown"
			3 = "Read"
			4 = "Read-ahead"
			5 = "Read and Read-ahead"
			6 = "Determination per I/O"
		End ENUM
		Value = 1
	End Attribute
	Start Attribute
		Name = "Flush Timer"
		ID = 14
		Description = "The maximum amount of time, in seconds, dirty lines or "
			  "buckets may remain in the cache before they are flushed. A "
			  "value of zero indicated that a cache flush is not controlled "
			  "by a flushing timer." 
		Access = Read-Only
		Storage = Specific
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Associativity"
		ID = 15
		Description = "This defines the system cache associativity (direct-mapped, "
			  "2-way, 4-way, etc)." 
		Access = Read-Only
		Storage = Common
		Type = Start ENUM
			1 = "Other"
			2 = "Unknown"
			3 = "Direct Mapped"
			4 = "2-way Set-Associative"
			5 = "4-way Set-Associative"
			6 = "Fully Associative"
			7 = "8-way Set-Associative"
			8 = "16-way Set-Associative"
		End ENUM
		Value = 1
	End Attribute
End Group //////////////////////////////////////////////////////////////////////
