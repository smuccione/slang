		  "then the Type Description attribute shall be used. "
		Access = Read-Only
		Storage = Common
		Type =  Start Enum
			0x01 = "Other"
			0x02 = "Unknown"
			0x03 = "Rigid Disk Drive"
			0x04 = "Flexible Diskette Drive"
			0x06 = "Optical Write-Once/Read-Many (WORM) Drive"
			0x07 = "Magneto-Optical Drive"
			0x08 = "Compact Disk Drive"
			0x09 = "Flash Disk"
			0x0A = "Cartridge Rigid Disk Drive"
			0x0B = "Optical Floppy Drive"
			0x0C = "Tape Drive"
			0x0D = "Solid State"
			0x0E = "Media Changer"
			0x0F = "Digital Versatile Disk (DVD) Drive"
			0x10 = "Digital Versatile Disk (DVD) RAM Drive"
		End Enum
		Value = 0x02
	End Attribute
	Start Attribute
		Name = "Type Description"
		ID = 3
		Description = "A longer description of the storage device.  For example: 3.5 "
		  "inch flexible diskette drive using diskettes with a maximum "
		  "capacity of 1.44MB.  If 'Other' was specified above, then "
		  "this field shall be used.  Otherwise, the contents of this "
		  "optional field shall not contradict the Storage Device Type "
		  "specified above."
		Access = Read-Only
		Storage = Specific
		Type = String(64)
		Value = ""
	End Attribute
