	Name = " Aggregate Protected Space Extent "
	ID = 5
	Class = "DMTF|Aggregate Protected Space Extent|001"
	Description = "Summary information about the addressable logical blocks which are in "
	  "the same volume set and are derived from the same storage device." 
	Key = 1
