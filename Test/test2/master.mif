			2 = "Unknown"
			3 = "8-bit"
			4 = "8- and 16-bit"
			5 = "16-bit"
			6 = "32-bit"
			7 = "64-bit"
		End ENUM
		Value = 1
	End Attribute
	Start Attribute
		Name = "Bus Master"
		ID = 6
		Description = "Indicates whether the device is using DMA is a bus master."
		Access = Read-Only
		Storage = Common
		Type = Start ENUM
			1 = "Other"
			2 = "Unknown"
			3 = "logical device is not a bus master"
			4 = "logical device is a bus master"
		End ENUM
		Value = 1
	End Attribute
	Start Attribute
		Name = "Byte Mode"
		ID = 7
		Description = "Indicates whether DMA may execute in 'count by byte' mode."
		Access = Read-Only
		Storage = Common
		Type = Start ENUM
			1 = "Other"
			2 = "Unknown"
			3 = "DMA may not execute in 'count by byte' mode."
			4 = "DMA may execute in 'count by byte' mode."
		End ENUM
		Value = 1
	End Attribute
	Start Attribute
		Name = "Word Mode"
		ID = 8
		Description = "Indicates whether DMA may execute in 'count by word' mode."
		Access = Read-Only
		Storage = Common
		Type = Start ENUM
			1 = "Other"
			2 = "Unknown"
			3 = "DMA may not execute in 'count by word' mode."
			4 = "DMA may execute in 'count by word' mode."
		End ENUM
		Value = 1
	End Attribute
	Start Attribute
		Name = "Channel Timing"
		ID = 9
		Description = "DMA channel speed support."
		Access = Read-Only
		Storage = Common
		Type = Start ENUM
			1 = "Other"
			2 = "Unknown"
			3 = "ISA compatible"
			4 = "Type A"
			5 = "Type B"
			6 = "Type F"
		End ENUM
		Value = 1
	End Attribute
	Start Attribute
		Name = "Type-C Timing"
		ID = 10
		Description = "Indicates whether C type (burst) timing is "
		"supported."
		Access = Read-Only
		Storage = Common
		Type = Start ENUM
			1 = "Other"
			2 = "Unknown"
			3 = "ISA compatible"
			4 = "C type timing is not supported."
			5 = "C type timing is supported."
		End ENUM
		Value = 1
	End Attribute
End Group
//////////////////////////////////////////////////////////////////////
// "DMTF|System Resource Device Info|001"
// 
// Supercedes:	---
// Superceded By: DMTF|System Resource Device Info|002
// 
//////////////////////////////////////////////////////////////////////
Start Group
	Name = "System Resource Device Info"
	Class = "DMTF|System Resource Device Info|001"
	ID = 221
	Description = "This group describes the base level of Memory, I/O, DMA, and "
	  "INT (interrupt) resources that are used by a device in the system." 
	Key = 1
	Pragma = "SNMP:1.3.6.1.4.1.412.2.4.38 ;"

	Start Attribute
		Name = "Resource User"
		ID = 1
		Description = "A number that uniquely identifies this device. This number "
			  "may be derived from the 'device number' that is assigned by "
			  "'Plug N Play', or may be uniquely assigned by the component "
			  "instrumentation." 
		Access = Read-Only
		Storage = Common
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Device ID"
		ID = 2
		Description = "Physical Device ID from Config manager info. Equal to "
			  "the CISTPL_MANFID field for PCMCIA devices. 0xFFFFFFFF = "
			  "Unknown" 
		Access = Read-Only
		Storage = Specific
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Device Serial Number"
		ID = 3
		Description = "Device Serial Number from Config manager info. 0 = Undefined"
		Access = Read-Only
		Storage = Specific
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Logical Device ID - Class Code"
		ID = 4
		Description = "Logical device ID for PnP ISA devices, Class code for PCI "
			  "devices, CISTPL_FUNCID for PCMCIA devices. 0xFFFFFFFF = "
			  "Undefined, 0 = reserved"
		Access = Read-Only
		Storage = Specific
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Device Flags"
		ID = 5
		Description = "Device flags from config manager info. "
			  "Bit 0: 1 = device has been initialized, \n "
			  "Bit 1: 1 = device is enabled, \n " 
			  "Bit 2: 1 = device config has been locked, \n " 
			  "Bit 3: 1 = device has temporary config resources assigned, \n " 
			  "Bit 4: 1 = device is reconfigurable" 
		Access = Read-Only
		Storage = Specific
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Device Number"
		ID = 6
		Description = "Device Number for PCI Devices, Logical Device number for "
			  "PnP Devices. 0 otherwise." 
		Access = Read-Only
		Storage = Specific
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Function Number"
		ID = 7
		Description = "Function Number for PCI & EISA Devices. 0 otherwise."
		Access = Read-Only
		Storage = Specific
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Bus Type"
		ID = 8
		Description = "Bus number (0-255) for PCI Devices, Slot number for EISA and "
			  "PnP Devices, Card logical socket number for PCMCIA "
			  "devices. Zero otherwise." 
		Access = Read-Only
		Storage = Specific
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "CM Reserved"
		ID = 9
		Description = "Data from the Reserved field of the Configuration Manager bus "
			  "access structure, or 0." 
		Access = Read-Only
		Storage = Specific
		Type = Integer
		Value = 0
	End Attribute
End Group
