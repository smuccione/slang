	Start Attribute
		Name = "Volume Set Index"
		ID = 1
		Description = "An index into the Volume Set table."
		Access = Read-Only
		Storage = Common
		Type = Integer
		Value = -1
	End Attribute
		
	Start Attribute
		Name = "Name"
		ID = 2
		Description = "The name of the volume set."
		Access = Read-Only
		Storage = Specific
		Type = String(64)
		Value = ""
	End Attribute
		
	Start Attribute
		Name = "Total Storage Capacity"
		ID = 3
		Description = "The total size in bytes of the user data space of this volume "
		  "set."
		Access = Read-Only
		Storage = Specific
		Type = Integer64
		Value = 0
	End Attribute
	
