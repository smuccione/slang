		Name = "Error Data Size"
		ID = 16
		Description = "The size of the data transfer that caused the error,in "
		  "bits. Zero indicates no error, 0x80000000 denotes 'unknown'." 
		Access = Read-Only
		Storage = Specific
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Error Data"
		ID = 17
		Description = "Data captured during the erroneous Memory Array access. The "
		  "data occupies the first n bytes of the octet string required to "
		  "hold 'Error Data Size' bits of the data. Data is stored "
		  "least-significant byte first." 
		Access = Read-Only
		Storage = Specific
		Type = OctetString(64)
		Value = ""
	End Attribute
	Start Attribute
		Name = "Vendor Syndrome"
		ID = 18
		Description = "Vendor-specific syndrome or CRC data associated with the "
			  "erroneous access." 
		Access = Read-Only
		Storage = Specific
		Type = OctetString(64)
		Value = ""
	End Attribute
	Start Attribute
		Name = "Device Error Address"
		ID = 19
		Description = "Physical address of the error relative to the start of the "
			  "device, in bytes.  0x80000000 denotes 'unknown'." 
		Access = Read-Only
		Storage = Common
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Array Error Address"
		ID = 20
		Description = "Physical address of the kilobyte where the error is located, "
			  "relative to the bus for the Memory Array. 0x80000000 denotes "
			  "'unknown'." 
		Access = Read-Only
		Storage = Common
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Error Resolution"
		ID = 21
		Description = "Range in bytes that the error can be determined to be within,"
			  "when an Error Address is given. 0x80000000 denotes 'unknown'." 
		Access = Read-Only
		Storage = Common
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "FRU Group Index"
		ID = 22
		Description = "If this is a Field Replaceable Unit or if it is part of "
			  "another FRU, this provides an index into the FRU table; 'value "
			  "= -1' indicates that the group is not a FRU." 
		Access = Read-Only
		Storage = Common
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Operational Group Index"
		ID = 23
		Description = "The index into the Operational State Table for this device."
		Access = Read-Only
		Storage = Common
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Speed"
		ID = 24
		Description = "The speed of this memory device in Megahertz(MHz)"
			"(Note: nanoseconds = 1000/ MHz). A value of 0 indicates"
			" that the speed is unknown.)"
		Access = Read-Only
		Storage = Common
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Memory Channel Index"
		ID = 25
		Description = "The ID of the Memory Channel that this Memory"
			" Device is a part of."
		Access = Read-Only
		Storage = Common
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Number of Low-level Devices"
		ID = 26
		Description = "Identifies the number of low-level memory devices "
			"present on this Memory Device.  If the Memory Device's Memory "
			"Type is RDRAM, the value must be non-zero and identifies the "
			"number of RDRAM 'devices' present on the memory device."
		Access = Read-Only
		Storage = Common
		Type = Integer
		Value = 0
	End Attribute
End Group
