		Access = Read-Only
		Storage = Common
		Type = Start Enum
			0x00 = "False"
			0x01 = "True"
			0x02 = "Unknown"
		End Enum
		Value = 0x02
	End Attribute
End Group
//////////////////////////////////////////////////////////////////////
// "DMTF|Structure Dependency Table|001"
// 
// Supercedes:	---
// Superceded By:---
// 
//////////////////////////////////////////////////////////////////////
Start Group
	Name = "Structure Dependency Table"
	Class = "DMTF|Structure Dependency Table|001"
	ID = 198
	Description = "This group describes a table whose entries identify the structural "
	  "dependencies of elements on other elements in the system.  The "
	  "attributes in this group form a row of the table and the row has the "
	  "following structure:<dependency-index> <supporting-element-pointer> "
	  "<dependency-type> <dependent-element-pointer>.  The "
	  "<dependency-index> is the index of the row in the table. The "
	  "<dependency-element-pointer> can point either to a element in the "
	  "current Component or to an external Component.  The "
	  "<supporting-element-pointer> points to one of the structure tables in "
	  "the current Component." 
	Key = 1
	Pragma = "SNMP:1.3.6.1.4.1.412.2.4.68 ;"

	Start Attribute
		Name = "Dependency Index"
		ID = 1
		Description = "This is a unique index into the Structure Dependency Table."
		Access = Read-Only
		Storage = Common
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Supporting Element Group ID"
		ID = 2
		Description = "This attribute holds the Group ID of the structure table "
			  "(e.g. Physical Container Global Table, etc.) or other table "
			  "group within the current expandable component that describes "
			  "the supporting element. A supporting element Component ID is "
			  "not required because the supporting element is expected to "
			  "reside in the current Component that is implementing this "
			  "attribute."
		Access = Read-Only
		Storage = Common
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Supporting Element Row Key"
		ID = 3
		Description = "This attribute holds the Row Key to the structure table or "
			  "other table group within the current expandable component that "
			  "describes the supporting element. The Row Key is a KeyList "
			  "composed of Integers (or Enums) ONLY.  It is currently "
			  "represented as a string whose content is a "
			  "comma-separated list of Integers in ASCII form (i.e. the "
			  "individual keys), without any intervening spaces. If the "
			  "supporting element is not described by a table group then "
			  "this attribute must be set to a null string." 
		Access = Read-Only
		Storage = Specific
		Type = DisplayString(64)
		Value = ""
	End Attribute
	Start Attribute
		Name = "Dependency Type"
		ID = 4
		Description = "This attribute describes the type of dependency represented "
			  "by this entry in the Structure Dependency Table, "
			  "e.g. 'contains', or'provides power to', etc."
		Access = Read-Only
		Storage = Common
		Type = Start ENUM
			1 = "Other"
			2 = "Unknown"
			3 = "Contains"
			4 = "Provides Power To"
			5 = "Provides Cooling To"
			6 = "Connects To"
		End ENUM
		Value = 1
	End Attribute
	Start Attribute
		Name = "Dependent Element Component ID"
		ID = 5
		Description = "This is the Component ID of the dependent element in the "
			  "dependency relationship which is of the "
			  "form'<supporting-element> <dependency-relation> "
			  "<dependent-element>'.  If this attribute has a zero value then "
			  "the current component is being referenced. If it is non-zero "
			  "then an external component is being pointed to."
		Access = Read-Only
		Storage = Common
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Dependent Element Group ID"
		ID = 6
		Description = "This attribute contains the Group ID of the attribute group "
			  "that describes the dependent element within the component "
			  "identified by the attribute Dependent Element Component ID."
		Access = Read-Only
		Storage = Common
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Dependent Element Row Key"
		ID = 7
		Description = "This attribute holds the RowKey selecting the particular row "
			  "in the(table) group uniquely identified by the contents of "
			  "the attribute's Dependent Element Group ID and Dependent "
			  "Element Component ID. The Row Key is a KeyList composed of "
			  "Integers (or Enums) ONLY. It is currently represented as a "
			  "string whose content is a comma-separated list of Integers in "
			  "ASCII form (i.e. the individual keys), without any "
			  "intervening spaces. If the dependent element is not described "
			  "by a table group then this attribute must be set to a null "
			  "string" 
		Access = Read-Only
		Storage = Common
		Type = DisplayString(64)
		Value = ""
	End Attribute
End Group
