	End Attribute
	Start Attribute
		Name = "Cache Type"
		ID = 6
		Description = "Indicates Cache Type that is compatible with this resource."
		Access = Read-Only
		Storage = Common
		Type = Start ENUM
			1 = "Other"
			2 = "Unknown"
			3 = "Write-Back"
			4 = "Write-Through"
			5 = "Not Applicable"
		End ENUM
		Value = 1
	End Attribute
	Start Attribute
		Name = "Read-Write"
		ID = 7
		Description = "Indicates the read-write accessibility of this memory resource."
		Access = Read-Only
		Storage = Common
		Type = Start ENUM
			1 = "Other"
			2 = "Unknown"
			3 = "ROM (read only)"
			4 = "RAM (read/write)"
		End ENUM
		Value = 1
	End Attribute
End Group
//////////////////////////////////////////////////////////////////////
// "DMTF|System Resources 2|001"
// 
// Supercedes:	---
// Superceded By:---
// 
//////////////////////////////////////////////////////////////////////

Start Group
	Name = "System Resources 2"
	Class = "DMTF|System Resources 2|001"
	ID = 227
	Description = "This group describes the base level of Memory, I/O, DMA, and "
	  "INT (interrupt) resources that are used by a device in the system." 
	Key = 1
	Pragma = "SNMP:1.3.6.1.4.1.412.2.4.37 ;"

	Start Attribute
		Name = "System Resources Index"
		ID = 1
		Description = "A number that uniquely identifies the rows in this table."
		Access = Read-Only
		Storage = Common
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Resource User"
		ID = 2
		Description = "A unique number for each different 'resource user' that has "
			  "resources specified in this table." 
		Access = Read-Only
		Storage = Specific
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Resource Set"
		ID = 3
		Description = "A number used as the ID of a set of Memory, I/O, DMA and/or "
			  "INT resources for the resource user." 
		Access = Read-Only
		Storage = Specific
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Resource Assignment"
		ID = 4
		Description = "Describes the state of the assignment of this set of "
			  "resources. (Note: This value must be the same for all "
			  "resources within a given set.)" 
		Access = Read-Only
		Storage = Common
		Type = Start ENUM
			1 = "Other"
			2 = "Unknown"
			3 = "Allocated"
			4 = "Assignable"
			5 = "Temporary Assignment"
		End ENUM
		Value = 1
	End Attribute
	Start Attribute
		Name = "Resource Type"
		ID = 5
		Description = "The type of resource described by this row."
		Access = Read-Only
		Storage = Common
		Type = Start ENUM
			1 = "Other"
			2 = "Unknown"
			3 = "Memory"
			4 = "I/O"
			5 = "IRQ"
			6 = "DMA"
		End ENUM
		Value = 1
	End Attribute
	Start Attribute
		Name = "Resource Number"
		ID = 6
		Description = "DMA or IRQ number - 0 for Memory and I/O ranges. This is "
			  "the interrupt or DMA number relative to the bus that the "
			  "interrupt is sourced from." 
		Access = Read-Only
		Storage = Specific
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Resource Info ID"
		ID = 7
		Description = "ID of the row in the 'Info' table for this type of system "
			  "resource. E.g. if this Resource Type is 'I/O' then this would "
			  "be an index into the 'System Resource I/O Info' table." 
		Access = Read-Only
		Storage = Specific
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Start Address"
		ID = 8
		Description = "Starting physical address for this memory range, or the "
			  "minimum base address if this attribute is being used to "
			  "describe a programmable range. 0 for IRQ and DMA resources." 
		Access = Read-Only
		Storage = Specific
		Type = Integer64
		Value = 0
	End Attribute
	Start Attribute
		Name = "End Address"
		ID = 9
		Description = "Ending physical address (address of last byte) for this "
			  "memory range, or the maximum configurable base address if this "
			  "attribute is being used to describe a programmable range. 0 "
			  "for IRQ and DMA resources."  
		Access = Read-Only
		Storage = Specific
		Type = Integer64
		Value = 0
	End Attribute
	Start Attribute
		Name = "Resource Size"
		ID = 10
		Description = "Number of consecutive bytes that a memory or I/O resource "
			  "consumes. 0 for IRQ and DMA resources." 
		Access = Read-Only
		Storage = Specific
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Base Alignment"
		ID = 11
		Description = "Alignment of Start Address, in bytes. Indicates the "
			  "granularity of the increments in which a programmable range "
			  "can be set." 
		Access = Read-Only
		Storage = Specific
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Shareable"
		ID = 12
		Description = "Indicates whether the resource is shareable."
		Access = Read-Only
		Storage = Common
		Type = Start ENUM
			0 = "False"
			1 = "True"
			2 = "Unknown"
		End ENUM
		Value = 1
	End Attribute
	Start Attribute
		Name = "Shared"
		ID = 13
		Description = "Indicates whether this resource, or a portion of this "
			  "resource, is shared with another device." 
		Access = Read-Only
		Storage = Common
		Type = Start ENUM
			0 = "False"
			1 = "True"
			2 = "Unknown"
		End ENUM
		Value = 1
	End Attribute
End Group
