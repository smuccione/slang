//////////////////////////////////////////////////////////////////////
// "DMTF|Power Unit Global Table|001"
// 
// Supercedes:	---
// Superceded By:---
// 
//////////////////////////////////////////////////////////////////////

Start Group
	Name = "Power Unit Global Table"
	Class = "DMTF|Power Unit Global Table|001"
	ID = 160
	Description = "This global table describes all of the Power Units in this system "
	  "component. The unique index of each Power Unit is the key into this "
	  "table. A Power Unit is composed of potentially more than one Power "
	  "Supply in a redundant configuration. Individual power supplies are "
	  "described in the 'Power Supply' standard group. In that group, each "
	  "individual power supply entry will point to a Power Unit in this "
	  "table by using the index of the row in this table that describes the "
	  "Power Unit. If a Power Unit is redundant, more than one row in the "
	  "Power Supply group will point to it. If a Power Unit is not "
	  "redundant, then a single row in the Power Supply group will point to "
	  "it."
	Key = 1
	Pragma = "SNMP:1.3.6.1.4.1.412.2.4.66 ;"

	Start Attribute
		Name = "Power Unit Index"
		ID = 1
		Description = "The unique index given to each Power Unit being described by "
			  "this table. This unique index is the key into this table." 
		Access = Read-Only
		Storage = Common
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "Power Unit Redundancy Status"
		ID = 2
		Description = "Gives the redundancy status of the Power Unit.  'Fully "
			  "Redundant' means that all of the configured redundancy is "
			  "still available; 'Degraded Redundancy' means that some "
			  "failures have been experienced but some reduced amount of "
			  "redundancy is still available; 'Redundancy Lost' means that a "
			  "sufficient number of failures have been experienced that no "
			  "redundancy is available and the next failure experienced "
			  "within the Power Unit will cause overall Power Unit failure. "
		Access = Read-Only
		Storage = Common
		Type = Start ENUM
			1 = "Other"
			2 = "Unknown"
			3 = "Not Applicable; Unit not redundant"
			4 = "Offline"
			5 = "Fully Redundant"
			6 = "Degraded Redundancy"
			7 = "Redundancy Lost"
		End ENUM
		Value = 1
	End Attribute
End Group
