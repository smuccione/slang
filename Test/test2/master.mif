Start Group
	Name = " Protected Space Extent "
	ID = 179
	Class = "DMTF|Protected Space Extent|001"
	Description = "A ps_extent defines addressable logical block addresses on a single "
	  "storage device, excluding any logical blocks mapped as check data. "
	  "In addition the ps_extent contains the user data stripe depth mapping "
	  "information." 
	Key = 1
	Pragma = "SNMP:1.3.6.1.4.1.412.2.10.8 ;"
	
	Start Attribute
		Name = "Protected Space Extent  Index"
		ID = 1
		Description = "An index into the Protected Space Extent table."
		Access = Read-Only
		Storage = Common
		Type = Integer
		Value = -1
	End Attribute
	Start Attribute
		Name = "Start Address"
		ID = 2
		Description = "The starting LBA of the p_extent from which this ps_extent "
		"is derived."
		Access = Read-Only
		Storage = Specific
		Type = Integer64
		Value = 0
	End Attribute
	Start Attribute
		Name = "Number of Blocks"
		ID = 3
		Description = "The number of user data blocks contained in this ps_extent."
		Access = Read-Only
		Storage = Specific
		Type = Integer64
		Value = 0
	End Attribute
	Start Attribute
		Name = "Block Size"
		ID = 4
		Description = "The size in bytes of the blocks which form this ps_extent."
		Access = Read-Only
		Storage = Specific
		Type = Integer
		Value = 0
	End Attribute
	Start Attribute
		Name = "User Data Stripe Granularity Units"
		ID = 5
		Description = "This field specifies the units in which the User Data Stripe "
		"Depth is given."
		Access = Read-Only
		Storage = Common
		Type = Start Enum
			0x01 = "Other"
			0x02 = "Unknown"
			0x03 = "Bits"
			0x04 = "Bytes"
			0x05 = "16 bit words"
			0x06 = "32 bit double words"
			0x07 = "blocks"
		End Enum
		Value = 0x02
	End Attribute
	Start Attribute
		Name = "User Data Stripe Depth"
		ID = 6
		Description = "The number of granularity units which form the stripe size for "
		"this ps_extent."
		Access = Read-Only
		Storage = Specific
		Type = Integer
		Value = 0
	End Attribute
End Group
