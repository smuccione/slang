end

function Walk()
   dbuse       ( "d2.dbf", "d2", 1 )

   dbCreateFilter ( "d2 smoker.flt", 'ati ("smoker=yes", d2->desc ) != -1' );
   dbCreateFilter ( "d2 married.flt", 'ati ("married=yes", d2->desc ) != -1' );

   println ( "-------------------- NO FILTER ---------------- " );
   d2->dbGoTop()
   while ( !(d2->dbeof()) )
      println ( d2->recno(), "   NAME: ", d2->name, d2->desc )
      d2->dbskip()
   end
   println ( "\r\n\r\n" );

   println ( "--------------------- NOT SMOKERS - BACKWARDS ----------------- " );
   dbCloseFilter();
   dbOpenFilter ( "d2 smoker.flt", 0 );
   d2->dbGoBottom()
   while ( !(d2->dbbof()) )
      println ( d2->recno(), "   NAME: ", d2->name, d2->desc )
	d2->dbskip( - 1)
   end
   println ( "\r\n\r\n" );

   println ( "--------------------- NOT SMOKERS ----------------- " );
   d2->dbGoTop()
   dbCloseFilter();
   dbOpenFilter ( "d2 smoker.flt", 0 );
   while ( !(d2->dbeof()) )
      println ( d2->recno(), "   NAME: ", d2->name, d2->desc )
	d2->dbskip()
   end
   println ( "\r\n\r\n" );

   println ( "--------------------- SMOKERS ----------------- " );
   d2->dbGoTop()
   dbCloseFilter();
   dbOpenFilter ( "d2 smoker.flt", 1 );
   while ( !(d2->dbeof()) )
      println ( d2->recno(), "   NAME: ", d2->name, d2->desc )
	d2->dbskip()
   end
   println ( "\r\n\r\n" );

   println ( "--------------------- SMOKERS - REPEAT ----------------- " );
   d2->dbGoTop()
   while ( !(d2->dbeof()) )
      println ( d2->recno(), "   NAME: ", d2->name, d2->desc )
	d2->dbskip()
   end
   println ( "\r\n\r\n" );

   println ( "--------------------- SMOKERS - BACKWARDS----------------- " );
   d2->dbGoBottom()
   while ( !(d2->dbbof()) )
      println ( d2->recno(), "   NAME: ", d2->name, d2->desc )
	d2->dbskip(-1)
   end
   println ( "\r\n\r\n" );

   println ( "--------------------- MARRIED----------------- " );
   d2->dbGoTop()
   dbCloseFilter();
   dbOpenFilter ( "d2 married.flt", 1 );
   while ( !(d2->dbeof()) )
      println ( d2->recno(), "   NAME: ", d2->name, d2->desc )
	d2->dbskip()
   end
   println ( "\r\n\r\n" );

   println ( "--------------------- SMOKERS & MARRIED----------------- " );
   d2->dbGoTop()
   dbCloseFilter();
   dbOpenFilter ( "d2 smoker.flt", 1 );
   dbOpenFilter ( "d2 married.flt", 1 );
   while ( !(d2->dbeof()) )
      println ( d2->recno(), "   NAME: ", d2->name, d2->desc )
	d2->dbskip()
   end
   println ( "\r\n\r\n" );

   println ( "---------------------MARRIED & SMOKERS ----------------- " );
   d2->dbGoTop()
   dbCloseFilter();
   dbOpenFilter ( "d2 married.flt", 1 );
   dbOpenFilter ( "d2 smoker.flt", 1 );
   while ( !(d2->dbeof()) )
      println ( d2->recno(), "   NAME: ", d2->name, d2->desc )
	d2->dbskip()
   end
   println ( "\r\n\r\n" );

   println ( "---------------------MARRIED & SMOKERS - REPEAT ----------------- " );
   d2->dbGoTop();
   while ( !(d2->dbeof()) )
      println ( d2->recno(), "   NAME: ", d2->name, d2->desc )
	d2->dbskip()
   end
   println ( "\r\n\r\n" );

   println ( "---------------------MARRIED & SMOKERS - REPEAT -BACKWARDS ----------------- " );
   d2->dbGoBottom();
   while ( !(d2->dbbof()) )
      println ( d2->recno(), "   NAME: ", d2->name, d2->desc )
	d2->dbskip(-1)
   end
   println ( "\r\n\r\n" );

   println ( "---------------------NOT MARRIED & SMOKERS ----------------- " );
   d2->dbGoTop()
   dbCloseFilter();
   dbOpenFilter ( "d2 married.flt", 0 );
   dbOpenFilter ( "d2 smoker.flt", 1 );
   while ( !(d2->dbeof()) )
      println ( d2->recno(), "   NAME: ", d2->name, d2->desc )
	d2->dbskip()
   end
   println ( "\r\n\r\n" );

   println ( "---------------------MARRIED & NOT SMOKERS ----------------- " );
   d2->dbGoTop()
   dbCloseFilter();
   dbOpenFilter ( "d2 married.flt", 1 );
   dbOpenFilter ( "d2 smoker.flt", 0 );
   while ( !(d2->dbeof()) )
      println ( d2->recno(), "   NAME: ", d2->name, d2->desc )
	d2->dbskip()
   end
   println ( "\r\n\r\n" );

   println ( "---------------------NOT MARRIED & NOT SMOKER ----------------- " );
   dbCloseFilter();
   d2->dbGoTop()
   dbOpenFilter ( "d2 married.flt", 0 );
   dbOpenFilter ( "d2 smoker.flt", 0 );
   while ( !(d2->dbeof()) )
      println ( d2->recno(), "   NAME: ", d2->name, d2->desc )
	d2->dbskip()
   end
   println ( "\r\n\r\n" );

   d2->dbclose()
end

function main()
	println ( "starting" );
	MakeFile();
	Walk();
end
