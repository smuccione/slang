f<[
	library c:\fgl\libs\system.flb
	.
	class DropboxFileSystemInterface
		inherit	DavFileSystemStatus
		

		private:
			local	file
			local	userId
			
			local	web
			
			local	appKey = "uzgkp8xgv9yoplk"
			local	appSecret = "8xzshua5obltcod"


		public:
			method new ( userId, password )
				
				web = new ( "webClient")
				web.domain = "api.Dropbox.com"
				web.ssl = 1
				web.submit ( "1/oauth/request_token", "" )
				
				x = web.page()
				x = split2 ( web.page(), "=", "&" )
				y = aArray()
				y.add ( x )
				
				
				
				return ( 1 )
			end

			method GetWebDavProperties ( fName )
				local data

				fName = ::basePath + fName
				
				data = fileReadAscii ( fName+":WebDav$Data" )

				if ( data )
					return ( unpack ( data ) )
				else
					return aArray()
				end
			end

			method SetWebDavProperties ( fName, props )
				local data

				fName = ::basePath + fName

				return fileWriteAscii ( fName+":WebDav$Data", pack ( props ) )
			end

			method MakeDirectory ( dir )
				dir = ::basePath + dir
				if ( mkDir ( dir ) )
					return 201
				else
					switch ( getLastError() )
						case 3			// need intermediaries
							return 409
						case 183		// already exists
							return 405
						default:
							return 403
					end
				end
			end
			
			method Delete ( dir )
				dir = ::basePath + dir
				
				if ( fEraseX ( dir ) )
					return ( 204 )
				end
				return ( 404 )
			end

			method Move ( src, dst )
				src = ::basePath + src
				dst = ::basePath + dst
				
				if ( fMoveX ( src, dst ) )
					return ( 204 )
				end
				return ( 404 )
			end

			method Copy ( src, dst )
				src = ::basePath + src
				dst = ::basePath + dst
				
				if ( fCopyX ( src, dst ) )
					return ( 204 )
				end
				return ( 404 )
			end

			method GetDir ( pathP, depth )
				local ret, ret2
				
				path = ::basePath + pathP;

				switch ( upper ( depth ) )
					case '0'
						if ( path[len(path)] == '\' )
							path = left ( path, len ( path ) - 1 )
						end
						
						if ( path == '\' )
							return ( { { '\', 0, webGmt(), 0, 0x00000010, 0 } })
						end
						ret = dir ( path )

						if ( !ret && (path[1] != '\') )
							ret = dir ( '\' + path )
						end
						
						for ( loop = 1; loop <= len ( ret ); loop++ )
							if ( !(ret[loop][5] & 0x00000010) )
								ret[loop][7] = ::GetWebDavProperties ( pathP )
							end
						end
//						debugBreak()
						if ( pathP == "" )
							ret[1][1] = ""
						end
						return ret;
					case '1'
						if ( right ( path, 1 ) == '\' )
							path = path + '*'
						end

						if ( path == '\*' )
							path = 'c:\*'
						end
						ret = dir ( path )
						if ( !ret && (path[1] != '\') )
							ret = dir ( '\' + path )
						end
						for ( loop = 1; loop <= len ( ret ); loop++ )
							if ( !(ret[loop][5] & 0x00000010) )
								ret[loop][7] = ::GetWebDavProperties ( pathP + '\' + ret[loop][1] )
							end
						end
						break;
					case 'INFINITY'
						if ( right ( path, 1 ) == '\' )
							path = path + '*'
						end

						ret = dir ( path )
						for ( loop = 1; loop <= len ( ret ); loop++ )
							if ( !(ret[loop][5] & 0x00000010) )
								ret[loop][7] = ::GetWebDavProperties ( pathP + '\' + ret[loop][1] )
							end
						end
						break;
				end

				if ( (len ( ret ) == 1) && (ret[1][5] & 0x00000010) && (depth != '0') )
					return ( ::GetDir ( pathP + '\', depth ) )
				end
				
				return ( ret )
			end

			method ReadFile ( fileName )
				local data 

				fileName = ::basePath + fileName;

				return fileReadAscii ( fileName )
			end

			method WriteFile ( fileName, data )
				local handle
				
				fileName = ::basePath + fileName;
				
				if ( isFile ( fileName, 0 ) )
					openMode = FileConstants::_O_RDWR | FileConstants::_O_TRUNC | FileConstants::_O_BINARY
				
					if ( (handle = fOpen ( fileName, openMode )) == -1 )
						return ( 404 );
					end
					fWrite ( handle, data )
					fClose ( handle )
					return ( 204 )
				else
					openMode = FileConstants::_O_RDWR | FileConstants::_O_CREAT | FileConstants::_O_BINARY
						
					if ( (handle = fOpen ( fileName, openMode )) == -1 )
						return ( 403 );
					end
					fWrite ( handle, data )
					fClose ( handle )
					return ( 201 );
				end
			end

	end

    function loginDigest( userid, response, hashMethod, httpMethod, username, realm, qop, uri, nonce, clientnonce, nonceCount )
		local   h1
		local   h2
		local   kd
		local   pass
		local 	a1, a2

//		if ( ! ::user.GetRecord( userid ) )
//			::errmsg = "Unable to locate user account."
//			return( 0 )
//		end
//		pass = ::user.data.password
		pass = "test"
		
		switch ( upper ( hashMethod ) )
		  case "MD5"
			a1 = userName + ":" +  realm + ":" + pass
			h1 = hashMD5 ( a1 )
			break;
		  case "MD5-SESS"
			a1 = userName + ":" +  realm + ":" + pass
			h1 = hashMD5 ( hashMD5 ( a1 ) + ":" + nonce + ":" + clientnonce )
			break;
		end
		
		switch ( upper ( qop ) )
		  case "AUTH-INT"
			a2 = httpMethod +":" +  uri
			h2 = hashMD5 ( a2 )
			break;
		  case "AUTH"
		  default:
			a2 = httpMethod +":" +  uri
			h2 = hashMD5 ( a2 )
			break;
		end

		switch ( upper ( qop ) )
		  case "AUTH"
		  case "AUTH-INT"
			kd = sprintf ( "%s:%s:%s:%s:%s:%s", h1, nonce, nonceCount, clientNonce, qop, h2 )
			kd = hashMD5 ( kd )
			break;
		  default:
			kd = hashMD5 ( h1 + ":" + nonce + ":" + h2 )
			break;
		end

		if ( kd != response )
			// password doesn't match
			return ( 0 )
		end

		new ( "cookie").set( "Zude", "logged in", webGmt( time + timeOut )  )

		return( 1 )

	END
	
	function convertPath ( path )
		if ( upper ( left ( path, 7 ) ) == '\DAV.AP' )
			path = mid ( path, 7, len ( path ) )
		elseif ( upper ( left ( path, 4 ) ) == '\DAV' )
			path = mid ( path, 4, len ( path ) )
		end
		return ( path )
	end
	
	function encodeProp ( nameSpace, propName )
		return ( webEncodeUrl ( nameSpace ) + ":" + webEncodeUrl ( propName ) )
	end
	
	function decodePropNameSpace ( encProp )
		return ( webDecodeUrl ( token ( encProp, ":", 1 ) ) )
	end
	
	function decodePropName ( encProp )
		return ( webDecodeUrl ( token ( encProp, ":", 2 ) ) )
	end
	
	class DavFileSystemStatus
		const	SUCCESS		= 0
		const	FORBIDDEN	= 1
		const	CONFLICT	= 2
		const	UNSUPPORTED	= 3
		const	DISK_FULL	= 4
		const	LOCKED		= 5
		const	NOT_FOUND	= 6
	end

	class DosFileSystemInterface
		inherit	DavFileSystemStatus
		
		local	basePath = 'c:\tmp\'
		
		private:
			local	file
			local	userId


		public:
			method new ( userId, password )
				return ( 1 )
			end

			method GetWebDavProperties ( fName )
				local data

				fName = ::basePath + fName
				
				data = fileReadAscii ( fName+":WebDav$Data" )

				if ( data )
					return ( unpack ( data ) )
				else
					return aArray()
				end
			end

			method SetWebDavProperties ( fName, props )
