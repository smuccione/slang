function ains ( array, start )
   local loop

   loop = start

   for ( loop := len ( array ); loop >= start; loop-- )
      array[loop + 1] := array[loop]
   end

   array[start] = NIL
end

function adel ( array, start )
   local loop

   for ( loop := start; loop <= len ( array ) - 1; loop++ )
      array[loop] = array[loop + 1]
   end

   array[loop] = NIL
end

function disp ( array )
  println ( "-----------------------" )

  for ( loop := 1; loop <= len ( array ); loop++ )
     print ( array[loop], " " )
  end
  println()
end


